@prefix sh: <http://www.w3.org/ns/shacl#> .

@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gx: <https://example.org/test/2511#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .

gx:LegalPersonShape
	a sh:NodeShape ;
	sh:targetClass gx:LegalPerson ;
	sh:property [ sh:path gx:legalName ;
				  sh:name "legal name" ;
				  sh:order 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:registrationNumber ;
				  sh:name "registration number" ;
				  sh:order 2 ;
				  sh:minCount 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:legalAddress ;
				  sh:name "legal address" ;
				  sh:order 3 ;
				  sh:minCount 1 ;
				  sh:maxCount 1 ;
				  sh:node gx:AddressShape ] ;
	sh:property [ sh:path gx:headquarterAddress ;
				  sh:name "headquarter address" ;
				  sh:order 4 ;
				  sh:minCount 1 ;
				  sh:maxCount 1 ;
				  sh:node gx:AddressShape ] ;
	sh:property [ sh:path gx:leiCode ;
				  sh:name "lei code" ;
				  sh:order 5 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:parentOrganisation ;
				  sh:name "parent organisation" ;
				  sh:order 6 ;
				  sh:nodeKind sh:IRI ] ;
	sh:property [ sh:path gx:subOrganisation ;
				  sh:name "sub organisation" ;
				  sh:order 7 ;
				  sh:nodeKind sh:IRI ] ;
	sh:property [ sh:path gx:termsAndConditions ;
				  sh:name "terms and conditions" ;
				  sh:order 8 ;
				  sh:minCount 1 ;
				  sh:maxCount 1 ;
				  sh:node gx:TermsAndConditionsShape ] ;
.

gx:AddressShape
	a sh:NodeShape ;
	sh:targetClass vcard:Address ;
	sh:property [ sh:path vcard:country-name ;
				  sh:name "country-name" ;
				  sh:order 1 ;
				  sh:minCount 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path vcard:gps ;
				  sh:name "gps" ;
				  sh:order 2 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path vcard:street-address ;
				  sh:name "street-address" ;
				  sh:order 3 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path vcard:postal-code ;
				  sh:name "postal-code" ;
				  sh:order 4 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path vcard:locality ;
				  sh:name "locality" ;
				  sh:order 5 ;
				  sh:datatype xsd:string ] ;
.

gx:TermsAndConditionsShape
	a sh:NodeShape ;
	sh:targetClass gx:TermsAndConditions ;
	sh:property [ sh:path gx:content ;
				  sh:name "content" ;
				  sh:order 1 ;
				  sh:minCount 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:anyURI ] ;
	sh:property [ sh:path gx:hash ;
				  sh:name "hash" ;
				  sh:order 2 ;
				  sh:minCount 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
.
