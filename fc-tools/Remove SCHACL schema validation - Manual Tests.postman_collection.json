            ],
            "body": {
              "mode": "raw",
              "raw": "@prefix sh: <http://www.w3.org/ns/shacl#> .\n@prefix gax-validation: <https://w3id.org/gaia-x/2511#> .\n@prefix gx: <https://w3id.org/gaia-x/2511#> .\n@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .\n\ngax-validation:ServiceOfferingShape\n\ta sh:NodeShape ;\n\tsh:targetClass gx:ServiceOffering ;\n\tsh:property [ sh:path gx:dataAccountExport ;\n\t\t\t\t  sh:name \"data account export\" ;\n\t\t\t\t  sh:minCount 1 ;\n\t\t\t\t  sh:datatype xsd:string ] ;\n."
            },
