<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet author="saackef" id="2026-04-16-asset-links-sequence">
        <createSequence sequenceName="asset_links_id_seq" startValue="1" incrementBy="50"/>
    </changeSet>

    <changeSet author="saackef" id="2026-04-16-asset-links-table">
        <createTable tableName="asset_links">
            <column name="id" type="BIGINT" defaultValueSequenceNext="asset_links_id_seq">
                <constraints primaryKey="true" primaryKeyName="pk_asset_links" nullable="false"/>
            </column>
            <column name="source_id" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="target_id" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="link_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="TEXT"/>
        </createTable>
    </changeSet>

    <changeSet author="saackef" id="2026-04-16-asset-links-unique-constraint">
        <addUniqueConstraint tableName="asset_links"
            columnNames="source_id, target_id, link_type"
            constraintName="uq_asset_link"/>
    </changeSet>

    <changeSet author="saackef" id="2026-04-16-asset-links-source-index">
        <createIndex tableName="asset_links" indexName="idx_asset_links_source">
            <column name="source_id"/>
        </createIndex>
    </changeSet>

    <changeSet author="saackef" id="2026-04-16-asset-links-target-index">
        <createIndex tableName="asset_links" indexName="idx_asset_links_target">
            <column name="target_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
