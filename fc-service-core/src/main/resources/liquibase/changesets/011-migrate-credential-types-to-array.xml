<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet author="peleskek" id="2026-04-01-migrate-credential-types-to-array">
        <comment>Migrate credential_types from CSV VARCHAR to PostgreSQL TEXT[] array for better querying</comment>

        <!-- 1. Add new array column -->
        <addColumn tableName="assets">
            <column name="credential_types_array" type="text[]">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="assets_aud">
            <column name="credential_types_array" type="text[]"/>
        </addColumn>

        <!-- 2. Migrate data: CSV → array (trim each element, drop blanks) -->
        <sql>
            UPDATE assets
            SET credential_types_array = ARRAY(
                SELECT trim(t) FROM unnest(string_to_array(credential_types, ',')) AS t
                WHERE trim(t) != ''
            )
            WHERE credential_types IS NOT NULL AND credential_types != '';
        </sql>

        <sql>
            UPDATE assets_aud
            SET credential_types_array = ARRAY(
                SELECT trim(t) FROM unnest(string_to_array(credential_types, ',')) AS t
                WHERE trim(t) != ''
            )
            WHERE credential_types IS NOT NULL AND credential_types != '';
        </sql>

        <!-- 3. Drop old CSV column -->
        <dropColumn tableName="assets" columnName="credential_types"/>
        <dropColumn tableName="assets_aud" columnName="credential_types"/>

        <!-- 4. Rename array column to credential_types -->
        <renameColumn tableName="assets"
                      oldColumnName="credential_types_array"
                      newColumnName="credential_types"
                      columnDataType="text[]"/>

        <renameColumn tableName="assets_aud"
                      oldColumnName="credential_types_array"
                      newColumnName="credential_types"
                      columnDataType="text[]"/>

    </changeSet>

</databaseChangeLog>
