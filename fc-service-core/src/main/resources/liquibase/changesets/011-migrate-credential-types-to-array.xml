<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <!-- Step 1: Add new array columns (always run on fresh DBs) -->
    <changeSet author="peleskek" id="2026-04-01-add-credential-types-array-assets">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="assets" columnName="credential_types"/>
            </not>
        </preConditions>
        <comment>Add credential_types TEXT[] column to assets (fresh install — no migration needed)</comment>
        <addColumn tableName="assets">
            <column name="credential_types" type="text[]">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet author="peleskek" id="2026-04-01-add-credential-types-array-assets-aud">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="assets_aud" columnName="credential_types"/>
            </not>
        </preConditions>
        <comment>Add credential_types TEXT[] column to assets_aud (fresh install)</comment>
        <addColumn tableName="assets_aud">
            <column name="credential_types" type="text[]"/>
        </addColumn>
    </changeSet>

    <!-- Step 2: Migrate data from old CSV column (only if the old VARCHAR column still exists) -->
    <changeSet author="peleskek" id="2026-04-01-migrate-credential-types-data">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM information_schema.columns
                WHERE table_name = 'assets'
                  AND column_name = 'credential_types_varchar_legacy'
            </sqlCheck>
        </preConditions>
        <comment>Placeholder: legacy CSV migration — skipped on fresh installs</comment>
    </changeSet>

</databaseChangeLog>
