<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet author="saackef" id="2026-04-21-provenance-credentials-table">
        <createTable tableName="provenance_credentials">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="asset_id" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="asset_version" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="credential_id" type="VARCHAR(500)">
                <constraints unique="true"/>
            </column>
            <column name="issuer" type="VARCHAR(500)"/>
            <column name="issued_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="provenance_type" type="VARCHAR(32)"/>
            <column name="credential_content" type="TEXT"/>
            <column name="credential_format" type="VARCHAR(20)"/>
            <column name="verified" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="verification_timestamp" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="verification_result" type="JSONB"/>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="last_modified_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
    </changeSet>

    <changeSet author="saackef" id="2026-04-21-provenance-credentials-idx-asset-issued">
        <!-- Supports list-by-asset queries ordered by issuedAt DESC -->
        <createIndex tableName="provenance_credentials" indexName="idx_prov_cred_asset_issued">
            <column name="asset_id"/>
            <column name="issued_at"/>
        </createIndex>
    </changeSet>

    <changeSet author="saackef" id="2026-04-21-provenance-credentials-idx-asset-version">
        <!-- Supports list-by-asset-version queries -->
        <createIndex tableName="provenance_credentials" indexName="idx_prov_cred_asset_version">
            <column name="asset_id"/>
            <column name="asset_version"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
