@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .

@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix did: <https://www.w3.org/TR/did-core/#> .
@prefix gx: <https://w3id.org/gaia-x/2511#> .

gx:PhysicalResourceShape
	a sh:NodeShape ;
	sh:targetClass gx:PhysicalResource ;
	sh:property [ sh:path gx:maintainedBy ;
				  sh:name "maintained by" ;
				  sh:order 1 ;
				  sh:minCount 1 ;
				  sh:nodeKind sh:IRI ] ;
	sh:property [ sh:path gx:ownedBy ;
				  sh:name "owned by" ;
				  sh:order 2 ;
				  sh:minCount 0 ;
				  sh:nodeKind sh:IRI ] ;
	sh:property [ sh:path gx:manufacturedBy ;
				  sh:name "manufactured by" ;
				  sh:order 3 ;
				  sh:minCount 0 ;
				  sh:nodeKind sh:IRI ] ;
	sh:property [ sh:path gx:locationAddress ;
				  sh:name "location address" ;
				  sh:order 4 ;
				  sh:minCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:aggregationOf ;
				  sh:name "aggregation of" ;
				  sh:order 1 ;
				  sh:minCount 0 ;
				  sh:nodeKind sh:IRI ] ;
	sh:property [ sh:path gx:name ;
				  sh:name "name" ;
				  sh:order 2 ;
				  sh:minCount 0 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path dct:description ;
				  sh:name "description" ;
				  sh:order 3 ;
				  sh:minCount 0 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
.
