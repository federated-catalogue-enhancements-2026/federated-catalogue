@prefix sh: <http://www.w3.org/ns/shacl#> .

@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix did: <https://www.w3.org/TR/did-core/#> .
@prefix gx: <https://w3id.org/gaia-x/2511#> .

gx:GPUShape
	a sh:NodeShape ;
	sh:targetClass gx:GPU ;
	sh:property [ sh:path gx:gpuGeneration ;
				  sh:name "gpu generation" ;
				  sh:order 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:memorySize ;
				  sh:name "memory size" ;
				  sh:order 2 ;
				  sh:maxCount 1 ;
				  sh:node gx:MeasureShape ] ;
	sh:property [ sh:path gx:memoryType ;
				  sh:name "memory type" ;
				  sh:order 3 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:connection ;
				  sh:name "connection" ;
				  sh:order 4 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:name ;
				  sh:name "name" ;
				  sh:order 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:vendor ;
				  sh:name "vendor" ;
				  sh:order 2 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
.

gx:MeasureShape
	a sh:NodeShape ;
	sh:targetClass gx:Measure ;
	sh:property [ sh:path gx:value ;
				  sh:name "value" ;
				  sh:order 1 ;
				  sh:minCount 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:float ] ;
	sh:property [ sh:path gx:unit ;
				  sh:name "unit" ;
				  sh:order 2 ;
				  sh:minCount 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
.
