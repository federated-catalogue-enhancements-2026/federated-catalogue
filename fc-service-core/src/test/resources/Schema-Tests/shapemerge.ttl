] ;
        sh:property     [ skos:example    "'ML', 'Classification'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Keywords that describe / tag the service." ;
                          sh:name         "keyword" ;
                          sh:order        7 ;
                          sh:path         dcat:keyword
] ;
        sh:targetClass  gx:Storage .

gx:PhysicalNodeShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'Example Resource placed somewhere in Europe'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A more detailed description of resource." ;
                          sh:maxCount     1 ;
                          sh:name         "description" ;
                          sh:order        2 ;
                          sh:path         dct:description
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "Participant owning the resource." ;
                          sh:name         "owned by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:ownedBy
] ;
        sh:property     [ skos:example    "'a structured object of type gpu, e.g. GPU:memoryType=DDR6, GPU:memorySize:value=24 and GPU:memorySize:value:unit=GB'" ;
                          sh:description  "Description of GPU(s) of this node." ;
                          sh:name         "gpu" ;
                          sh:node         gx:GPUShape ;
                          sh:order        2 ;
                          sh:path         gx:gpu
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "Participant manufacturing the resource." ;
                          sh:name         "manufactured by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:manufacturedBy
] ;
        sh:property     [ skos:example    "'a structured object of type measure, e.g. measure:value=950 and measure:unit=GB'" ;
                          sh:description  "Size of RAM of this node" ;
                          sh:name         "ramsize" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        3 ;
                          sh:path         gx:ramsize
] ;
        sh:property     [ skos:example    "'Atlantic Ocean +00-025/'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A list of physical GPS in ISO 6709:2008/Cor 1:2009 format." ;
                          sh:name         "location g p s" ;
                          sh:order        5 ;
                          sh:path         gx:locationGPS
] ;
        sh:property     [ skos:example    "'a structured object of type cpu, e.g. CPU:numberOfCores=4, CPU:frequency:value=3.0 and CPU:frequency:measure:unit=GHz'" ;
                          sh:description  "Description of CPU(s) of this node" ;
                          sh:name         "cpu" ;
                          sh:node         gx:CPUShape ;
                          sh:order        1 ;
                          sh:path         gx:cpu
] ;
        sh:property     [ skos:example    "'a structured object of type harddrive, e.g. harddrive:productid=6CX68AV, and harddrive:name=Xeon Platinum 8280,and harddrive:manufacture=NVIDA; harddrive:size:value=1000, harddrive:size:unit=GB, and harddrive:type=SSD'" ;
                          sh:description  "Description of disk(s) of this nodes" ;
                          sh:name         "disk" ;
                          sh:node         gx:DiskShape ;
                          sh:order        4 ;
                          sh:path         gx:disk
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "Participant maintaining the resource in operational condition and thus have physical access to it." ;
                          sh:minCount     1 ;
                          sh:name         "maintained by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:maintainedBy
] ;
        sh:property     [ skos:example    "''" ;
                          sh:description  "DID of resources self-description related to the resource and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "''" ;
                          sh:description  "A vcard:Address object that contains the physical location in ISO 3166-1 alpha2, alpha-3 or numeric format." ;
                          sh:minCount     1 ;
                          sh:name         "location address" ;
                          sh:node         gx:AddressShape ;
                          sh:order        4 ;
                          sh:path         gx:locationAddress
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of participant self-description related to the participant, who operates this resource." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "operated by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:operatedBy
] ;
        sh:property     [ skos:example    "'Example Resource'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Name of resource." ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        1 ;
                          sh:path         gx:name
] ;
        sh:property     [ skos:example    "'a structured object of type measure, e.g. measure:value=10 and measure:unit=GBase-T'" ;
                          sh:description  "Description of network interface card(s) of this node" ;
                          sh:name         "nic" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        5 ;
                          sh:path         gx:nic
] ;
        sh:property     [ skos:example    "'(a reference to gx:Resource object)'" ;
                          sh:description  "Resources related to the resource and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:aggregationOf
] ;
        sh:targetClass  gx:PhysicalNode .

gx:ComplianceAssessmentBodyShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'did:web:compliance.gaia-x.eu/3rdPartyComplianceCertScheme/sha256#1', 'did:web:compliance.gaia-x.eu/3rdPartyComplianceCertScheme/sha256#2'" ;
                          sh:description  "IDs of the Third Party Compliance Certification Scheme this Compliance Assessment Body can certify." ;
                          sh:minCount     1 ;
                          sh:name         "can certify third party compliance certification scheme" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:canCertifyThirdPartyComplianceCertificationScheme
] ;
        sh:property     [ skos:example    "'did:web:compliance.gaia-x.eu/complianceCertClaim/sha256#1', 'did:web:compliance.gaia-x.eu/complianceCertClaim/sha256#2'" ;
                          sh:description  "IDs of Certificate claims issued by this Compliance Assessment Body." ;
                          sh:minCount     1 ;
                          sh:name         "has third party compliance certificate claim" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:hasThirdPartyComplianceCertificateClaim
] ;
        sh:property     [ skos:example    "'did:web:compliance.gaia-x.eu/complianceVC/sha256#1', 'did:web:compliance.gaia-x.eu/complianceVC/sha256#2'" ;
                          sh:description  "IDs of the Certificate claims VC certified by this Compliance Assessment Body." ;
                          sh:minCount     1 ;
                          sh:name         "has third party compliance credential" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:hasThirdPartyComplianceCredential
] ;
        sh:targetClass  gx:ComplianceAssessmentBody .

gx:VolumeTypeShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'small', 'medium', 'large'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Unique name of this volume type." ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        1 ;
                          sh:path         gx:name
] ;
        sh:targetClass  gx:VolumeType .

gx:InstantiatedVirtualResourceShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A list of SPDX license identifiers or URL to license document" ;
                          sh:minCount     1 ;
                          sh:name         "license" ;
                          sh:order        2 ;
                          sh:path         gx:license
] ;
        sh:property     [ skos:example    "'Example Resource placed somewhere in Europe'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A more detailed description of resource." ;
                          sh:maxCount     1 ;
                          sh:name         "description" ;
                          sh:order        2 ;
                          sh:path         dct:description
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of participant self-description related to the participant, who operates this resource." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "operated by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:operatedBy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A list of policy expressed using a DSL (e.g., Rego or ODRL) (access control, throttling, usage, retention, …)" ;
                          sh:minCount     1 ;
                          sh:name         "policy" ;
                          sh:order        3 ;
                          sh:path         gx:policy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "a list of participants  maintaining the resource in operational condition." ;
                          sh:minCount     1 ;
                          sh:name         "maintained by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:maintainedBy
] ;
        sh:property     [ skos:example    "''" ;
                          sh:description  "DID of resources self-description related to the resource and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "A virtual resource (normally a software resource) this process is an instance of." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "instance of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:instanceOf
] ;
        sh:property     [ skos:example    "'Example Resource'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Name of resource." ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        1 ;
                          sh:path         gx:name
] ;
        sh:property     [ skos:example    "'(a reference to gx:Resource object)'" ;
                          sh:description  "Resources related to the resource and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "The copyright owner(s), given as a Gaia-X Participant or as some other agent, possibly also a person outside of Gaia-X. A copyright owner is a person or organization, that has the right to exploit the resource. Copyright owner does not necessary refer to the author of the resource, who is a natural person and may differ from copyright owner. A simple name string can be referenced as a blank node whose foaf:name attribute has that string value." ;
                          sh:minCount     1 ;
                          sh:name         "copyright owned by" ;
                          sh:node         gx:AgentShape ;
                          sh:order        1 ;
                          sh:path         gx:copyrightOwnedBy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "A list of participant with contractual relation with the resource." ;
                          sh:minCount     1 ;
                          sh:name         "tenant owned by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        4 ;
                          sh:path         gx:tenantOwnedBy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "a resource where the instance of this virtual resource is being executed on." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "hosted on" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:hostedOn
] ;
        sh:property     [ skos:example    "'PD-SAP', 'PLME-SAP'" ;
                          sh:description  "a list of Service Access Point which can be an endpoint as a mean to access and interact with the resource" ;
                          sh:in           ( "PD-SAP" "PLME-SAP" ) ;
                          sh:minCount     1 ;
                          sh:name         "service access point" ;
                          sh:node         gx:ServiceAccessPointShape ;
                          sh:order        5 ;
                          sh:path         gx:serviceAccessPoint
] ;
        sh:targetClass  gx:InstantiatedVirtualResource .

gx:EncryptionShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'none', 'rsa'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Supported algorithm used to encrypt." ;
                          sh:in           ( "none" "rsa" ) ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "encryption algorithm" ;
                          sh:order        1 ;
                          sh:path         gx:encryptionAlgorithm
] ;
        sh:property     [ skos:example    "'managed', 'byok', 'hyok'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Define key management method. 'managed': Keys are created by and stored in key manager of cloud. 'byok': bring-your-own-key: Keys created by user and stored in key manager of cloud. 'hyok' hold-your-own-key Key created by user and kept by user" ;
                          sh:in           ( "managed" "byok" "hyok" ) ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "key management" ;
                          sh:order        2 ;
                          sh:path         gx:keyManagement
] ;
        sh:targetClass  gx:Encryption .

gx:CPUShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'A structure object of type measure, e.g. measure:value=38 and measure:unit=MB'" ;
                          sh:description  "Cache size of the CPU" ;
                          sh:maxCount     1 ;
                          sh:name         "cache size" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        9 ;
                          sh:path         gx:cacheSize
] ;
        sh:property     [ skos:example    "'A structure object of type measure, e.g. measure:value=3.0 and measure:unit=GHz'" ;
                          sh:description  "Frequency of the CPU" ;
                          sh:maxCount     1 ;
                          sh:name         "frequency" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        7 ;
                          sh:path         gx:frequency
] ;
        sh:property     [ skos:example    "'fpu', 'vme', 'de', 'pse', 'sse', 'sse2', 'ht', 'vmx', 'smx', 'sse4_1', 'sse4_2', 'avx', '3dnowprefetch', 'ibrs_enhanced', 'ept_ad', 'sgx', 'sgx_lc', 'md_clear', 'arch_capabilities', '...'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "CPU flags as documented by lscpu and defined in https://github.com/torvalds/linux/blob/master/tools/arch/x86/include/asm/cpufeatures.h ." ;
                          sh:name         "cpu flag" ;
                          sh:order        3 ;
                          sh:path         gx:cpuFlag
] ;
        sh:property     [ skos:example     "'4', '6', '8', '12', '24'" ;
                          sh:datatype      xsd:integer ;
                          sh:description   "Number of Cores of the CPU" ;
                          sh:maxCount      1 ;
                          sh:minInclusive  1 ;
                          sh:name          "number of cores" ;
                          sh:order         5 ;
                          sh:path          gx:numberOfCores
] ;
        sh:property     [ skos:example    "'FCLGA3647'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Socket the CPU fits into." ;
                          sh:maxCount     1 ;
                          sh:name         "allowed socket" ;
                          sh:order        10 ;
                          sh:path         gx:allowedSocket
] ;
        sh:property     [ skos:example    "'A structure object of type measure, e.g. measure:value=4.0 and measure:unit=GHz'" ;
                          sh:description  "Boost frequency of the CPU" ;
                          sh:maxCount     1 ;
                          sh:name         "boost frequency" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        8 ;
                          sh:path         gx:boostFrequency
] ;
        sh:property     [ skos:example    "'x86', 'x86-64', 'RISC-V', 'Generic'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Basic CPU architecture." ;
                          sh:in           ( "x86" "x86-64" "RISC-V" "Generic" ) ;
                          sh:maxCount     1 ;
                          sh:name         "cpu architecture" ;
                          sh:order        1 ;
                          sh:path         gx:cpuArchitecture
] ;
        sh:property     [ skos:example     "'4', '6', '8', '12', '24'" ;
                          sh:datatype      xsd:integer ;
                          sh:description   "Number of Cores of the CPU" ;
                          sh:maxCount      1 ;
                          sh:minInclusive  1 ;
                          sh:name          "number of cores" ;
                          sh:order         5 ;
