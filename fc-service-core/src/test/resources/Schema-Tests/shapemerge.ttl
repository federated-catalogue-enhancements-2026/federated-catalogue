] ;
        sh:property     [ skos:example    "' '" ;
                          sh:description  "a list of methods to export data out of the service" ;
                          sh:minCount     1 ;
                          sh:name         "data account export" ;
                          sh:node         gx:DataAccountExportShape ;
                          sh:order        4 ;
                          sh:path         gx:dataAccountExport
] ;
        sh:property     [ skos:example    "'Ethrnet, ARP, PPP, VLAN'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Link protocol type" ;
                          sh:maxCount     1 ;
                          sh:name         " protocol type" ;
                          sh:order        8 ;
                          sh:path         gx:ProtocolType
] ;
        sh:property     [ skos:example    "'GDPR2016', 'LGPD2019'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a list of data protection regime from the list available below" ;
                          sh:name         "data protection regime" ;
                          sh:order        3 ;
                          sh:path         gx:dataProtectionRegime
] ;
        sh:property     [ skos:example    "'Image classification ML service'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A human readable name of the component" ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        5 ;
                          sh:path         gx:name
] ;
        sh:property     [ skos:example    "''" ;
                          sh:datatype     xsd:string ;
                          sh:description  "" ;
                          sh:maxCount     1 ;
                          sh:name         " instantiation requirements" ;
                          sh:order        1 ;
                          sh:path         gx:InstantiationRequirements
] ;
        sh:property     [ skos:example    "'0.00002 %'" ;
                          sh:description  "Contractual packet loss of connection defined in the SLA agreement. If not specified, then best effort is assumed. PackageLoss s measured in the pseudo-unit 'percent'-" ;
                          sh:maxCount     1 ;
                          sh:name         "packet loss" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        6 ;
                          sh:path         gx:packetLoss
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "a resolvable link to the Terms and Conditions applying to that service." ;
                          sh:minCount     1 ;
                          sh:name         "terms and conditions" ;
                          sh:node         gx:TermsAndConditionsShape ;
                          sh:order        1 ;
                          sh:path         gx:termsAndConditions
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of resource self-escription related to the service and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'(reference to endpoint)'" ;
                          sh:description  "Endpoint through which the Service Offering can be accessed" ;
                          sh:name         "endpoint" ;
                          sh:node         gx:EndpointShape ;
                          sh:order        9 ;
                          sh:path         gx:endpoint
] ;
        sh:property     [ skos:example    "'FR:VLANID:56'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "defined via interconnection point identifier of the source" ;
                          sh:maxCount     1 ;
                          sh:name         " source access point" ;
                          sh:order        1 ;
                          sh:path         gx:SourceAccessPoint
] ;
        sh:property     [ skos:example    "'1 Gbit/s', '10 Gbit/s', '100 Gbit/s', '400 Gbit/s'" ;
                          sh:description  "Contractual bandwidth defined in the service level agreement (SLA)" ;
                          sh:maxCount     1 ;
                          sh:name         "bandwidth" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        3 ;
                          sh:path         gx:bandwidth
] ;
        sh:property     [ skos:example    "'1 ms', '10 ms', '1 s'" ;
                          sh:description  "Contractual latency defined in the SLA." ;
                          sh:maxCount     1 ;
                          sh:name         " round trip time r t t" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        4 ;
                          sh:path         gx:RoundTripTimeRTT
] ;
        sh:property     [ skos:example    "'Hybrid', 'gx:PrivateProvisioning'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Provision type of the service" ;
                          sh:maxCount     1 ;
                          sh:name         "provision type" ;
                          sh:order        8 ;
                          sh:path         gx:provisionType
] ;
        sh:property     [ skos:example    "'23', '175'" ;
                          sh:description  "Vlan Tag ID that range between 1 and 4094. In case qinq connection type is chosen tow vlan tag, namely outer and innter should be provided" ;
                          sh:maxCount     1 ;
                          sh:name         " v l a n tag" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        10 ;
                          sh:path         gx:VLANTag
] ;
        sh:property     [ skos:example    "'An ML service for training, deploying and improving image classifiers.'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A description in natural language" ;
                          sh:maxCount     1 ;
                          sh:name         "description" ;
                          sh:order        6 ;
                          sh:path         dct:description
] ;
        sh:property     [ skos:example    "'MUC:VLANID:24'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "defined via interconnection point identifier of the destination" ;
                          sh:maxCount     1 ;
                          sh:name         " destination access point" ;
                          sh:order        2 ;
                          sh:path         gx:DestinationAccessPoint
] ;
        sh:property     [ skos:example    "'99.9999 %', '99.9 %', '99.99 %'" ;
                          sh:description  "Contractual availability of connection defined in the SLA agreement. Availability is measured in the pseudo-unit 'percent'." ;
                          sh:maxCount     1 ;
                          sh:name         "availability" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        5 ;
                          sh:path         gx:availability
] ;
        sh:property     [ skos:example    "'ML', 'Classification'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Keywords that describe / tag the service." ;
                          sh:name         "keyword" ;
                          sh:order        7 ;
                          sh:path         dcat:keyword
] ;
        sh:property     [ skos:example    "' '" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
                          sh:minCount     1 ;
                          sh:name         "policy" ;
                          sh:order        2 ;
                          sh:path         gx:policy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of participant self-descrription, who is offering this service offering." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "offered by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:offeredBy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of the service offering self-description related to the service and that can exist independently of it." ;
                          sh:name         "depends on" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:dependsOn
] ;
        sh:targetClass  gx:LinkConnectivity .

gx:ImageShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'8'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Version of this image." ;
                          sh:maxCount     1 ;
                          sh:name         "version" ;
                          sh:order        7 ;
                          sh:path         gx:version
] ;
        sh:property     [ skos:example    "'(a structured object of type gx:Measure)'" ;
                          sh:description  "Mininal size of ram required to instantiate this image." ;
                          sh:maxCount     1 ;
                          sh:name         "min ram size" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        3 ;
                          sh:path         gx:minRamSize
] ;
        sh:property     [ skos:example    "'Example Resource placed somewhere in Europe'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A more detailed description of resource." ;
                          sh:maxCount     1 ;
                          sh:name         "description" ;
                          sh:order        2 ;
                          sh:path         dct:description
] ;
        sh:property     [ skos:example    "'raw'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Disk format. Default: RAW" ;
                          sh:in           ( "raw" "vhd" "vmdk" "vdi" "iso" "qcow2" "aki" "ari" "ami" ) ;
                          sh:maxCount     1 ;
                          sh:name         "disk format" ;
                          sh:order        4 ;
                          sh:path         gx:diskFormat
] ;
        sh:property     [ skos:example    "''" ;
                          sh:description  "DID of resources self-description related to the resource and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'5d68f20237c7c01c067b577ee5e490d1'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Checksum of this image." ;
                          sh:maxCount     1 ;
                          sh:name         "check sum" ;
                          sh:order        6 ;
                          sh:path         gx:checkSum
] ;
        sh:property     [ skos:example    "'bare'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Container format. Default: bare" ;
                          sh:in           ( "bare" "ovf" "aki" "ami" "ari" ) ;
                          sh:maxCount     1 ;
                          sh:name         "container format" ;
                          sh:order        5 ;
                          sh:path         gx:containerFormat
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of participant self-description related to the participant, who operates this resource." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "operated by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:operatedBy
] ;
        sh:property     [ skos:example    "'Example Resource'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Name of resource." ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        1 ;
                          sh:path         gx:name
] ;
        sh:property     [ skos:example    "'virtual machine', 'container'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Type of this image. Default: virtual machine" ;
                          sh:in           ( "virtual machine" "container" ) ;
                          sh:maxCount     1 ;
                          sh:name         "image type" ;
                          sh:order        1 ;
                          sh:path         gx:imageType
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A list of SPDX license identifiers or URL to license document" ;
                          sh:minCount     1 ;
                          sh:name         "license" ;
                          sh:order        2 ;
                          sh:path         gx:license
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "The copyright owner(s), given as a Gaia-X Participant or as some other agent, possibly also a person outside of Gaia-X. A copyright owner is a person or organization, that has the right to exploit the resource. Copyright owner does not necessary refer to the author of the resource, who is a natural person and may differ from copyright owner. A simple name string can be referenced as a blank node whose foaf:name attribute has that string value." ;
                          sh:minCount     1 ;
                          sh:name         "copyright owned by" ;
                          sh:node         gx:AgentShape ;
                          sh:order        1 ;
                          sh:path         gx:copyrightOwnedBy
] ;
        sh:property     [ skos:example    "'(a structured object of type gx:Measure)'" ;
                          sh:description  "Size of this image " ;
                          sh:maxCount     1 ;
                          sh:name         "size" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        2 ;
                          sh:path         gx:size
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A list of policy expressed using a DSL (e.g., Rego or ODRL) (access control, throttling, usage, retention, …)" ;
                          sh:minCount     1 ;
                          sh:name         "policy" ;
                          sh:order        3 ;
                          sh:path         gx:policy
] ;
        sh:property     [ skos:example    "'x86', 'x86-64', 'RISC-V', 'Generic'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "CPU Architecture required to instantiate this image." ;
                          sh:in           ( "x86" "x86-64" "RISC-V" "Generic" ) ;
                          sh:maxCount     1 ;
                          sh:name         "architecture" ;
                          sh:order        8 ;
                          sh:path         gx:architecture
] ;
        sh:property     [ skos:example    "'(a reference to gx:Resource object)'" ;
                          sh:description  "Resources related to the resource and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:aggregationOf
] ;
        sh:targetClass  gx:Image .

gx:BlockStorageShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'None', 'managed', 'byok', 'hyok'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Default: None. Define encryption method of storage service. None: means no encryption art all. managed: Virtual storage is encrypted by key managed provider. byok: Virtual storage  " ;
                          sh:in           ( "None" "managed" "byok" "hyok" ) ;
                          sh:maxCount     1 ;
                          sh:name         "encryption method" ;
                          sh:order        2 ;
                          sh:path         gx:encryptionMethod
] ;
        sh:property     [ skos:example    "'Hybrid', 'gx:PrivateProvisioning'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Provision type of the service" ;
                          sh:maxCount     1 ;
                          sh:name         "provision type" ;
                          sh:order        8 ;
                          sh:path         gx:provisionType
] ;
        sh:property     [ skos:example    "'virtual', 'bare-metal', 'mixed'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Type of Service Offering. Choose one of the following: virtual, bare-metal, mixed" ;
                          sh:in           ( "virtual" "bare-metal" "mixed" ) ;
                          sh:maxCount     1 ;
                          sh:name         "service type" ;
                          sh:order        1 ;
                          sh:path         gx:serviceType
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of the service offering self-description related to the service and that can exist independently of it." ;
                          sh:name         "depends on" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:dependsOn
] ;
        sh:property     [ skos:example    "'True', 'False'" ;
                          sh:datatype     xsd:boolean ;
                          sh:description  "Default: False. True is storage service supports snapshots." ;
                          sh:maxCount     1 ;
                          sh:name         "snapshot supported" ;
                          sh:order        3 ;
                          sh:path         gx:snapshotSupported
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of resource self-escription related to the service and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:aggregationOf
