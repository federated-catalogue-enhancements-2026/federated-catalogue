gx:ComputeShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "' '" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
                          sh:minCount     1 ;
                          sh:name         "policy" ;
                          sh:order        2 ;
                          sh:path         gx:policy
] ;
        sh:property     [ skos:example    "'hw-virtualized', 'sw-virtualized', 'os-virtualized', 'os-hw-virtualized', 'hw-partitioned', 'physical'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Default: virtual. How compute resources of different tenants are separated." ;
                          sh:in           ( "hw-virtualized" "sw-virtualized" "os-virtualized" "os-hw-virtualized" "hw-partitioned" "physical" ) ;
                          sh:maxCount     1 ;
                          sh:name         "tenant separation" ;
                          sh:order        1 ;
                          sh:path         gx:tenantSeparation
] ;
        sh:property     [ skos:example    "'Image classification ML service'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A human readable name of the component" ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        5 ;
                          sh:path         gx:name
] ;
        sh:property     [ skos:example    "''" ;
                          sh:datatype     xsd:string ;
                          sh:description  "lists autoscaling group that this VM belongs to." ;
                          sh:maxCount     1 ;
                          sh:name         "is part of scaling group" ;
                          sh:order        3 ;
                          sh:path         gx:isPartOfScalingGroup
] ;
        sh:property     [ skos:example    "'(a structured object of type gx:IdentityAccessManagement)'" ;
                          sh:description  "Reference to identity access management service  storage service offing to create disks used within this compute service." ;
                          sh:minCount     1 ;
                          sh:name         "identity" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        7 ;
                          sh:path         gx:identity
] ;
        sh:property     [ skos:example    "'Hybrid', 'gx:PrivateProvisioning'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Provision type of the service" ;
                          sh:maxCount     1 ;
                          sh:name         "provision type" ;
                          sh:order        8 ;
                          sh:path         gx:provisionType
] ;
        sh:property     [ skos:example    "'ML', 'Classification'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Keywords that describe / tag the service." ;
                          sh:name         "keyword" ;
                          sh:order        7 ;
                          sh:path         dcat:keyword
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of participant self-descrription, who is offering this service offering." ;
                          sh:maxCount     1 ;
