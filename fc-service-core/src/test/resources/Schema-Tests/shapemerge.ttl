gx:ParticipantShape
        rdf:type        sh:NodeShape ;
        sh:targetClass  gx:Participant .

gx:ComplianceCriteriaCombinationShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'Gaia-X Criteria Combination #1'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Name of the Gaia-X criteria combination" ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "has name" ;
                          sh:order        1 ;
                          sh:path         gx:hasName
] ;
        sh:property     [ skos:example    "'Gaia-X'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A description in natural language" ;
                          sh:maxCount     1 ;
                          sh:name         "has description" ;
                          sh:order        2 ;
                          sh:path         dct:hasDescription
] ;
        sh:property     [ skos:example    "'22/04 or 2022/04/12 or 1.5.34 or built 240344'" ;
                          sh:description  "List of Required Criteria to be granted for the label or list of granted Criteria by the compliance. All the Criteria have to be granted (logic AND)" ;
                          sh:minCount     1 ;
                          sh:name         "required or granted criteria" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:requiredOrGrantedCriteria
] ;
        sh:targetClass  gx:ComplianceCriteriaCombination .

gx:FlavorShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'(a structured object of type gx:Disk)'" ;
                          sh:description  "Detailed information about additional disks of this flavor." ;
                          sh:maxCount     1 ;
                          sh:name         "additional disk" ;
                          sh:node         gx:DiskShape ;
                          sh:order        10 ;
                          sh:path         gx:additionalDisk
] ;
        sh:property     [ skos:example    "'small', 'medium', 'large'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Unique name of this flavor." ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        1 ;
                          sh:path         gx:name
] ;
        sh:property     [ skos:example    "'2', '8'" ;
                          sh:datatype     xsd:boolean ;
                          sh:description  "Default: False. True, if GPU Pass-Through is activated. Either set numberOfvGPU or GpuPassThrough=true. Both options are prohibitted." ;
                          sh:maxCount     1 ;
                          sh:name         " gpu pass through" ;
                          sh:order        6 ;
                          sh:path         gx:GpuPassThrough
] ;
        sh:property     [ skos:example    "'(a structured object of type gx:Disk)'" ;
                          sh:description  "Detailed information about root disk of this flavor." ;
                          sh:maxCount     1 ;
                          sh:name         "root disk" ;
                          sh:node         gx:DiskShape ;
                          sh:order        9 ;
                          sh:path         gx:rootDisk
] ;
        sh:property     [ skos:example     "'2', '8'" ;
                          sh:datatype      xsd:integer ;
                          sh:description   "Number of virtual CPUs." ;
                          sh:maxCount      1 ;
                          sh:minInclusive  1 ;
                          sh:name          "number ofv c p us" ;
                          sh:order         3 ;
                          sh:path          gx:numberOfvCPUs
] ;
        sh:property     [ skos:example    "'(a structured object of type gx:Software)', 'bare-metal'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Ability to lable high-performance CPUs, disks, network. Choose one of the following classes: CPU, GPU, disk, network, none. Default value none" ;
                          sh:in           ( "software" "bare-metal" ) ;
                          sh:maxCount     1 ;
                          sh:name         "hypervisor" ;
                          sh:order        12 ;
                          sh:path         gx:hypervisor
] ;
        sh:property     [ skos:example    "'(a structured object of type gax-core_CPU'" ;
                          sh:description  "Detailed information about CPU used by this flavor." ;
                          sh:maxCount     1 ;
                          sh:name         "cpu" ;
                          sh:node         gx:CPUShape ;
                          sh:order        2 ;
                          sh:path         gx:cpu
] ;
        sh:property     [ skos:example    "'cpu', 'disk', 'network', 'gpu', 'none'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Ability to lable high-performance CPUs, disks, network. Choose one of the following classes: CPU, GPU, disk, network, none. Default value none" ;
                          sh:in           ( "cpu" "disk" "network" "gpu" "none" ) ;
                          sh:maxCount     1 ;
                          sh:name         "performance class" ;
                          sh:order        11 ;
                          sh:path         gx:performanceClass
] ;
        sh:property     [ skos:example    "'(a structured object of type gx:FPGA'" ;
                          sh:description  "Detailed information about FPGA used by this flavor." ;
                          sh:maxCount     1 ;
                          sh:name         "fpga" ;
                          sh:node         gx:FPGAShape ;
                          sh:order        7 ;
                          sh:path         gx:fpga
] ;
        sh:property     [ skos:example    "'(a structured object of type gx:Measure)'" ;
                          sh:description  "Amount of memory available for the server." ;
                          sh:maxCount     1 ;
                          sh:name         "ram size" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        8 ;
                          sh:path         gx:ramSize
] ;
        sh:property     [ skos:example    "'(a structured object of type gax-core_CPU'" ;
                          sh:description  "Detailed information about GPU used by this flavor." ;
                          sh:maxCount     1 ;
                          sh:name         "gpu" ;
                          sh:node         gx:GPUShape ;
                          sh:order        4 ;
                          sh:path         gx:gpu
] ;
        sh:property     [ skos:example     "'2', '8'" ;
                          sh:datatype      xsd:integer ;
                          sh:description   "Number of virtual GPUs. Either set numberOfvGPU or GpuPassThrough=true. Using both options are prohibitted." ;
                          sh:maxCount      1 ;
                          sh:minInclusive  1 ;
                          sh:name          "number ofv g p us" ;
                          sh:order         5 ;
                          sh:path          gx:numberOfvGPUs
] ;
        sh:targetClass  gx:Flavor .

gx:SigningShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'md5-check-sum'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Defines algorithm used to sign" ;
                          sh:in           ( "md5" "ECDSA" "EdDSA" "Curve 25519" ) ;
                          sh:name         "signature algo" ;
                          sh:order        1 ;
                          sh:path         gx:signatureAlgo
] ;
        sh:property     [ skos:example    "'managed', 'byok', 'hyok'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Define key management method. 'managed': Keys are created by and stored in key manager of cloud. 'byok': bring-your-own-key: Keys created by user and stored in key manager of cloud. 'hyok' hold-your-own-key Key created by user and kept by user" ;
                          sh:in           ( "managed" "byok" "hyok" ) ;
                          sh:minCount     1 ;
                          sh:name         "key management" ;
                          sh:order        2 ;
                          sh:path         gx:keyManagement
] ;
        sh:targetClass  gx:Signing .

