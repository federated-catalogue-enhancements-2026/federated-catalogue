gx:ComplianceCertificateCredentialShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'https://company-a.com/self-descriptions/cab.jsonld'" ;
                          sh:description  "ID of the claim to be signed in a verifiable credential build with all the information that are bound in the claim. In case of third party credential the ID is the ID of the third party" ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "credential subject" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:credentialSubject
] ;
        sh:targetClass  gx:ComplianceCertificateCredential .

gx:AddressShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'DE', 'DEU'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "GPS in ISO 6709:2008/Cor 1:2009 format." ;
                          sh:maxCount     1 ;
                          sh:name         "gps" ;
                          sh:order        2 ;
                          sh:path         vcard:gps
] ;
        sh:property     [ skos:example    "'DE', 'DEU'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Physical location of head quarter in ISO 3166-1 alpha2, alpha-3 or numeric format." ;
                          sh:maxCount     1 ;
