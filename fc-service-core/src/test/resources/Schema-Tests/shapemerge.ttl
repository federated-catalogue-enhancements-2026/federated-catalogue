gx:ComplianceReferenceShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'Information security management system standards.'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A description in natural language" ;
                          sh:maxCount     1 ;
                          sh:name         "has description" ;
                          sh:order        4 ;
                          sh:path         dct:hasDescription
] ;
        sh:property     [ skos:example    "'22/04 or 2022/04/12 or 1.5.34 or built 240344'" ;
                          sh:datatype     xsd:dateTime ;
                          sh:description  "Indicates the first date when the compliance reference goes into effect" ;
                          sh:maxCount     1 ;
                          sh:name         "c r valid from" ;
                          sh:order        7 ;
                          sh:path         gx:cRValidFrom
] ;
        sh:property     [ skos:example    "'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "SHA256 of PDF document referenced by hasReferenceUrl." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "has sha256" ;
                          sh:order        2 ;
                          sh:path         gx:hasSha256
] ;
        sh:property     [ skos:example    "'https://www.iso.org/iso-27001.pdf'" ;
                          sh:datatype     xsd:anyURI ;
                          sh:description  "URI to reference the content of the compliance reference in a single PDF file" ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "has reference url" ;
                          sh:order        1 ;
                          sh:path         gx:hasReferenceUrl
] ;
        sh:property     [ skos:example    "'ISO 27001'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Name of the Compliance Reference" ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "has compliance reference title" ;
                          sh:order        3 ;
                          sh:path         gx:hasComplianceReferenceTitle
] ;
        sh:property     [ skos:example    "'22/04 or 2022/04/12 or 1.5.34 or built 240344'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "versioning according to [semver](https://semver.org/)." ;
                          sh:maxCount     1 ;
                          sh:name         "has version" ;
                          sh:order        6 ;
                          sh:path         gx:hasVersion
] ;
        sh:property     [ skos:example    "'did:web:compliance.cispe.org/coc/gdpr/thirdparty#1'" ;
                          sh:description  "List of schemes that grants certification. This list is managed by a reference manager." ;
                          sh:minCount     1 ;
                          sh:name         "has compliance certification schemes" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        9 ;
                          sh:path         gx:hasComplianceCertificationSchemes
] ;
        sh:property     [ skos:example    "'22/04 or 2022/04/12 or 1.5.34 or built 240344'" ;
                          sh:datatype     xsd:dateTime ;
                          sh:description  "Indicates the last date when the compliance reference is no more into effect" ;
                          sh:maxCount     1 ;
                          sh:name         "c r valid until" ;
                          sh:order        8 ;
                          sh:path         gx:cRValidUntil
] ;
        sh:property     [ skos:example    "'https://company-a.com/self-descriptions/compliance-ref-manager.jsonld'" ;
                          sh:description  "ID of Participant (self-description) in charge of managing this Compliance Reference" ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "has compliance reference manager" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        5 ;
                          sh:path         gx:hasComplianceReferenceManager
] ;
        sh:targetClass  gx:ComplianceReference .

gx:FileStorageShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'Image classification ML service'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A human readable name of the component" ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        5 ;
                          sh:path         gx:name
] ;
        sh:property     [ skos:example    "'Hybrid', 'gx:PrivateProvisioning'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Provision type of the service" ;
                          sh:maxCount     1 ;
                          sh:name         "provision type" ;
                          sh:order        8 ;
                          sh:path         gx:provisionType
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of resource self-escription related to the service and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'virtual', 'bare-metal', 'mixed'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Type of Service Offering. Choose one of the following: virtual, bare-metal, mixed" ;
                          sh:in           ( "virtual" "bare-metal" "mixed" ) ;
                          sh:maxCount     1 ;
                          sh:name         "service type" ;
                          sh:order        1 ;
                          sh:path         gx:serviceType
] ;
        sh:property     [ skos:example    "'FAT32', 'NTFS', 'exFAT'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "File system of storage service." ;
                          sh:in           ( "FAT32" "NTFS" "exFAT" ) ;
                          sh:maxCount     1 ;
                          sh:name         "file system" ;
                          sh:order        1 ;
                          sh:path         gx:fileSystem
] ;
        sh:property     [ skos:example    "'GDPR2016', 'LGPD2019'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a list of data protection regime from the list available below" ;
                          sh:name         "data protection regime" ;
                          sh:order        3 ;
                          sh:path         gx:dataProtectionRegime
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of participant self-descrription, who is offering this service offering." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "offered by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:offeredBy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "a resolvable link to the Terms and Conditions applying to that service." ;
                          sh:minCount     1 ;
                          sh:name         "terms and conditions" ;
                          sh:node         gx:TermsAndConditionsShape ;
                          sh:order        1 ;
                          sh:path         gx:termsAndConditions
] ;
        sh:property     [ skos:example    "' '" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
                          sh:minCount     1 ;
                          sh:name         "policy" ;
                          sh:order        2 ;
                          sh:path         gx:policy
] ;
        sh:property     [ skos:example    "'(reference to endpoint)'" ;
                          sh:description  "Endpoint through which the Service Offering can be accessed" ;
                          sh:name         "endpoint" ;
                          sh:node         gx:EndpointShape ;
                          sh:order        9 ;
                          sh:path         gx:endpoint
] ;
        sh:property     [ skos:example    "'True', 'False'" ;
                          sh:datatype     xsd:boolean ;
                          sh:description  "Default: False. True is storage service supports snapshots." ;
                          sh:maxCount     1 ;
                          sh:name         "snapshot supported" ;
                          sh:order        3 ;
                          sh:path         gx:snapshotSupported
] ;
        sh:property     [ skos:example    "'An ML service for training, deploying and improving image classifiers.'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A description in natural language" ;
                          sh:maxCount     1 ;
                          sh:name         "description" ;
                          sh:order        6 ;
                          sh:path         dct:description
] ;
        sh:property     [ skos:example    "'True', 'False'" ;
                          sh:datatype     xsd:boolean ;
                          sh:description  "Default: False. True is storage service supports backus." ;
                          sh:maxCount     1 ;
                          sh:name         "backups supported" ;
                          sh:order        4 ;
                          sh:path         gx:backupsSupported
] ;
        sh:property     [ skos:example    "' '" ;
                          sh:description  "a list of methods to export data out of the service" ;
                          sh:minCount     1 ;
                          sh:name         "data account export" ;
                          sh:node         gx:DataAccountExportShape ;
                          sh:order        4 ;
                          sh:path         gx:dataAccountExport
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of the service offering self-description related to the service and that can exist independently of it." ;
                          sh:name         "depends on" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:dependsOn
] ;
        sh:property     [ skos:example    "'None', 'managed', 'byok', 'hyok'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Default: None. Define encryption method of storage service. None: means no encryption art all. managed: Virtual storage is encrypted by key managed provider. byok: Virtual storage  " ;
                          sh:in           ( "None" "managed" "byok" "hyok" ) ;
                          sh:maxCount     1 ;
                          sh:name         "encryption method" ;
                          sh:order        2 ;
                          sh:path         gx:encryptionMethod
] ;
        sh:property     [ skos:example    "'ML', 'Classification'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Keywords that describe / tag the service." ;
                          sh:name         "keyword" ;
                          sh:order        7 ;
                          sh:path         dcat:keyword
] ;
        sh:targetClass  gx:FileStorage .

gx:ProviderShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'did:web:provider.com/location#1', 'did:web:provider.com/location#2'" ;
                          sh:description  "Ids of available Locations for this provider" ;
                          sh:name         "has locations" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:hasLocations
] ;
        sh:property     [ skos:example    "'did:web:provider.com/serviceoffering#1', 'did:web:provider.com/serviceoffering#2'" ;
                          sh:description  "Ids of the ServiceOffering managed by this provider." ;
                          sh:name         "has service offering" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:hasServiceOffering
] ;
        sh:targetClass  gx:Provider .

gx:GPUShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'a structure object of type measure, e.g. measure:value=24 and measure:unit=GB'" ;
                          sh:description  "Memory of the GPU" ;
                          sh:maxCount     1 ;
                          sh:name         "memory size" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        2 ;
                          sh:path         gx:memorySize
] ;
