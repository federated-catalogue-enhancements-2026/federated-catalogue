@prefix dcat:                <http: //www.w3.org/ns/dcat#> .
@prefix dct:                 <http: //purl.org/dc/terms/> .
@prefix foaf:                <http: //xmlns.com/foaf/0.1/> .
@prefix rdf:                 <http: //www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh:                  <http: //www.w3.org/ns/shacl#> .
@prefix skos:                <http: //www.w3.org/2004/02/skos/core#> .
@prefix vcard:               <http: //www.w3.org/2006/vcard/ns#> .
@prefix xsd:                 <http: //www.w3.org/2001/XMLSchema#> .
@prefix gx: <https://w3id.org/gaia-x/2511#> .

gx:LegalPersonShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "A list of direct participant that this entity is a subOrganization of, if any." ;
                          sh:name         "parent organization" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        8 ;
                          sh:path         gx:parentOrganization
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "A list of direct participant with an legal mandate on this entity, e.g., as a subsidiary." ;
                          sh:name         "sub organization" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        9 ;
                          sh:path         gx:subOrganization
] ;
        sh:property     [ skos:example    "'L.L.C, GmbH'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Legal form" ;
                          sh:in           ( "LLC" "Corporation" "Limited partnership (LP)" "Nonprofit corporation" "Gesellschaft mit beschränkter Haftung (GmbH)" "Aktiengesellschaft (AG)" "Einzelunternehmen" "Gesellschaft bürgerlichen Rechts (GbR)" "Offene Handelsgesellschaft (OHG)" "Kommanditgesellschaft (KG)" "Unternehmergesellschaft (haftungsbeschränkt)" "Sole Trader" "Unincorporated Association" "Partnership" "Limited Partnership" "Trust" "Limited Company" "Limited Liability Partnership (LLP)" "Community Interest Company (CIC)" "Charitable Incorporated Organisation (CIO)" "Co-operative Society (Co-op)" "Community Benefit Society (BenCom)" "other" ) ;
                          sh:maxCount     1 ;
                          sh:name         "legal form" ;
                          sh:order        2 ;
                          sh:path         gx:legalForm
] ;
        sh:property     [ skos:example    "'(a structured object which has the attribute country as mandatory attribute and some other optional attributes e.g., the attributes vcard:street-address,vcard:locality and vcard:country-name)'" ;
                          sh:description  "The full legal address of the organization." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "legal address" ;
                          sh:node         gx:AddressShape ;
                          sh:order        5 ;
                          sh:path         gx:legalAddress
] ;
        sh:property     [ skos:example    "'M07J9MTYHFCSVRBV2631'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Unique LEI number as defined by https://www.gleif.org." ;
                          sh:maxCount     1 ;
                          sh:name         "lei code" ;
                          sh:order        7 ;
                          sh:path         gx:leiCode
] ;
        sh:property     [ skos:example    "'ACME'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Legally binding name" ;
                          sh:maxCount     1 ;
                          sh:name         "legal name" ;
                          sh:order        1 ;
                          sh:path         gx:legalName
] ;
        sh:property     [ skos:example    "'A company making everything'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Textual description of this organization." ;
                          sh:maxCount     1 ;
                          sh:name         "description" ;
                          sh:order        3 ;
                          sh:path         gx:description
] ;
        sh:property     [ skos:example    "'(a structured object which has the attribute country as mandatory attribute and some other optional attributes e.g., the attributes vcard:street-address,vcard:locality and vcard:country-name)'" ;
                          sh:description  "The full legal address of the organization." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "headquarter address" ;
                          sh:node         gx:AddressShape ;
                          sh:order        6 ;
                          sh:path         gx:headquarterAddress
] ;
        sh:property     [ skos:example    "'DEU1234.HRB12345'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Country’s registration number which identifies one specific entity. Valid formats are local, EUID, EORI, vatID, leiCode." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "registration number" ;
                          sh:order        4 ;
                          sh:path         gx:registrationNumber
] ;
        sh:targetClass  gx:LegalPerson .

gx:NetworkingDeviceShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'192.168.24.2/32'" ;
                          sh:datatype     xsd:float ;
                          sh:description  "IP address of the netowrking device" ;
                          sh:name         "network adress" ;
                          sh:order        10 ;
                          sh:path         gx:networkAdress
] ;
        sh:property     [ skos:example    "'1'" ;
                          sh:description  "Number of available CPUs." ;
                          sh:name         "cpu count" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        7 ;
                          sh:path         gx:cpuCount
] ;
        sh:property     [ skos:example    "'switch, router, repeater'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Type of networking device" ;
                          sh:name         "type" ;
                          sh:order        8 ;
                          sh:path         gx:type
] ;
        sh:property     [ skos:example    "'2Gb'" ;
                          sh:description  "Ram size of the networking device" ;
                          sh:name         "ram size" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        6 ;
                          sh:path         gx:ramSize
] ;
        sh:property     [ skos:example     "'10', '1'" ;
                          sh:datatype      xsd:integer ;
                          sh:description   "The assigned number of ports." ;
                          sh:minInclusive  1 ;
                          sh:name          "port capacity_ a_ count" ;
                          sh:order         4 ;
                          sh:path          gx:portCapacity_A_Count
] ;
        sh:property     [ skos:example    "'IP', 'IRP'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "List of  supported protocols among used layers should be specified." ;
                          sh:name         "supported protocols" ;
                          sh:order        9 ;
                          sh:path         gx:supportedProtocols
] ;
        sh:property     [ skos:example    "'yes', 'no'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Availability of redundant power supply for the cases of emergency." ;
                          sh:name         "redundant power supply" ;
                          sh:order        5 ;
                          sh:path         gx:redundantPowerSupply
] ;
        sh:property     [ skos:example    "'no', 'yes'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A dedicated port for console tasks." ;
                          sh:name         "console port" ;
                          sh:order        2 ;
                          sh:path         gx:consolePort
] ;
        sh:property     [ skos:example     "'10GE', '100GE'" ;
                          sh:datatype      xsd:float ;
                          sh:description   "The assigned capacity of ports." ;
                          sh:minInclusive  0 ;
                          sh:name          "port capacity_ a" ;
                          sh:order         3 ;
                          sh:path          gx:portCapacity_A
] ;
        sh:property     [ skos:example    "'no', 'yes'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A dedicated port for management tasks." ;
                          sh:name         "management port" ;
                          sh:order        1 ;
                          sh:path         gx:managementPort
] ;
        sh:targetClass  gx:NetworkingDevice .

gx:ConnectivityShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'Hybrid', 'gx:PrivateProvisioning'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Provision type of the service" ;
                          sh:maxCount     1 ;
                          sh:name         "provision type" ;
                          sh:order        8 ;
                          sh:path         gx:provisionType
] ;
        sh:property     [ skos:example    "' '" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
                          sh:minCount     1 ;
                          sh:name         "policy" ;
                          sh:order        2 ;
                          sh:path         gx:policy
] ;
        sh:property     [ skos:example    "'An ML service for training, deploying and improving image classifiers.'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A description in natural language" ;
                          sh:maxCount     1 ;
                          sh:name         "description" ;
                          sh:order        6 ;
                          sh:path         dct:description
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of participant self-descrription, who is offering this service offering." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "offered by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:offeredBy
] ;
        sh:property     [ skos:example    "' '" ;
                          sh:description  "a list of methods to export data out of the service" ;
                          sh:minCount     1 ;
                          sh:name         "data account export" ;
                          sh:node         gx:DataAccountExportShape ;
                          sh:order        4 ;
                          sh:path         gx:dataAccountExport
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "a resolvable link to the Terms and Conditions applying to that service." ;
                          sh:minCount     1 ;
                          sh:name         "terms and conditions" ;
                          sh:node         gx:TermsAndConditionsShape ;
                          sh:order        1 ;
                          sh:path         gx:termsAndConditions
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of resource self-escription related to the service and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'GDPR2016', 'LGPD2019'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a list of data protection regime from the list available below" ;
                          sh:name         "data protection regime" ;
                          sh:order        3 ;
                          sh:path         gx:dataProtectionRegime
] ;
        sh:property     [ skos:example    "'(reference to endpoint)'" ;
                          sh:description  "Endpoint through which the Service Offering can be accessed" ;
                          sh:name         "endpoint" ;
                          sh:node         gx:EndpointShape ;
                          sh:order        9 ;
                          sh:path         gx:endpoint
] ;
        sh:property     [ skos:example    "''" ;
                          sh:datatype     xsd:string ;
                          sh:description  "" ;
                          sh:maxCount     1 ;
                          sh:name         " instantiation requirements" ;
                          sh:order        1 ;
                          sh:path         gx:InstantiationRequirements
] ;
        sh:property     [ skos:example    "'ML', 'Classification'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Keywords that describe / tag the service." ;
                          sh:name         "keyword" ;
                          sh:order        7 ;
                          sh:path         dcat:keyword
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of the service offering self-description related to the service and that can exist independently of it." ;
                          sh:name         "depends on" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:dependsOn
] ;
        sh:property     [ skos:example    "'Image classification ML service'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A human readable name of the component" ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        5 ;
                          sh:path         gx:name
] ;
        sh:targetClass  gx:Connectivity .

gx:PhysicalResourceShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'(a reference to gx:Resource object)'" ;
                          sh:description  "Resources related to the resource and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "Participant maintaining the resource in operational condition and thus have physical access to it." ;
                          sh:minCount     1 ;
                          sh:name         "maintained by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:maintainedBy
] ;
        sh:property     [ skos:example    "'Example Resource placed somewhere in Europe'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A more detailed description of resource." ;
                          sh:maxCount     1 ;
                          sh:name         "description" ;
                          sh:order        2 ;
                          sh:path         dct:description
] ;
        sh:property     [ skos:example    "'Atlantic Ocean +00-025/'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A list of physical GPS in ISO 6709:2008/Cor 1:2009 format." ;
                          sh:name         "location g p s" ;
                          sh:order        5 ;
                          sh:path         gx:locationGPS
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of participant self-description related to the participant, who operates this resource." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "operated by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:operatedBy
] ;
        sh:property     [ skos:example    "'Example Resource'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Name of resource." ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        1 ;
                          sh:path         gx:name
] ;
        sh:property     [ skos:example    "''" ;
                          sh:description  "DID of resources self-description related to the resource and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "Participant manufacturing the resource." ;
                          sh:name         "manufactured by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:manufacturedBy
] ;
        sh:property     [ skos:example    "''" ;
                          sh:description  "A vcard:Address object that contains the physical location in ISO 3166-1 alpha2, alpha-3 or numeric format." ;
                          sh:minCount     1 ;
                          sh:name         "location address" ;
                          sh:node         gx:AddressShape ;
                          sh:order        4 ;
                          sh:path         gx:locationAddress
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "Participant owning the resource." ;
                          sh:name         "owned by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:ownedBy
] ;
        sh:targetClass  gx:PhysicalResource .

