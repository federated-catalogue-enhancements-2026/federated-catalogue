gx:DataResourceShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'(a reference to gx:Participant object)'" ;
                          sh:description  "A resolvable link to the participant self-description legally enabling the data usage." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "produced by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:producedBy
] ;
        sh:property     [ skos:example    "''" ;
                          sh:description  "DID of resources self-description related to the resource and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'2022-10-26T21:32:52'" ;
                          sh:datatype     xsd:dateTime ;
                          sh:description  "Date time in ISO 8601 format after which data is obsolete." ;
                          sh:maxCount     1 ;
                          sh:name         "obsolete date time" ;
                          sh:order        3 ;
                          sh:path         gx:obsoleteDateTime
] ;
        sh:property     [ skos:example    "'True'" ;
                          sh:datatype     xsd:boolean ;
                          sh:description  "Boolean determined by Participant owning the Data Resource." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "contains p i i" ;
                          sh:order        5 ;
                          sh:path         gx:containsPII
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "The copyright owner(s), given as a Gaia-X Participant or as some other agent, possibly also a person outside of Gaia-X. A copyright owner is a person or organization, that has the right to exploit the resource. Copyright owner does not necessary refer to the author of the resource, who is a natural person and may differ from copyright owner. A simple name string can be referenced as a blank node whose foaf:name attribute has that string value." ;
                          sh:minCount     1 ;
                          sh:name         "copyright owned by" ;
                          sh:node         gx:AgentShape ;
                          sh:order        1 ;
                          sh:path         gx:copyrightOwnedBy
] ;
        sh:property     [ skos:example    "'2022-10-26T21:32:52'" ;
                          sh:datatype     xsd:dateTime ;
                          sh:description  "Date time in ISO 8601 format after which data is expired and shall be deleted." ;
                          sh:maxCount     1 ;
                          sh:name         "expiration date time" ;
                          sh:order        4 ;
                          sh:path         gx:expirationDateTime
] ;
        sh:property     [ skos:example    "'(a reference to gx:Resource object)'" ;
                          sh:description  "Resources related to the resource and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A list of policy expressed using a DSL (e.g., Rego or ODRL) (access control, throttling, usage, retention, …)" ;
                          sh:minCount     1 ;
                          sh:name         "policy" ;
                          sh:order        3 ;
                          sh:path         gx:policy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of participant self-description related to the participant, who operates this resource." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "operated by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:operatedBy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A list of SPDX license identifiers or URL to license document" ;
                          sh:minCount     1 ;
                          sh:name         "license" ;
                          sh:order        2 ;
                          sh:path         gx:license
] ;
        sh:property     [ skos:example    "''" ;
                          sh:description  "A resolvable link to the data exchange component that exposes the data resource." ;
                          sh:minCount     1 ;
                          sh:name         "exposed through" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:exposedThrough
] ;
        sh:property     [ skos:example    "'https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:32016R0679&from=EN#d1e1888-1-1'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "NOTE: Mandatory if containsPII is true. One of the reasons as detailed in the identified Personal Data Protection Regimes, such as [GDPR2018]. Potential Legal Bases can be [article 6], article 7, (https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:32016R0679&from=EN#d1e1888-1-1) or article 9. It shall be expressed as a string matching 6.1.[a-f], 6.1.4, 7 or 9.2.[a-j]. (Note: this list is not final, as GDPR and Member State Law may provide for additional legal basis. Those will be implemented as options in future iterations.)" ;
                          sh:maxCount     1 ;
                          sh:name         "legal basis" ;
                          sh:order        6 ;
                          sh:path         gx:legalBasis
] ;
        sh:property     [ skos:example    "'Example Resource'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Name of resource." ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        1 ;
                          sh:path         gx:name
] ;
        sh:property     [ skos:example    "'Example Resource placed somewhere in Europe'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A more detailed description of resource." ;
                          sh:maxCount     1 ;
                          sh:name         "description" ;
                          sh:order        2 ;
                          sh:path         dct:description
] ;
        sh:targetClass  gx:DataResource .

gx:NetworkShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'An ML service for training, deploying and improving image classifiers.'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A description in natural language" ;
                          sh:maxCount     1 ;
                          sh:name         "description" ;
                          sh:order        6 ;
                          sh:path         dct:description
] ;
        sh:property     [ skos:example    "'Image classification ML service'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A human readable name of the component" ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        5 ;
                          sh:path         gx:name
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of the service offering self-description related to the service and that can exist independently of it." ;
                          sh:name         "depends on" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:dependsOn
] ;
        sh:property     [ skos:example    "'IPV6', 'IPv4'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Version of IP address supported. IPv4: only ipV4 addresses are supported. IPv6: both version iIPV4 and IPv6 are supported." ;
                          sh:in           ( "ipV6" "IPv4" ) ;
                          sh:maxCount     1 ;
                          sh:name         "ip version" ;
                          sh:order        3 ;
                          sh:path         gx:ipVersion
] ;
        sh:property     [ skos:example    "'virtual', 'physical'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Default: virtual. How networks of different tenants are separated." ;
                          sh:in           ( "virtual" "physical" ) ;
                          sh:maxCount     1 ;
                          sh:name         "tenant separation" ;
                          sh:order        4 ;
                          sh:path         gx:tenantSeparation
] ;
        sh:property     [ skos:example    "' '" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
                          sh:minCount     1 ;
                          sh:name         "policy" ;
                          sh:order        2 ;
                          sh:path         gx:policy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "a resolvable link to the Terms and Conditions applying to that service." ;
                          sh:minCount     1 ;
                          sh:name         "terms and conditions" ;
                          sh:node         gx:TermsAndConditionsShape ;
                          sh:order        1 ;
                          sh:path         gx:termsAndConditions
] ;
        sh:property     [ skos:example    "'ML', 'Classification'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Keywords that describe / tag the service." ;
                          sh:name         "keyword" ;
                          sh:order        7 ;
                          sh:path         dcat:keyword
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of participant self-descrription, who is offering this service offering." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "offered by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:offeredBy
] ;
        sh:property     [ skos:example    "'GDPR2016', 'LGPD2019'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a list of data protection regime from the list available below" ;
                          sh:name         "data protection regime" ;
                          sh:order        3 ;
                          sh:path         gx:dataProtectionRegime
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of resource self-escription related to the service and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'(reference to endpoint)'" ;
                          sh:description  "Endpoint through which the Service Offering can be accessed" ;
                          sh:name         "endpoint" ;
                          sh:node         gx:EndpointShape ;
                          sh:order        9 ;
                          sh:path         gx:endpoint
] ;
        sh:property     [ skos:example    "' '" ;
                          sh:description  "a list of methods to export data out of the service" ;
                          sh:minCount     1 ;
                          sh:name         "data account export" ;
                          sh:node         gx:DataAccountExportShape ;
                          sh:order        4 ;
                          sh:path         gx:dataAccountExport
] ;
        sh:property     [ skos:example    "'virtual', 'bare-metal', 'mixed'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Type of Service Offering. Choose one of the following: virtual, bare-metal, mixed" ;
                          sh:in           ( "virtual" "bare-metal" "mixed" ) ;
                          sh:maxCount     1 ;
                          sh:name         "service type" ;
                          sh:order        1 ;
                          sh:path         gx:serviceType
] ;
        sh:property     [ skos:example    "'floating', 'fixed', 'provider-network'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Defines how public IP address are provided. Floating: floating ips are supported ." ;
                          sh:in           ( "floating" "fixed" "provider-network" ) ;
                          sh:maxCount     1 ;
                          sh:name         "public ip address provisioning" ;
                          sh:order        2 ;
                          sh:path         gx:publicIpAddressProvisioning
] ;
        sh:property     [ skos:example    "'Hybrid', 'gx:PrivateProvisioning'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Provision type of the service" ;
                          sh:maxCount     1 ;
                          sh:name         "provision type" ;
                          sh:order        8 ;
                          sh:path         gx:provisionType
] ;
        sh:targetClass  gx:Network .

gx:LinkConnectivityShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'0.01 ms', '0.002 ms'" ;
                          sh:description  "Contractual jitter defined in the SLA. If not specified, then best effort is assumed." ;
                          sh:maxCount     1 ;
                          sh:name         "jitter" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        7 ;
                          sh:path         gx:jitter
] ;
        sh:property     [ skos:example    "'0x8100', '0x88a8'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "The ethertype of the vlan in hexadecimal notation." ;
                          sh:maxCount     1 ;
                          sh:name         " v l a n ether type" ;
                          sh:order        11 ;
                          sh:path         gx:VLANEtherType
] ;
        sh:property     [ skos:example    "'qinq', 'dot1q'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "the chosen types of vlan types" ;
                          sh:maxCount     1 ;
                          sh:name         " v l a n type" ;
                          sh:order        9 ;
