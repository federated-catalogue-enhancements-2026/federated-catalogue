gx:InterconnectionShape
        rdf:type        sh:NodeShape ;
        sh:property     [ skos:example    "'176.46.32.0/24'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "CIDR Provider Identifier of network on the side A" ;
                          sh:name         "prefix set_ a" ;
                          sh:order        17 ;
                          sh:path         gx:prefixSet_A
] ;
        sh:property     [ skos:example    "'a MAC address', 'IP address'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "The ID of the destination of the connection." ;
                          sh:name         "connection point z" ;
                          sh:order        4 ;
                          sh:path         gx:connectionPointZ
] ;
        sh:property     [ skos:example    "'ethernet unicast', 'multicast', 'broadcast support'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "the supported types of connection, preferably specified as a controlled vocabulary entry" ;
                          sh:name         "connection type" ;
                          sh:order        11 ;
                          sh:path         gx:connectionType
] ;
        sh:property     [ skos:example    "'GDPR2016', 'LGPD2019'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a list of data protection regime from the list available below" ;
                          sh:name         "data protection regime" ;
                          sh:order        3 ;
                          sh:path         gx:dataProtectionRegime
] ;
        sh:property     [ skos:example    "'(reference to endpoint)'" ;
                          sh:description  "Endpoint through which the Service Offering can be accessed" ;
                          sh:name         "endpoint" ;
                          sh:node         gx:EndpointShape ;
                          sh:order        9 ;
                          sh:path         gx:endpoint
] ;
        sh:property     [ skos:example    "'Hybrid', 'gx:PrivateProvisioning'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Provision type of the service" ;
                          sh:maxCount     1 ;
                          sh:name         "provision type" ;
                          sh:order        8 ;
                          sh:path         gx:provisionType
] ;
        sh:property     [ skos:example    "'qinq', 'dot1q'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "the chosen types of vlan types" ;
                          sh:name         "vlan type" ;
                          sh:order        12 ;
                          sh:path         gx:vlanType
] ;
        sh:property     [ skos:example    "'floating', 'fixed', 'provider-network'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Defines how public IP address are provided. Floating: floating ips are supported ." ;
                          sh:in           ( "floating" "fixed" "provider-network" ) ;
                          sh:maxCount     1 ;
                          sh:name         "public ip address provisioning" ;
                          sh:order        2 ;
                          sh:path         gx:publicIpAddressProvisioning
] ;
        sh:property     [ skos:example    "'192.46.52.0/24'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "CIDR Provider Identifier of network on the side Z" ;
                          sh:name         "prefix set_ z" ;
                          sh:order        18 ;
                          sh:path         gx:prefixSet_Z
] ;
        sh:property     [ skos:example    "'99 percent'" ;
                          sh:description  "Contractual availability of connection defined in the SLA agreement. If not specified, then best effort is assumed. Availability is measured in the pseudo-unit 'percent'." ;
                          sh:name         "availability" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        7 ;
                          sh:path         gx:availability
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "a resolvable link to the Terms and Conditions applying to that service." ;
                          sh:minCount     1 ;
                          sh:name         "terms and conditions" ;
                          sh:node         gx:TermsAndConditionsShape ;
                          sh:order        1 ;
                          sh:path         gx:termsAndConditions
] ;
        sh:property     [ skos:example    "'97.5%, 99%'" ;
                          sh:description  "Contractual percentile in the SLA. Usually referred to the nubmer of frames the SLA metrics such as availability, latency and jitter can bbe guaranteed." ;
                          sh:name         "target percentile" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        10 ;
                          sh:path         gx:targetPercentile
] ;
        sh:property     [ skos:example    "'ML', 'Classification'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Keywords that describe / tag the service." ;
                          sh:name         "keyword" ;
                          sh:order        7 ;
                          sh:path         dcat:keyword
] ;
        sh:property     [ skos:example    "'Copper cable', '5G'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a type of physical interface" ;
                          sh:name         "interface.type" ;
                          sh:order        2 ;
                          sh:path         gx:interface.type
] ;
        sh:property     [ skos:example    "'500 Gbps'" ;
                          sh:description  "Contractual bandwidth defined in the service level agreement (SLA). Bandwidth is usually measured in dimension of bits per second." ;
                          sh:name         "bandwidth" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        5 ;
                          sh:path         gx:bandwidth
] ;
        sh:property     [ skos:example    "' '" ;
                          sh:datatype     xsd:string ;
                          sh:description  "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
                          sh:minCount     1 ;
                          sh:name         "policy" ;
                          sh:order        2 ;
                          sh:path         gx:policy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of resource self-escription related to the service and that can exist independently of it." ;
                          sh:name         "aggregation of" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        2 ;
                          sh:path         gx:aggregationOf
] ;
        sh:property     [ skos:example    "'a MAC address', 'IP address'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "The ID of the source of the connection." ;
                          sh:name         "connection point a" ;
                          sh:order        3 ;
                          sh:path         gx:connectionPointA
] ;
        sh:property     [ skos:example    "'0.00002 %'" ;
                          sh:description  "Contractual packet loss of connection defined in the SLA agreement. If not specified, then best effort is assumed. PackageLoss s measured in the pseudo-unit 'percent'-" ;
                          sh:name         "packet loss" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        8 ;
                          sh:path         gx:packetLoss
] ;
        sh:property     [ skos:example    "'virtual', 'bare-metal', 'mixed'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Type of Service Offering. Choose one of the following: virtual, bare-metal, mixed" ;
                          sh:in           ( "virtual" "bare-metal" "mixed" ) ;
                          sh:maxCount     1 ;
                          sh:name         "service type" ;
                          sh:order        1 ;
                          sh:path         gx:serviceType
] ;
        sh:property     [ skos:example     "'200', '714'" ;
                          sh:datatype      xsd:decimal ;
                          sh:description   "autonomous system (AS) number (ASN) of the side A" ;
                          sh:minInclusive  0 ;
                          sh:name          "connected network_ a" ;
                          sh:order         15 ;
                          sh:path          gx:connectedNetwork_A
] ;
        sh:property     [ skos:example    "'10 seconds'" ;
                          sh:description  "Contractual latency defined in the SLA. If not specified, then best effort is assumed. Latency is usually measured in dimension of time." ;
                          sh:name         "latency" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        6 ;
                          sh:path         gx:latency
] ;
        sh:property     [ skos:example    "'0x8100', '0x88a8'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "The ethertype of the vlan in hexadecimal notation." ;
                          sh:name         "vlan ether type" ;
                          sh:order        14 ;
                          sh:path         gx:vlanEtherType
] ;
        sh:property     [ skos:example    "'Image classification ML service'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A human readable name of the component" ;
                          sh:maxCount     1 ;
                          sh:name         "name" ;
                          sh:order        5 ;
                          sh:path         gx:name
] ;
        sh:property     [ skos:example    "'IPV6', 'IPv4'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Version of IP address supported. IPv4: only ipV4 addresses are supported. IPv6: both version iIPV4 and IPv6 are supported." ;
                          sh:in           ( "ipV6" "IPv4" ) ;
                          sh:maxCount     1 ;
                          sh:name         "ip version" ;
                          sh:order        3 ;
                          sh:path         gx:ipVersion
] ;
        sh:property     [ skos:example    "' '" ;
                          sh:description  "a list of methods to export data out of the service" ;
                          sh:minCount     1 ;
                          sh:name         "data account export" ;
                          sh:node         gx:DataAccountExportShape ;
                          sh:order        4 ;
                          sh:path         gx:dataAccountExport
] ;
        sh:property     [ skos:example    "'(a reference to vcard:Address object)'" ;
                          sh:description  "A vcard:Address Object containing the physical location in ISO 3166-1 alpha2, alpha-3 or numeric format with at least the both ends of the connection." ;
                          sh:name         "location" ;
                          sh:node         gx:AddressShape ;
                          sh:order        1 ;
                          sh:path         gx:location
] ;
        sh:property     [ skos:example    "'An ML service for training, deploying and improving image classifiers.'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "A description in natural language" ;
                          sh:maxCount     1 ;
                          sh:name         "description" ;
                          sh:order        6 ;
                          sh:path         dct:description
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of participant self-descrription, who is offering this service offering." ;
                          sh:maxCount     1 ;
                          sh:minCount     1 ;
                          sh:name         "offered by" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        1 ;
                          sh:path         gx:offeredBy
] ;
        sh:property     [ skos:example    "'https://gaia-x.eu'" ;
                          sh:description  "DID of the service offering self-description related to the service and that can exist independently of it." ;
                          sh:name         "depends on" ;
                          sh:nodeKind     sh:IRI ;
                          sh:order        3 ;
                          sh:path         gx:dependsOn
] ;
        sh:property     [ skos:example    "'23', '175'" ;
                          sh:description  "Vlan Tag ID that range between 1 and 4094. In case qinq connection type is chosen tow vlan tag, namely outer and innter should be provided" ;
                          sh:name         "vlan tag" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        13 ;
                          sh:path         gx:vlanTag
] ;
        sh:property     [ skos:example    "'0.01 miliseconds'" ;
                          sh:description  "Contractual jitterdefined in the SLA. If not specified, then best effort is assumed. Jitter is measured in dimension of time." ;
                          sh:name         "jitter" ;
                          sh:node         gx:MeasureShape ;
                          sh:order        9 ;
                          sh:path         gx:jitter
] ;
        sh:property     [ skos:example     "'200', '714'" ;
                          sh:datatype      xsd:decimal ;
                          sh:description   "autonomous system (AS) number (ASN) of the side Z" ;
                          sh:minInclusive  0 ;
                          sh:name          "connected network_ z" ;
                          sh:order         16 ;
                          sh:path          gx:connectedNetwork_Z
] ;
        sh:property     [ skos:example    "'virtual', 'physical'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Default: virtual. How networks of different tenants are separated." ;
                          sh:in           ( "virtual" "physical" ) ;
                          sh:maxCount     1 ;
                          sh:name         "tenant separation" ;
                          sh:order        4 ;
                          sh:path         gx:tenantSeparation
] ;
        sh:targetClass  gx:Interconnection .

gx:StorageShape
