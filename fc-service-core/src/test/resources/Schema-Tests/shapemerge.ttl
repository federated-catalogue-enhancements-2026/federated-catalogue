                          sh:datatype     xsd:boolean ;
                          sh:description  "Default: False. True is storage service supports backus." ;
                          sh:maxCount     1 ;
                          sh:name         "backups supported" ;
                          sh:order        4 ;
                          sh:path         gx:backupsSupported
] ;
        sh:property     [ skos:example    "'True', 'False'" ;
                          sh:datatype     xsd:boolean ;
                          sh:description  "Default: False. True is storage service supports snapshots." ;
                          sh:maxCount     1 ;
                          sh:name         "snapshot supported" ;
                          sh:order        3 ;
                          sh:path         gx:snapshotSupported
] ;
        sh:property     [ skos:example    "'virtual', 'bare-metal', 'mixed'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Type of Service Offering. Choose one of the following: virtual, bare-metal, mixed" ;
                          sh:in           ( "virtual" "bare-metal" "mixed" ) ;
                          sh:maxCount     1 ;
                          sh:name         "service type" ;
                          sh:order        1 ;
                          sh:path         gx:serviceType
] ;
        sh:property     [ skos:example    "'FAT32', 'FAT16', 'exFAT', 'HFS+', 'APFS', 'ext4', 'ext3', 'ext2', 'NTFS'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "File system of storage services provides." ;
                          sh:in           ( "FAT32" "FAT16" "exFAT" "HFS+" "APFS" "ext4" "ext3" "ext2" "NTFS" ) ;
                          sh:maxCount     1 ;
                          sh:name         "file system" ;
                          sh:order        1 ;
                          sh:path         gx:fileSystem
] ;
        sh:property     [ skos:example    "'Hybrid', 'gx:PrivateProvisioning'" ;
                          sh:datatype     xsd:string ;
                          sh:description  "Provision type of the service" ;
                          sh:maxCount     1 ;
                          sh:name         "provision type" ;
                          sh:order        8 ;
                          sh:path         gx:provisionType
] ;
        sh:targetClass  gx:ObjectStorage .

