@prefix sh: <http://www.w3.org/ns/shacl#> .

@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix did: <https://www.w3.org/TR/did-core/#> .
@prefix gx: <https://w3id.org/gaia-x/2511#> .

gx:CPUShape
	a sh:NodeShape ;
	sh:targetClass gx:CPU ;
	sh:property [ sh:path gx:cpuArchitecture ;
				  sh:name "cpu architecture" ;
				  sh:order 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:cpuGeneration ;
				  sh:name "cpu generation" ;
				  sh:order 2 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:cpuFlag ;
				  sh:name "cpu flag" ;
				  sh:order 3 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:smtIsEnabled ;
				  sh:name "smt is enabled" ;
				  sh:order 4 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:boolean ] ;
	sh:property [ sh:path gx:numberOfCores ;
				  sh:name "number of cores" ;
				  sh:order 5 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:integer ] ;
	sh:property [ sh:path gx:numberOfThreads ;
				  sh:name "number of threads" ;
				  sh:order 6 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:integer ] ;
	sh:property [ sh:path gx:frequency ;
				  sh:name "frequency" ;
				  sh:order 7 ;
				  sh:maxCount 1 ;
				  sh:node gx:MeasureShape ] ;
	sh:property [ sh:path gx:boostFrequency ;
				  sh:name "boost frequency" ;
				  sh:order 8 ;
				  sh:maxCount 1 ;
				  sh:node gx:MeasureShape ] ;
	sh:property [ sh:path gx:cacheSize ;
				  sh:name "cache size" ;
				  sh:order 9 ;
				  sh:maxCount 1 ;
				  sh:node gx:MeasureShape ] ;
	sh:property [ sh:path gx:allowedSocket ;
				  sh:name "allowed socket" ;
				  sh:order 10 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:name ;
				  sh:name "name" ;
				  sh:order 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
	sh:property [ sh:path gx:vendor ;
				  sh:name "vendor" ;
				  sh:order 2 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
.

gx:MeasureShape
	a sh:NodeShape ;
	sh:targetClass gx:Measure ;
	sh:property [ sh:path gx:value ;
				  sh:name "value" ;
				  sh:order 1 ;
				  sh:minCount 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:float ] ;
	sh:property [ sh:path gx:unit ;
				  sh:name "unit" ;
				  sh:order 2 ;
				  sh:minCount 1 ;
				  sh:maxCount 1 ;
				  sh:datatype xsd:string ] ;
.
