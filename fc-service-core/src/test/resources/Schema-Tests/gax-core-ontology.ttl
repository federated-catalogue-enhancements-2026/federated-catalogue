@prefix cc: <http://creativecommons.org/ns#> .
@prefix cred: <https://www.w3.org/TR/vc-data-model/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gx: <https://w3id.org/gaia-x/2511#> .

gx: a voaf:Vocabulary,
        owl:Ontology ;
    rdfs:label "Gaia-X Core Ontology"@en ;
    cc:license <http://www.apache.org/licenses/LICENSE-2.0> ;
    dct:abstract """The Gaia-X core ontology contains the components needed to model an efficient, competitive, secure and trustworthy federation of data infrastructure and service providers.

The different ontology modules can be found here:

Core: <a href="https://www.w3id.org/gaia-x/core">https://www.w3id.org/gaia-x/core</a>

Resource: <a href="https://www.w3id.org/gaia-x/resource">https://www.w3id.org/gaia-x/resource</a>

Participant: <a href="https://www.w3id.org/gaia-x/participant">https://www.w3id.org/gaia-x/participant</a>

Service Offering: <a href="https://www.w3id.org/gaia-x/service">https://www.w3id.org/gaia-x/service</a>

Compliance: <a href="https://www.w3id.org/gaia-x/compliance">https://www.w3id.org/gaia-x/compliance</a>

All underlying information for this documentation page can be found on the landing page of the Gaia-X Service Characteristics repository: <a href="https://gaia-x.gitlab.io/technical-committee/service-characteristics">https://gaia-x.gitlab.io/technical-committee/service-characteristics</a>.

Additional information on the constraints that have to be fulfilled be the self descriptions can be found here: <a href="https://gaia-x.gitlab.io/technical-committee/service-characteristics/yaml2shacl">https://gaia-x.gitlab.io/technical-committee/service-characteristics/yaml2shacl</a>.""" ;
    dct:contributor "Akyürek, Haydar",
        "Bader, Sebastian",
        "Baum, Hannes",
        "Blanch, Josep",
        "Frömberg, Jan",
        "Gronlier, Pierre",
        "Hermsen, Felix",
        "Lange, Christoph",
        "Langkau, Jörg",
        "Leberecht, Markus",
        "Meinke, Kai",
        "Moosmann, Paul",
        "Niessen, Thomas",
        "Ogel, Frederic",
        "Ottradovetz, Klaus",
        "Qin, Chang",
        "Rubina, Alina",
        "Staginus, Judith",
        "Strunk, Anja",
        "Theissen-Lipp, Johannes" ;
    dct:created "2021-10-18T12:00:00+01:00"^^xsd:dateTimeStamp ;
    dct:creator "Working Group Service Characteristics" ;
    dct:modified "2022-10-26T18:32:04+02:00"^^xsd:dateTimeStamp ;
    dct:title "Gaia-X Core Ontology"@en ;
    vann:preferredNamespacePrefix "gax-core" ;
    vann:preferredNamespaceUri "https://w3id.org/gaia-x/2511#" ;
    void:vocabulary dct:,
        vann:,
        voaf:,
        void: ;
    owl:versionInfo "22.04" .

gx:aggregationOf a owl:ObjectProperty ;
    rdfs:label "aggregation of"@en ;
    rdfs:comment "DID of resource self-escription related to the service and that can exist independently of it.",
        "DID of resources self-description related to the resource and that can exist independently of it." ;
    rdfs:domain gx:Resource,
        gx:ServiceOffering ;
    rdfs:range gx:Resource .

gx:operatedBy a owl:ObjectProperty ;
    rdfs:label "operated by"@en ;
    rdfs:comment "DID of resources self-description related to the resource and that can exist independently of it." ;
    rdfs:domain gx:Resource ;
    rdfs:range gx:Resource .

gx:providedBy a owl:ObjectProperty ;
    rdfs:label "provided by"@en ;
    rdfs:comment "DID of participant self-descrription providing this service offering." ;
    rdfs:domain gx:ServiceOffering ;
    rdfs:range gx:Participant .

gx: a voaf:Vocabulary,
        owl:Ontology ;
    rdfs:label "Gaia-X gax-trust-framework Ontology"@en ;
    cc:license <http://www.apache.org/licenses/LICENSE-2.0> ;
    dct:abstract "todo" ;
    dct:contributor "Akyürek, Haydar",
        "Bader, Sebastian",
        "Baum, Hannes",
        "Blanch, Josep",
        "Frömberg, Jan",
        "Gronlier, Pierre",
        "Hermsen, Felix",
        "Lange, Christoph",
        "Langkau, Jörg",
        "Leberecht, Markus",
        "Meinke, Kai",
        "Moosmann, Paul",
        "Niessen, Thomas",
        "Ogel, Frederic",
        "Ottradovetz, Klaus",
        "Qin, Chang",
        "Rubina, Alina",
        "Staginus, Judith",
        "Strunk, Anja",
        "Theissen-Lipp, Johannes" ;
    dct:created "2021-10-18T12:00:00+01:00"^^xsd:dateTimeStamp ;
    dct:creator "Working Group Service Characteristics" ;
    dct:modified "2022-10-26T18:32:04+02:00"^^xsd:dateTimeStamp ;
    dct:title "Gaia-X gax-trust-framework Ontology"@en ;
    vann:preferredNamespacePrefix "gax-trust-framework" ;
    vann:preferredNamespaceUri "https://w3id.org/gaia-x/2511#" ;
    void:vocabulary dct:,
        vann:,
        voaf:,
        void: ;
    owl:versionInfo "22.04" .

gx:BigData a owl:Class ;
    rdfs:label "Big Data"@en ;
    rdfs:subClassOf gx:Platform .

gx:Database a owl:Class ;
    rdfs:label "Database"@en ;
    rdfs:subClassOf gx:Platform .

gx:DigitalIdentityWallet a owl:Class ;
    rdfs:label "Digital Identity Wallet"@en ;
    rdfs:subClassOf gx:Wallet .

gx:GpuPassThrough a owl:DatatypeProperty ;
    rdfs:label "gpu pass through"@en ;
    rdfs:comment "Default: False. True, if GPU Pass-Through is activated. Either set numberOfvGPU or GpuPassThrough=true. Both options are prohibitted." ;
    rdfs:domain gx:Flavor ;
    rdfs:range xsd:boolean .

gx:IdentityFederation a owl:Class ;
    rdfs:label "Identity Federation"@en ;
    rdfs:subClassOf gx:IdentityAccessManagement .

gx:IdentityProvider a owl:Class ;
    rdfs:label "Identity Provider"@en ;
    rdfs:subClassOf gx:IdentityAccessManagement .

gx:PhysicalNode a owl:Class ;
    rdfs:label "Physical Node"@en ;
    rdfs:subClassOf gx:Node,
        gx:PhysicalResource .

gx:SoftwareOffering a owl:Class ;
    rdfs:label "Software Offering"@en ;
    rdfs:subClassOf gx:ServiceOffering .

gx:accessType a owl:DatatypeProperty ;
    rdfs:label "access type"@en ;
    rdfs:comment "type of data support: digital, physical." ;
    rdfs:domain gx:DataAccountExport ;
    rdfs:range xsd:string .

gx:additionalDisk a owl:ObjectProperty ;
    rdfs:label "additional disk"@en ;
    rdfs:comment "Detailed information about additional disks of this flavor." ;
    rdfs:domain gx:Flavor ;
    rdfs:range gx:Disk .

gx:aggregationOf a owl:ObjectProperty ;
    rdfs:label "aggregation of"@en ;
    rdfs:comment "Resources related to the resource and that can exist independently of it." ;
    rdfs:domain gx:Resource ;
    rdfs:range gx:Resource .

gx:allowedSocket a owl:DatatypeProperty ;
    rdfs:label "allowed socket"@en ;
    rdfs:comment "Socket the CPU fits into." ;
    rdfs:domain gx:CPU ;
    rdfs:range xsd:string .

gx:architecture a owl:DatatypeProperty ;
    rdfs:label "architecture"@en ;
    rdfs:comment "CPU Architecture required to instantiate this image." ;
    rdfs:domain gx:Image ;
    rdfs:range xsd:string .

gx:authKind a owl:DatatypeProperty ;
    rdfs:label "auth kind"@en ;
    rdfs:comment "Indicate, which kind of authentication is used. \"credentials\": Authentication with username and password. \"ssl-cert\": Authentication with X.509 certificates." ;
    rdfs:domain gx:IdentityAccessManagement ;
    rdfs:range xsd:string .

gx:availability a owl:ObjectProperty ;
    rdfs:label "availability"@en ;
    rdfs:comment "Contractual availability of connection defined in the SLA agreement. If not specified, then best effort is assumed. Availability is measured in the pseudo-unit \"percent\"." ;
    rdfs:domain gx:Interconnection ;
    rdfs:range gx:Measure .

gx:backupsSupported a owl:DatatypeProperty ;
    rdfs:label "backups supported"@en ;
    rdfs:comment "Default: False. True is storage service supports backus." ;
    rdfs:domain gx:Storage ;
    rdfs:range xsd:boolean .

gx:bandwidth a owl:ObjectProperty ;
    rdfs:label "bandwidth"@en ;
    rdfs:comment "Contractual bandwidth defined in the service level agreement (SLA). Bandwidth is usually measured in dimension of bits per second." ;
    rdfs:domain gx:Interconnection ;
    rdfs:range gx:Measure .

gx:boostFrequency a owl:ObjectProperty ;
    rdfs:label "boost frequency"@en ;
    rdfs:comment "Boost frequency of the CPU" ;
    rdfs:domain gx:CPU ;
    rdfs:range gx:Measure .

gx:cRValidFrom a owl:DatatypeProperty ;
    rdfs:label "valid from"@en ;
    rdfs:comment "Indicates the first date when the compliance reference goes into effect" ;
    rdfs:domain gx:ComplianceReference ;
    rdfs:range xsd:dateTime .

gx:cRValidUntil a owl:DatatypeProperty ;
    rdfs:label "valid until"@en ;
    rdfs:comment "Indicates the last date when the compliance reference is no more into effect" ;
    rdfs:domain gx:ComplianceReference ;
    rdfs:range xsd:dateTime .

gx:cacheSize a owl:ObjectProperty ;
    rdfs:label "cache size"@en ;
    rdfs:comment "Cache size of the CPU" ;
    rdfs:domain gx:CPU ;
    rdfs:range gx:Measure .

gx:canCertifyThirdPartyComplianceCertificationScheme a owl:ObjectProperty ;
    rdfs:label "can certify third party compliance certification scheme"@en ;
    rdfs:comment "IDs of the Third Party Compliance Certification Scheme this Compliance Assessment Body can certify." ;
    rdfs:domain gx:ComplianceAssessmentBody ;
    rdfs:range gx:ThirdPartyComplianceCertificationScheme .

gx:canHostServiceOffering a owl:ObjectProperty ;
    rdfs:label "can host service offering"@en ;
    rdfs:comment "List of references of Service Offering that may be hosted on this location" ;
    rdfs:domain gx:Location ;
    rdfs:range gx:ServiceOffering .

gx:certificateAuthority a owl:DatatypeProperty ;
    rdfs:label "certificate authority"@en ;
    rdfs:comment "Certificate authority for this service or its certificate" ;
    rdfs:domain gx:Certificates ;
    rdfs:range xsd:string .

gx:certificateDocument a owl:DatatypeProperty ;
    rdfs:label "certificate document"@en ;
    rdfs:comment "Document that contains a certificate copy" ;
    rdfs:domain gx:Certificates ;
    rdfs:range xsd:string .

gx:certificateName a owl:DatatypeProperty ;
    rdfs:label "certificate name"@en ;
    rdfs:comment "Relevant certificate for the service" ;
    rdfs:domain gx:Certificates ;
    rdfs:range xsd:string .

gx:certificateType a owl:DatatypeProperty ;
    rdfs:label "certificate type"@en ;
    rdfs:comment "Type of the certificates" ;
    rdfs:domain gx:Certificates ;
    rdfs:range xsd:string .

gx:checkSum a owl:DatatypeProperty ;
    rdfs:label "check sum"@en ;
    rdfs:comment "Checksum of this image." ;
    rdfs:domain gx:Image ;
    rdfs:range xsd:string .

gx:connectedNetwork_A a owl:DatatypeProperty ;
    rdfs:label "connected network a"@en ;
    rdfs:comment "autonomous system (AS) number (ASN) of the side A" ;
    rdfs:domain gx:Interconnection ;
    rdfs:range xsd:decimal .

gx:connectedNetwork_Z a owl:DatatypeProperty ;
    rdfs:label "connected network z"@en ;
    rdfs:comment "autonomous system (AS) number (ASN) of the side Z" ;
    rdfs:domain gx:Interconnection ;
    rdfs:range xsd:decimal .

gx:connection a owl:DatatypeProperty ;
    rdfs:label "connection"@en ;
    rdfs:comment "Interconnection of the GPU" ;
    rdfs:domain gx:GPU ;
    rdfs:range xsd:string .

gx:connectionPointA a owl:DatatypeProperty ;
    rdfs:label "connection point a"@en ;
    rdfs:comment "The ID of the source of the connection." ;
    rdfs:domain gx:Interconnection ;
    rdfs:range xsd:string .

gx:connectionPointZ a owl:DatatypeProperty ;
    rdfs:label "connection point z"@en ;
    rdfs:comment "The ID of the destination of the connection." ;
    rdfs:domain gx:Interconnection ;
    rdfs:range xsd:string .

gx:connectionType a owl:DatatypeProperty ;
    rdfs:label "connection type"@en ;
    rdfs:comment "the supported types of connection, preferably specified as a controlled vocabulary entry" ;
    rdfs:domain gx:Interconnection ;
    rdfs:range xsd:string .

gx:consolePort a owl:DatatypeProperty ;
    rdfs:label "console port"@en ;
    rdfs:comment "A dedicated port for console tasks." ;
    rdfs:domain gx:NetworkingDevice ;
    rdfs:range xsd:string .

gx:containerFormat a owl:DatatypeProperty ;
    rdfs:label "container format"@en ;
    rdfs:comment "Container format. Default: BARE" ;
    rdfs:domain gx:Image ;
    rdfs:range xsd:string .

gx:containsPII a owl:DatatypeProperty ;
    rdfs:label "contains pii"@en ;
    rdfs:comment "Boolean determined by Participant owning the Data Resource." ;
    rdfs:domain gx:DataResource ;
    rdfs:range xsd:boolean .

gx:content a owl:DatatypeProperty ;
    rdfs:label "content"@en ;
    rdfs:comment "a resolvable link to document" ;
    rdfs:domain gx:TermsAndConditions ;
    rdfs:range xsd:anyURI .

gx:copyrightOwnedBy a owl:ObjectProperty ;
    rdfs:label "copyright owned by"@en ;
    rdfs:comment "The copyright owner(s), given as a Gaia-X Participant or as some other agent, possibly also a person outside of Gaia-X. A copyright owner is a person or organization, that has the right to exploit the resource. Copyright owner does not necessary refer to the author of the resource, who is a natural person and may differ from copyright owner. A simple name string can be referenced as a blank node whose foaf:name attribute has that string value." ;
    rdfs:domain gx:VirtualResource ;
    rdfs:range foaf:Agent .

gx:cpu a owl:ObjectProperty ;
    rdfs:label "cpu"@en ;
    rdfs:comment "Description of CPU(s) of this node",
        "Detailed information about CPU used by this flavor." ;
    rdfs:domain gx:Flavor,
        gx:Node ;
    rdfs:range gx:CPU .

gx:cpuArchitecture a owl:DatatypeProperty ;
    rdfs:label "cpu architecture"@en ;
    rdfs:comment "Basic CPU architecture." ;
    rdfs:domain gx:CPU ;
    rdfs:range xsd:string .

gx:cpuCount a owl:ObjectProperty ;
    rdfs:label "cpu count"@en ;
    rdfs:comment "Number of available CPUs." ;
    rdfs:domain gx:NetworkingDevice ;
    rdfs:range gx:Measure .

gx:cpuFlag a owl:DatatypeProperty ;
    rdfs:label "cpu flag"@en ;
    rdfs:comment "CPU flags as documented by lscpu and defined in https://github.com/torvalds/linux/blob/master/tools/arch/x86/include/asm/cpufeatures.h." ;
    rdfs:domain gx:CPU ;
    rdfs:range xsd:string .

gx:cpuGeneration a owl:DatatypeProperty ;
    rdfs:label "cpu generation"@en ;
    rdfs:comment "CPU instruction set generation. Determines basic feature set and migration compatibility." ;
    rdfs:domain gx:CPU ;
    rdfs:range xsd:string .

gx:creationTime a owl:DatatypeProperty ;
    rdfs:label "creation time"@en ;
    rdfs:comment "Timestamp the service has been created." ;
    rdfs:domain gx:DataConnector ;
    rdfs:range xsd:dateTimeStamp .

gx:credentialSubject a owl:ObjectProperty ;
    rdfs:label "credential subject"@en ;
    rdfs:comment "ID of the claim to be signed in a verifiable credential build with all the information that are bound in the claim. In case of third party credential the ID is the ID of the third party",
        "Id of the claim to be signed in a verifiable credential build with all the information that are bound in the claim. In case of third party credential the id is the id of the third party" ;
    rdfs:domain gx:ComplianceCertificateCredential,
        gx:ThirdPartyComplianceCertificateCredential ;
    rdfs:range gx:ComplianceCertificateClaim,
        gx:ThirdPartyComplianceCertificateClaim .

gx:dataAccountExport a owl:ObjectProperty ;
    rdfs:label "data account export"@en ;
    rdfs:comment "a list of methods to export data out of the service" ;
    rdfs:domain gx:ServiceOffering ;
    rdfs:range gx:DataAccountExport .

gx:dataProtectionRegime a owl:DatatypeProperty ;
    rdfs:label "data protection regime"@en ;
    rdfs:comment "a list of data protection regime from the list available below" ;
    rdfs:domain gx:ServiceOffering ;
    rdfs:range xsd:string .

gx:description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Textual description of this organization." ;
    rdfs:domain gx:LegalPerson ;
    rdfs:range xsd:string .

gx:descriptionOfTestScope a owl:DatatypeProperty ;
    rdfs:label "description of test scope"@en ;
    rdfs:comment "Description of the scope of testing for this service" ;
    rdfs:domain gx:Certificates ;
    rdfs:range xsd:string .

gx:disableUserAccountDaysInactive a owl:DatatypeProperty ;
    rdfs:label "disable user account days inactive"@en ;
    rdfs:comment "Days of account inactivity before a user account is disabled." ;
    rdfs:domain gx:IdentityAccessManagement ;
    rdfs:range xsd:integer .

gx:disk a owl:ObjectProperty ;
    rdfs:label "disk"@en ;
    rdfs:comment "Description of disk(s) of this nodes" ;
    rdfs:domain gx:Node ;
    rdfs:range gx:Disk .

gx:diskFormat a owl:DatatypeProperty ;
    rdfs:label "disk format"@en ;
    rdfs:comment "Disk format. Default: RAW" ;
    rdfs:domain gx:Image ;
    rdfs:range xsd:string .

gx:encryption a owl:ObjectProperty ;
    rdfs:label "encryption"@en ;
    rdfs:comment "Details on encryption capabilities of this image registry." ;
    rdfs:domain gx:ImageRegistry ;
    rdfs:range gx:Encryption .

gx:encryptionAlgorithm a owl:DatatypeProperty ;
    rdfs:label "encryption algorithm"@en ;
    rdfs:comment "Supported algorithm used to encrypt." ;
    rdfs:domain gx:Encryption ;
    rdfs:range xsd:string .

gx:encryptionMethod a owl:DatatypeProperty ;
    rdfs:label "encryption method"@en ;
    rdfs:comment "Default: None. Define encryption method of storage service. None: means no encryption art all. managed: Virtual storage is encrypted by key managed provider. byok: Virtual storage  " ;
    rdfs:domain gx:Storage ;
    rdfs:range xsd:string .

gx:endPointURL a owl:DatatypeProperty ;
    rdfs:label "end point url"@en ;
    rdfs:comment "The URL of the endpoint where it can be accessed" ;
    rdfs:domain gx:Endpoint ;
    rdfs:range xsd:anyURI .

gx:endpoint a owl:ObjectProperty ;
    rdfs:label "endpoint"@en ;
    rdfs:comment "Endpoint through which the Service Offering can be accessed" ;
    rdfs:domain gx:ServiceOffering ;
    rdfs:range gx:Endpoint .

gx:endpointDescription a owl:DatatypeProperty ;
    rdfs:label "endpoint description"@en ;
    rdfs:comment "The Description (e.g. openAPI Description) of the endpoint" ;
    rdfs:domain gx:Endpoint ;
    rdfs:range xsd:anyURI .

gx:expirationDate a owl:DatatypeProperty ;
    rdfs:label "expiration date"@en ;
    rdfs:comment "Date on which the certificate expires" ;
    rdfs:domain gx:Certificates ;
    rdfs:range xsd:date .

gx:expirationDateTime a owl:DatatypeProperty ;
    rdfs:label "expiration date time"@en ;
    rdfs:comment "Date time in ISO 8601 format after which data is expired and shall be deleted." ;
    rdfs:domain gx:DataResource ;
    rdfs:range xsd:dateTime .

gx:exposedThrough a owl:ObjectProperty ;
    rdfs:label "exposed through"@en ;
    rdfs:comment "A resolvable link to the data exchange component that exposes the data resource." ;
    rdfs:domain gx:DataResource ;
    rdfs:range gx:Participant .

gx:fileSystem a owl:DatatypeProperty ;
    rdfs:label "file system"@en ;
    rdfs:comment "File system of storage service.",
        "File system of storage services provides." ;
    rdfs:domain gx:FileStorage,
        gx:ObjectStorage ;
    rdfs:range xsd:string .

gx:flavor a owl:ObjectProperty ;
    rdfs:label "flavor"@en ;
    rdfs:comment "Detailed description of available flavors. A flavor describes the size of the server. " ;
    rdfs:domain gx:Compute ;
    rdfs:range gx:Flavor .

gx:formatType a owl:DatatypeProperty ;
    rdfs:label "format type"@en ;
    rdfs:comment "type of Media Types (formerly known as MIME types) as defined by the IANA." ;
    rdfs:domain gx:DataAccountExport ;
    rdfs:range xsd:string .

gx:fpga a owl:ObjectProperty ;
    rdfs:label "fpga"@en ;
    rdfs:comment "Detailed information about FPGA used by this flavor." ;
    rdfs:domain gx:Flavor ;
    rdfs:range gx:FPGA .

gx:frequency a owl:ObjectProperty ;
    rdfs:label "frequency"@en ;
    rdfs:comment "Frequency of the CPU" ;
    rdfs:domain gx:CPU ;
    rdfs:range gx:Measure .

gx:generation a owl:DatatypeProperty ;
    rdfs:label "generation"@en ;
    rdfs:comment "FPGA generation." ;
    rdfs:domain gx:FPGA ;
    rdfs:range xsd:string .

gx:getVerifiableCredentialsIDs a owl:DatatypeProperty ;
    rdfs:label "get verifiable credentials ds"@en ;
    rdfs:comment "A route used to synchronize catalogues and retrieve the list of Verifiable Credentials (issuer, id)." ;
    rdfs:domain gx:Catalogue ;
    rdfs:range xsd:string .

gx:gpu a owl:ObjectProperty ;
    rdfs:label "gpu"@en ;
    rdfs:comment "Description of GPU(s) of this node.",
        "Detailed information about GPU used by this flavor." ;
    rdfs:domain gx:Flavor,
        gx:Node ;
    rdfs:range gx:GPU .

gx:gpuGeneration a owl:DatatypeProperty ;
    rdfs:label "gpu generation"@en ;
    rdfs:comment "GPU generation." ;
    rdfs:domain gx:GPU ;
    rdfs:range xsd:string .

gx:grantsComplianceCriteriaCombination a owl:ObjectProperty ;
    rdfs:label "grants compliance criteria combination"@en ;
    rdfs:comment "ID of Compliance Criterion Combination granted by the scheme in case of certification" ;
    rdfs:domain gx:ComplianceCertificationScheme ;
    rdfs:range gx:ComplianceCriteriaCombination .

gx:hasAdministrativeLocation a owl:DatatypeProperty ;
    rdfs:label "has administrative location"@en ;
    rdfs:comment "ISO 3166-2 5 digit string for location" ;
    rdfs:domain gx:Location ;
    rdfs:range xsd:string .

gx:hasComplianceAssessmentBodies a owl:ObjectProperty ;
    rdfs:label "has compliance assessment bodies"@en ;
    rdfs:comment "Unordered list of IDs of ComplianceAssessmentBody (participant) endorsed having a Compliance Assessment Body role by the Compliance Reference. This unordered list is managed and validated by the Compliance Reference Manager" ;
    rdfs:domain gx:ThirdPartyComplianceCertificationScheme ;
    rdfs:range gx:ComplianceAssessmentBody .

gx:hasComplianceAssessmentBody a owl:ObjectProperty ;
    rdfs:label "has compliance assessment body"@en ;
    rdfs:comment "Id of the Participant (self-description) endorsed having a Compliance Assessment Body role that claims the compliance" ;
    rdfs:domain gx:ThirdPartyComplianceCertificateClaim ;
    rdfs:range gx:ComplianceAssessmentBody .

gx:hasComplianceCertificateClaim a owl:ObjectProperty ;
    rdfs:label "has compliance certificate claim"@en ;
    rdfs:comment "Ids of the compliance reference claims claimed by the provider for the located service" ;
    rdfs:domain gx:LocatedServiceOffering ;
    rdfs:range gx:ComplianceCertificateClaim .

gx:hasComplianceCertificateCredential a owl:ObjectProperty ;
    rdfs:label "has compliance certificate credential"@en ;
    rdfs:comment "Ids of the compliance reference claim claimed by the provider for the located service" ;
    rdfs:domain gx:LocatedServiceOffering ;
    rdfs:range gx:ComplianceCertificateCredential .

gx:hasComplianceCertificationScheme a owl:ObjectProperty ;
    rdfs:label "has compliance certification scheme"@en ;
    rdfs:comment "ID of the Compliance Certification Scheme (self-description) involved in the certification" ;
    rdfs:domain gx:ComplianceCertificateClaim ;
    rdfs:range gx:ComplianceCertificationScheme .

gx:hasComplianceCertificationSchemes a owl:ObjectProperty ;
    rdfs:label "has compliance certification schemes"@en ;
    rdfs:comment "List of schemes that grants certification. This list is managed by a reference manager." ;
    rdfs:domain gx:ComplianceReference ;
    rdfs:range gx:ComplianceCertificationScheme .

gx:hasComplianceReference a owl:ObjectProperty ;
    rdfs:label "has compliance reference"@en ;
    rdfs:comment "ID of Compliance Reference (self-description) to be certified by any means defined in the Certification Scheme" ;
    rdfs:domain gx:ComplianceCertificationScheme ;
    rdfs:range gx:ComplianceReference .

gx:hasComplianceReferenceManager a owl:ObjectProperty ;
    rdfs:label "has compliance reference manager"@en ;
    rdfs:comment "ID of Participant (self-description) in charge of managing this Compliance Reference" ;
    rdfs:domain gx:ComplianceReference ;
    rdfs:range gx:ComplianceReferenceManager .

gx:hasComplianceReferenceTitle a owl:DatatypeProperty ;
    rdfs:label "has compliance reference title"@en ;
    rdfs:comment "Name of the Compliance Reference" ;
    rdfs:domain gx:ComplianceReference ;
    rdfs:range xsd:string .

gx:hasComplianceReferences a owl:ObjectProperty ;
    rdfs:label "has compliance references"@en ;
    rdfs:comment "Unordered list of Ids of ComplianceReferences (self-description) managed by this ComplianceReferenceManager" ;
    rdfs:domain gx:ComplianceReferenceManager ;
    rdfs:range gx:ComplianceReference .

gx:hasLevel a owl:DatatypeProperty ;
    rdfs:label "has level"@en ;
    rdfs:comment "A description in natural language of the Gaia-X Label Level as defined in TF document",
        "A description in natural language of the Label level. The level ordering is done by alphanumeric order." ;
    rdfs:domain gx:ComplianceCriterion,
        gx:ComplianceLabel ;
    rdfs:range xsd:string .

gx:hasLocatedServiceOffering a owl:ObjectProperty ;
    rdfs:label "has located service offering"@en ;
    rdfs:comment "Ids of Located Service Offerings on this location" ;
    rdfs:domain gx:Location ;
    rdfs:range gx:LocatedServiceOffering .

gx:hasLocations a owl:ObjectProperty ;
    rdfs:label "has locations"@en ;
    rdfs:comment "Ids of available Locations for this provider" ;
    rdfs:domain gx:Provider ;
    rdfs:range gx:Location .

gx:hasName a owl:DatatypeProperty ;
    rdfs:label "has name"@en ;
    rdfs:comment "Name of the Gaia-X Criterion",
        "Name of the Gaia-X Label",
        "Name of the Gaia-X criteria combination" ;
    rdfs:domain gx:ComplianceCriteriaCombination,
        gx:ComplianceCriterion,
        gx:ComplianceLabel ;
    rdfs:range xsd:string .

gx:hasProvider a owl:ObjectProperty ;
    rdfs:label "has provider"@en ;
    rdfs:comment "Id of the participant who operates the Location Unit that implements the Service Offering" ;
    rdfs:domain gx:Location ;
    rdfs:range gx:Provider .

gx:hasReferenceUrl a owl:DatatypeProperty ;
    rdfs:label "has reference url"@en ;
    rdfs:comment "URI to reference the content of the compliance reference in a single PDF file" ;
    rdfs:domain gx:ComplianceReference ;
    rdfs:range xsd:anyURI .

gx:hasRequiredCriteriaCombinations a owl:ObjectProperty ;
    rdfs:label "has required criteria combinations"@en ;
    rdfs:comment "List of Criteria Combinations. If one of these Combinations is valid the Label is Granted" ;
    rdfs:domain gx:ComplianceLabel ;
    rdfs:range gx:ComplianceCriteriaCombination .

gx:hasServiceOffering a owl:ObjectProperty ;
    rdfs:label "has service offering"@en ;
    rdfs:comment "ID of the Service Offering (self-description) certified for the compliance",
        "Ids of the ServiceOffering managed by this provider." ;
    rdfs:domain gx:ComplianceCertificateClaim,
        gx:Provider ;
    rdfs:range gx:LocatedServiceOffering,
        gx:ServiceOffering .

gx:hasSha256 a owl:DatatypeProperty ;
    rdfs:label "has sha"@en ;
    rdfs:comment "SHA256 of PDF document referenced by hasReferenceUrl." ;
    rdfs:domain gx:ComplianceReference ;
    rdfs:range xsd:string .

gx:hasThirdPartyComplianceCertificateClaim a owl:ObjectProperty ;
    rdfs:label "has third party compliance certificate claim"@en ;
    rdfs:comment "IDs of Certificate claims issued by this Compliance Assessment Body." ;
    rdfs:domain gx:ComplianceAssessmentBody ;
    rdfs:range gx:ThirdPartyComplianceCertificateClaim .

gx:hasThirdPartyComplianceCredential a owl:ObjectProperty ;
    rdfs:label "has third party compliance credential"@en ;
    rdfs:comment "IDs of the Certificate claims VC certified by this Compliance Assessment Body." ;
    rdfs:domain gx:ComplianceAssessmentBody ;
    rdfs:range gx:ThirdPartyComplianceCertificateCredential .

gx:hasVersion a owl:DatatypeProperty ;
    rdfs:label "has version"@en ;
    rdfs:comment "versioning according to [semver](https://semver.org/)." ;
    rdfs:domain gx:ComplianceReference ;
    rdfs:range xsd:string .

gx:hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "sha256 hash of the above document." ;
    rdfs:domain gx:TermsAndConditions ;
    rdfs:range xsd:string .

gx:headquarterAddress a owl:ObjectProperty ;
    rdfs:label "headquarter address"@en ;
    rdfs:comment "The full legal address of the organization." ;
    rdfs:domain gx:LegalPerson ;
    rdfs:range vcard:Address .

gx:host a owl:DatatypeProperty ;
    rdfs:label "host"@en ;
    rdfs:comment "Host of the access point" ;
    rdfs:domain gx:ServiceAccessPoint ;
    rdfs:range xsd:string .

gx:hostedOn a owl:ObjectProperty ;
    rdfs:label "hosted on"@en ;
    rdfs:comment "a resource where the instance of this virtual resource is being executed on." ;
    rdfs:domain gx:InstantiatedVirtualResource ;
    rdfs:range gx:Resource .

gx:hypervisor a owl:DatatypeProperty ;
    rdfs:label "hypervisor"@en ;
    rdfs:comment "Ability to lable high-performance CPUs, disks, network. Choose one of the following classes: CPU, GPU, disk, network, none. Default value none" ;
    rdfs:domain gx:Flavor ;
    rdfs:range xsd:string .

gx:identity a owl:ObjectProperty ;
    rdfs:label "identity"@en ;
    rdfs:comment "Reference to identity access management service  storage service offing to create disks used within this compute service." ;
    rdfs:domain gx:Compute ;
    rdfs:range gx:IdentityAccessManagement .

gx:image a owl:ObjectProperty ;
    rdfs:label "image"@en ;
    rdfs:comment "Images available in this image registry." ;
    rdfs:domain gx:ImageRegistry ;
    rdfs:range gx:Image .

gx:imageRegistry a owl:ObjectProperty ;
    rdfs:label "image registry"@en ;
    rdfs:comment "Reference to image registry of this compute service." ;
    rdfs:domain gx:Compute ;
    rdfs:range gx:ImageRegistry .

gx:imageType a owl:DatatypeProperty ;
    rdfs:label "image type"@en ;
    rdfs:comment "Type of this image. Default: virtual machine" ;
    rdfs:domain gx:Image ;
    rdfs:range xsd:string .

gx:instanceOf a owl:ObjectProperty ;
    rdfs:label "instance of"@en ;
    rdfs:comment "A virtual resource (normally a software resource) this process is an instance of." ;
    rdfs:domain gx:InstantiatedVirtualResource ;
    rdfs:range gx:Resource .

gx:interface.type a owl:DatatypeProperty ;
    rdfs:label "interface type"@en ;
    rdfs:comment "a type of physical interface" ;
    rdfs:domain gx:Interconnection ;
    rdfs:range xsd:string .

gx:ipVersion a owl:DatatypeProperty ;
    rdfs:label "ip version"@en ;
    rdfs:comment "Version of IP address supported. IPv4: only ipV4 addresses are supported. IPv6: both version iIPV4 and IPv6 are supported." ;
    rdfs:domain gx:Network ;
    rdfs:range xsd:string .

gx:isHostedOn a owl:ObjectProperty ;
    rdfs:label "is hosted on"@en ;
    rdfs:comment "Id of the Location where this located service is hosted on" ;
    rdfs:domain gx:LocatedServiceOffering ;
    rdfs:range gx:Location .

gx:isImplementationOf a owl:ObjectProperty ;
    rdfs:label "is implementation of"@en ;
    rdfs:comment "Id of the Service Offering referenced by this located service" ;
    rdfs:domain gx:LocatedServiceOffering ;
    rdfs:range gx:ServiceOffering .

gx:isPartOfScalingGroup a owl:DatatypeProperty ;
    rdfs:label "is part of scaling group"@en ;
    rdfs:comment "lists autoscaling group that this VM belongs to." ;
    rdfs:domain gx:Compute ;
    rdfs:range xsd:string .

gx:jitter a owl:ObjectProperty ;
    rdfs:label "jitter"@en ;
    rdfs:comment "Contractual jitterdefined in the SLA. If not specified, then best effort is assumed. Jitter is measured in dimension of time." ;
    rdfs:domain gx:Interconnection ;
    rdfs:range gx:Measure .

gx:keyManagement a owl:DatatypeProperty ;
    rdfs:label "key management"@en ;
    rdfs:comment "Define key management method. \"managed\": Keys are created by and stored in key manager of cloud. \"byok\": bring-your-own-key: Keys created by user and stored in key manager of cloud. \"hyok\" hold-your-own-key Key created by user and kept by user" ;
    rdfs:domain gx:Encryption,
        gx:Signing ;
    rdfs:range xsd:string .

gx:latency a owl:ObjectProperty ;
    rdfs:label "latency"@en ;
    rdfs:comment "Contractual latency defined in the SLA. If not specified, then best effort is assumed. Latency is usually measured in dimension of time." ;
    rdfs:domain gx:Interconnection ;
    rdfs:range gx:Measure .

gx:legalAddress a owl:ObjectProperty ;
    rdfs:label "legal address"@en ;
    rdfs:comment "The full legal address of the organization." ;
    rdfs:domain gx:LegalPerson ;
    rdfs:range vcard:Address .

gx:legalBasis a owl:DatatypeProperty ;
    rdfs:label "legal basis"@en ;
    rdfs:comment "NOTE: Mandatory if containsPII is true. One of the reasons as detailed in the identified Personal Data Protection Regimes, such as [GDPR2018]. Potential Legal Bases can be [article 6], article 7, (https://eur-lex.europa.eu/legal-content/EN/TXT/HTML/?uri=CELEX:32016R0679&from=EN#d1e1888-1-1) or article 9. It shall be expressed as a string matching 6.1.[a-f], 6.1.4, 7 or 9.2.[a-j]. (Note: this list is not final, as GDPR and Member State Law may provide for additional legal basis. Those will be implemented as options in future iterations.)" ;
    rdfs:domain gx:DataResource ;
    rdfs:range xsd:string .

gx:legalForm a owl:DatatypeProperty ;
    rdfs:label "legal form"@en ;
    rdfs:comment "Legal form" ;
    rdfs:domain gx:LegalPerson ;
    rdfs:range xsd:string .

gx:legalName a owl:DatatypeProperty ;
    rdfs:label "legal name"@en ;
    rdfs:comment "Legally binding name" ;
    rdfs:domain gx:LegalPerson ;
    rdfs:range xsd:string .

gx:leiCode a owl:DatatypeProperty ;
    rdfs:label "lei code"@en ;
    rdfs:comment "Unique LEI number as defined by https://www.gleif.org." ;
    rdfs:domain gx:LegalPerson ;
    rdfs:range xsd:string .

gx:license a owl:DatatypeProperty ;
    rdfs:label "license"@en ;
    rdfs:comment "A list of SPDX license identifiers or URL to license document" ;
    rdfs:domain gx:VirtualResource ;
    rdfs:range xsd:string .

gx:location a owl:ObjectProperty ;
    rdfs:label "location"@en ;
    rdfs:comment "A vcard:Address Object containing the physical location in ISO 3166-1 alpha2, alpha-3 or numeric format with at least the both ends of the connection." ;
    rdfs:domain gx:Interconnection ;
    rdfs:range vcard:Address .

gx:locationAddress a owl:ObjectProperty ;
    rdfs:label "location address"@en ;
    rdfs:comment "A vcard:Address object that contains the physical location in ISO 3166-1 alpha2, alpha-3 or numeric format." ;
    rdfs:domain gx:PhysicalResource ;
    rdfs:range vcard:Address .

gx:locationGPS a owl:DatatypeProperty ;
    rdfs:label "location gps"@en ;
    rdfs:comment "A list of physical GPS in ISO 6709:2008/Cor 1:2009 format." ;
    rdfs:domain gx:PhysicalResource ;
    rdfs:range xsd:string .

gx:maintainedBy a owl:ObjectProperty ;
    rdfs:label "maintained by"@en ;
    rdfs:comment "Participant maintaining the resource in operational condition and thus have physical access to it.",
        "a list of participants  maintaining the resource in operational condition." ;
    rdfs:domain gx:InstantiatedVirtualResource,
        gx:PhysicalResource ;
    rdfs:range gx:Participant .

gx:managementPort a owl:DatatypeProperty ;
    rdfs:label "management port"@en ;
    rdfs:comment "A dedicated port for management tasks." ;
    rdfs:domain gx:NetworkingDevice ;
    rdfs:range xsd:string .

gx:manufacturedBy a owl:ObjectProperty ;
    rdfs:label "manufactured by"@en ;
    rdfs:comment "Participant manufacturing the resource." ;
    rdfs:domain gx:PhysicalResource ;
    rdfs:range gx:Participant .

gx:memorySize a owl:ObjectProperty ;
    rdfs:label "memory size"@en ;
    rdfs:comment "Memory of the GPU" ;
    rdfs:domain gx:GPU ;
    rdfs:range gx:Measure .

gx:memoryType a owl:DatatypeProperty ;
    rdfs:label "memory type"@en ;
    rdfs:comment "Memory type of the GPU" ;
    rdfs:domain gx:GPU ;
    rdfs:range xsd:string .

gx:minRamSize a owl:ObjectProperty ;
    rdfs:label "min ram size"@en ;
    rdfs:comment "Mininal size of ram required to instantiate this image." ;
    rdfs:domain gx:Image ;
    rdfs:range gx:Measure .

gx:name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "A human readable name of the component",
        "Name of resource.",
        "Name of the access point",
        "Procuct name of the hardware resource.",
        "Unique name of this flavor.",
        "Unique name of this volume type." ;
    rdfs:domain gx:Flavor,
        gx:HardwareSpec,
        gx:Resource,
        gx:ServiceAccessPoint,
        gx:ServiceOffering,
        gx:VolumeType ;
    rdfs:range xsd:string .

gx:network a owl:ObjectProperty ;
    rdfs:label "network"@en ;
    rdfs:comment "Reference to network service offing for this compute service." ;
    rdfs:domain gx:Compute ;
    rdfs:range gx:Network .

gx:networkAdress a owl:DatatypeProperty ;
    rdfs:label "network adress"@en ;
    rdfs:comment "IP address of the netowrking device" ;
    rdfs:domain gx:NetworkingDevice ;
    rdfs:range xsd:float .

gx:nic a owl:ObjectProperty ;
    rdfs:label "nic"@en ;
    rdfs:comment "Description of network interface card(s) of this node" ;
    rdfs:domain gx:Node ;
    rdfs:range gx:Measure .

gx:numberOfCores a owl:DatatypeProperty ;
    rdfs:label "number of cores"@en ;
    rdfs:comment "Number of Cores of the CPU" ;
    rdfs:domain gx:CPU ;
    rdfs:range xsd:integer .

gx:numberOfThreads a owl:DatatypeProperty ;
    rdfs:label "number of threads"@en ;
    rdfs:comment "Number of Threads of the CPU" ;
    rdfs:domain gx:CPU ;
    rdfs:range xsd:integer .

gx:numberOfvCPUs a owl:DatatypeProperty ;
    rdfs:label "number ofv us"@en ;
    rdfs:comment "Number of virtual CPUs." ;
    rdfs:domain gx:Flavor ;
    rdfs:range xsd:integer .

gx:numberOfvGPUs a owl:DatatypeProperty ;
    rdfs:label "number ofv us"@en ;
    rdfs:comment "Number of virtual GPUs. Either set numberOfvGPU or GpuPassThrough=true. Using both options are prohibitted." ;
    rdfs:domain gx:Flavor ;
    rdfs:range xsd:integer .

gx:obsoleteDateTime a owl:DatatypeProperty ;
    rdfs:label "obsolete date time"@en ;
    rdfs:comment "Date time in ISO 8601 format after which data is obsolete." ;
    rdfs:domain gx:DataResource ;
    rdfs:range xsd:dateTime .

gx:openAPI a owl:DatatypeProperty ;
    rdfs:label "open api"@en ;
    rdfs:comment "URL of the OpenAPI documentation" ;
    rdfs:domain gx:ServiceAccessPoint ;
    rdfs:range xsd:string .

gx:ownedBy a owl:ObjectProperty ;
    rdfs:label "owned by"@en ;
    rdfs:comment "Participant owning the resource." ;
    rdfs:domain gx:PhysicalResource ;
    rdfs:range gx:Participant .

gx:packetLoss a owl:ObjectProperty ;
    rdfs:label "packet loss"@en ;
    rdfs:comment "Contractual packet loss of connection defined in the SLA agreement. If not specified, then best effort is assumed. PackageLoss s measured in the pseudo-unit \"percent\"-" ;
    rdfs:domain gx:Interconnection ;
    rdfs:range gx:Measure .

gx:parentOrganization a owl:ObjectProperty ;
    rdfs:label "parent organization"@en ;
    rdfs:comment "A list of direct participant that this entity is a subOrganization of, if any." ;
    rdfs:domain gx:LegalPerson ;
    rdfs:range gx:Participant .

gx:passwordExpiresDays a owl:DatatypeProperty ;
    rdfs:label "password expires days"@en ;
    rdfs:comment "Days until a user must renew their password. This attribute is only allowed with authKind=credentials." ;
    rdfs:domain gx:IdentityAccessManagement ;
    rdfs:range xsd:integer .

gx:performanceClass a owl:DatatypeProperty ;
    rdfs:label "performance class"@en ;
    rdfs:comment "Ability to lable high-performance CPUs, disks, network. Choose one of the following classes: CPU, GPU, disk, network, none. Default value none" ;
    rdfs:domain gx:Flavor ;
    rdfs:range xsd:string .

gx:physicalResource a owl:ObjectProperty ;
    rdfs:label "physical resource"@en ;
    rdfs:comment "a list of resource with information of where is the data located" ;
    rdfs:domain gx:DataConnector ;
    rdfs:range gx:PhysicalResource .

gx:policies a owl:DatatypeProperty ;
    rdfs:label "policies"@en ;
    rdfs:comment "a list of policy expressed using a DSL used by the data connector policy engine leveraging Gaia-X Self-descriptions as both data inputs and policy inputs" ;
    rdfs:domain gx:DataConnector ;
    rdfs:range xsd:anyURI .

gx:policy a owl:DatatypeProperty ;
    rdfs:label "policy"@en ;
    rdfs:comment "A list of policy expressed using a DSL (e.g., Rego or ODRL) (access control, throttling, usage, retention, …)",
        "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
    rdfs:domain gx:ServiceOffering,
        gx:VirtualResource ;
    rdfs:range xsd:string .

gx:port a owl:DatatypeProperty ;
    rdfs:label "port"@en ;
    rdfs:comment "Port of the access point" ;
    rdfs:domain gx:ServiceAccessPoint ;
    rdfs:range xsd:string .

gx:portCapacity_A a owl:DatatypeProperty ;
    rdfs:label "port capacity a"@en ;
    rdfs:comment "The assigned capacity of ports." ;
    rdfs:domain gx:NetworkingDevice ;
    rdfs:range xsd:float .

gx:portCapacity_A_Count a owl:DatatypeProperty ;
    rdfs:label "port capacity count"@en ;
    rdfs:comment "The assigned number of ports." ;
    rdfs:domain gx:NetworkingDevice ;
    rdfs:range xsd:integer .

gx:prefixSet_A a owl:DatatypeProperty ;
    rdfs:label "prefix set a"@en ;
    rdfs:comment "CIDR Provider Identifier of network on the side A" ;
    rdfs:domain gx:Interconnection ;
    rdfs:range xsd:string .

gx:prefixSet_Z a owl:DatatypeProperty ;
    rdfs:label "prefix set z"@en ;
    rdfs:comment "CIDR Provider Identifier of network on the side Z" ;
    rdfs:domain gx:Interconnection ;
    rdfs:range xsd:string .

gx:privateImagesAllowed a owl:DatatypeProperty ;
    rdfs:label "private images allowed"@en ;
    rdfs:comment "Default: \"true\". \"true\" means that the image registry supports upload of private user images." ;
    rdfs:domain gx:ImageRegistry ;
    rdfs:range xsd:boolean .

gx:privateKeyExportFormat a owl:DatatypeProperty ;
    rdfs:label "private key export format"@en ;
    rdfs:comment "a list of machine readable format used to export private keys." ;
    rdfs:domain gx:VerifiableCredentialWallet ;
    rdfs:range xsd:string .

gx:producedBy a owl:ObjectProperty ;
    rdfs:label "produced by"@en ;
    rdfs:comment "A resolvable link to the participant self-description legally enabling the data usage." ;
    rdfs:domain gx:DataResource ;
    rdfs:range gx:Participant .

gx:protocol a owl:DatatypeProperty ;
    rdfs:label "protocol"@en ;
    rdfs:comment "Protocol of the access point" ;
    rdfs:domain gx:ServiceAccessPoint ;
    rdfs:range xsd:string .

gx:provisionType a owl:DatatypeProperty ;
    rdfs:label "provision type"@en ;
    rdfs:comment "Provision type of the service" ;
    rdfs:domain gx:ServiceOffering ;
    rdfs:range xsd:string .

gx:publicIpAddressProvisioning a owl:DatatypeProperty ;
    rdfs:label "public ip address provisioning"@en ;
    rdfs:comment "Defines how public IP address are provided. Floating: floating ips are supported ." ;
    rdfs:domain gx:Network ;
    rdfs:range xsd:string .

gx:publisher a owl:DatatypeProperty ;
    rdfs:label "publisher"@en ;
    rdfs:comment "Publisher of the standard." ;
    rdfs:domain gx:Standard ;
    rdfs:range xsd:string .

gx:ramSize a owl:ObjectProperty ;
    rdfs:label "ram size"@en ;
    rdfs:comment "Amount of memory available for the server.",
        "Ram size of the networking device" ;
    rdfs:domain gx:Flavor,
        gx:NetworkingDevice ;
    rdfs:range gx:Measure .

gx:ramsize a owl:ObjectProperty ;
    rdfs:label "ramsize"@en ;
    rdfs:comment "Size of RAM of this node" ;
    rdfs:domain gx:Node ;
    rdfs:range gx:Measure .

gx:redundantPowerSupply a owl:DatatypeProperty ;
    rdfs:label "redundant power supply"@en ;
    rdfs:comment "Availability of redundant power supply for the cases of emergency." ;
    rdfs:domain gx:NetworkingDevice ;
    rdfs:range xsd:string .

gx:registrationNumber a owl:DatatypeProperty ;
    rdfs:label "registration number"@en ;
    rdfs:comment "Country’s registration number which identifies one specific entity. Valid formats are local, EUID, EORI, vatID, leiCode." ;
    rdfs:domain gx:LegalPerson ;
    rdfs:range xsd:string .

gx:regularAudits a owl:DatatypeProperty ;
    rdfs:label "regular audits"@en ;
    rdfs:comment "Is the certificate regularly audited?" ;
    rdfs:domain gx:Certificates ;
    rdfs:range xsd:boolean .

gx:requestType a owl:DatatypeProperty ;
    rdfs:label "request type"@en ;
    rdfs:comment "the mean to request data retrieval: API, email, webform, unregisteredLetter, registeredLetter, supportCenter." ;
    rdfs:domain gx:DataAccountExport ;
    rdfs:range xsd:string .

gx:requiredOrGrantedCriteria a owl:ObjectProperty ;
    rdfs:label "required or granted criteria"@en ;
    rdfs:comment "List of Required Criteria to be granted for the label or list of granted Criteria by the compliance. All the Criteria have to be granted (logic AND)" ;
    rdfs:domain gx:ComplianceCriteriaCombination ;
    rdfs:range gx:ComplianceCriterion .

gx:rootDisk a owl:ObjectProperty ;
    rdfs:label "root disk"@en ;
    rdfs:comment "Detailed information about root disk of this flavor." ;
    rdfs:domain gx:Flavor ;
    rdfs:range gx:Disk .

gx:serviceAccessPoint a owl:ObjectProperty ;
    rdfs:label "service access point"@en ;
    rdfs:comment "A list of Service Access Point which can be an endpoint as a mean to access and interact with the resource" ;
    rdfs:domain gx:InstantiatedVirtualResource ;
    rdfs:range gx:ServiceAccessPoint .

gx:serviceType a owl:DatatypeProperty ;
    rdfs:label "service type"@en ;
    rdfs:comment "Type of Service Offering. Choose one of the following: virtual, bare-metal, mixed" ;
    rdfs:domain gx:Network,
        gx:Storage ;
    rdfs:range xsd:string .

gx:signatureAlgo a owl:DatatypeProperty ;
    rdfs:label "signature algo"@en ;
    rdfs:comment "Defines algorithm used to sign" ;
    rdfs:domain gx:Signing ;
    rdfs:range xsd:string .

gx:signing a owl:ObjectProperty ;
    rdfs:label "signing"@en ;
    rdfs:comment "Details on signing capabilities of this image registry." ;
    rdfs:domain gx:ImageRegistry ;
    rdfs:range gx:Signing .

gx:size a owl:ObjectProperty ;
    rdfs:label "size"@en ;
    rdfs:comment "Size of this image ",
        "The size of that hard drive." ;
    rdfs:domain gx:Disk,
        gx:Image ;
    rdfs:range gx:Measure .

gx:smtIsEnabled a owl:DatatypeProperty ;
    rdfs:label "smt is enabled"@en ;
    rdfs:comment "Is simultaneous multithreading (SMT) or hyper threading (HT) active in this CPU? Default False." ;
    rdfs:domain gx:CPU ;
    rdfs:range xsd:boolean .

gx:snapshotSupported a owl:DatatypeProperty ;
    rdfs:label "snapshot supported"@en ;
    rdfs:comment "Default: False. True is storage service supports snapshots." ;
    rdfs:domain gx:Storage ;
    rdfs:range xsd:boolean .

gx:standardConformity a owl:ObjectProperty ;
    rdfs:label "standard conformity"@en ;
    rdfs:comment "Provides information about applied standards." ;
    rdfs:domain gx:DataConnector,
        gx:Endpoint ;
    rdfs:range gx:Standard .

gx:standardReference a owl:DatatypeProperty ;
    rdfs:label "standard reference"@en ;
    rdfs:comment "Provides a link to schemas or details about applied standards." ;
    rdfs:domain gx:Standard ;
    rdfs:range xsd:anyURI .

gx:storage a owl:ObjectProperty ;
    rdfs:label "storage"@en ;
    rdfs:comment "Reference to storage service offing to create disks used within this compute service." ;
    rdfs:domain gx:Compute ;
    rdfs:range gx:Storage .

gx:subOrganization a owl:ObjectProperty ;
    rdfs:label "sub organization"@en ;
    rdfs:comment "A list of direct participant with an legal mandate on this entity, e.g., as a subsidiary." ;
    rdfs:domain gx:LegalPerson ;
    rdfs:range gx:Participant .

gx:supportedProtocols a owl:DatatypeProperty ;
    rdfs:label "supported protocols"@en ;
    rdfs:comment "List of  supported protocols among used layers should be specified." ;
    rdfs:domain gx:NetworkingDevice ;
    rdfs:range xsd:string .

gx:targetPercentile a owl:ObjectProperty ;
    rdfs:label "target percentile"@en ;
    rdfs:comment "Contractual percentile in the SLA. Usually referred to the nubmer of frames the SLA metrics such as availability, latency and jitter can bbe guaranteed." ;
    rdfs:domain gx:Interconnection ;
    rdfs:range gx:Measure .

gx:tenantOwnedBy a owl:ObjectProperty ;
    rdfs:label "tenant owned by"@en ;
    rdfs:comment "A list of participant with contractual relation with the resource." ;
    rdfs:domain gx:InstantiatedVirtualResource ;
    rdfs:range gx:Participant .

gx:tenantSeparation a owl:DatatypeProperty ;
    rdfs:label "tenant separation"@en ;
    rdfs:comment "Default: virtual. How compute resources of different tenants are separated.",
        "Default: virtual. How networks of different tenants are separated." ;
    rdfs:domain gx:Compute,
        gx:Network ;
    rdfs:range xsd:string .

gx:termsAndConditions a owl:ObjectProperty ;
    rdfs:label "terms and conditions"@en ;
    rdfs:comment "a resolvable link to the Terms and Conditions applying to that service." ;
    rdfs:domain gx:ServiceOffering ;
    rdfs:range gx:TermsAndConditions .

gx:title a owl:DatatypeProperty ;
    rdfs:label "title"@en ;
    rdfs:comment "Name of the standard." ;
    rdfs:domain gx:Standard ;
    rdfs:range xsd:string .

gx:type a owl:DatatypeProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "The type of that hard drive.",
        "Type of networking device",
        "Type of the data asset, which helps discovery.  Preferably a controlled vocabulary entry referenced by URI",
        "Type of this Orchestration Service Offering, such as kubernetes.",
        "Type of virtual node" ;
    rdfs:domain gx:DataConnector,
        gx:Disk,
        gx:NetworkingDevice,
        gx:Orchestration,
        gx:VirtualNode ;
    rdfs:range xsd:string .

gx:unit a owl:DatatypeProperty ;
    rdfs:label "unit"@en ;
    rdfs:comment "The unit of this measurement" ;
    rdfs:domain gx:Measure ;
    rdfs:range xsd:string .

gx:value a owl:DatatypeProperty ;
    rdfs:label "value"@en ;
    rdfs:comment "The value of this measurement." ;
    rdfs:domain gx:Measure ;
    rdfs:range xsd:float .

gx:vendor a owl:DatatypeProperty ;
    rdfs:label "vendor"@en ;
    rdfs:comment "Vendor of this hardware." ;
    rdfs:domain gx:HardwareSpec ;
    rdfs:range xsd:string .

gx:verifiableCredentialExportFormat a owl:DatatypeProperty ;
    rdfs:label "verifiable credential export format"@en ;
    rdfs:comment "a list of machine readable format used to export verifiable credentials." ;
    rdfs:domain gx:VerifiableCredentialWallet ;
    rdfs:range xsd:string .

gx:version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "Version of the access point",
        "Version of this image." ;
    rdfs:domain gx:Image,
        gx:ServiceAccessPoint ;
    rdfs:range xsd:string .

gx:virtualResource a owl:ObjectProperty ;
    rdfs:label "virtual resource"@en ;
    rdfs:comment "a list of resource with information of who owns the data." ;
    rdfs:domain gx:DataConnector ;
    rdfs:range gx:VirtualResource .

gx:vlanEtherType a owl:DatatypeProperty ;
    rdfs:label "vlan ether type"@en ;
    rdfs:comment "The ethertype of the vlan in hexadecimal notation." ;
    rdfs:domain gx:Interconnection ;
    rdfs:range xsd:string .

gx:vlanTag a owl:ObjectProperty ;
    rdfs:label "vlan tag"@en ;
    rdfs:comment "Vlan Tag ID that range between 1 and 4094. In case qinq connection type is chosen tow vlan tag, namely outer and innter should be provided" ;
    rdfs:domain gx:Interconnection ;
    rdfs:range gx:Measure .

gx:vlanType a owl:DatatypeProperty ;
    rdfs:label "vlan type"@en ;
    rdfs:comment "the chosen types of vlan types" ;
    rdfs:domain gx:Interconnection ;
    rdfs:range xsd:string .

gx:volumeTypes a owl:ObjectProperty ;
    rdfs:label "volume types"@en ;
    rdfs:comment "List of volume types supported by this block storage" ;
    rdfs:domain gx:BlockStorage ;
    rdfs:range gx:VolumeType .

gx:BlockStorage a owl:Class ;
    rdfs:label "Block Storage"@en ;
    rdfs:subClassOf gx:Storage .

