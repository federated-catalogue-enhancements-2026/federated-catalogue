            sh:minCount 1 ;
            sh:name "policy" ;
            sh:order 3 ;
            sh:path gx:policy ],
        [ skos:example "'Example Resource'" ;
            sh:datatype xsd:string ;
            sh:description "Name of resource." ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 1 ;
            sh:path gx:name ],
        [ skos:example "'Example Resource placed somewhere in Europe'" ;
            sh:datatype xsd:string ;
            sh:description "A more detailed description of resource." ;
            sh:maxCount 1 ;
            sh:name "description" ;
            sh:order 2 ;
            sh:path dct:description ],
        [ skos:example "'(a reference to gx:Resource object)'" ;
            sh:description "Resources related to the resource and that can exist independently of it." ;
            sh:name "aggregation of" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:aggregationOf ],
        [ skos:example "''" ;
            sh:description "DID of resources self-description related to the resource and that can exist independently of it." ;
            sh:name "aggregation of" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:aggregationOf ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of resources self-description related to the resource and that can exist independently of it." ;
            sh:name "operated by" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:operatedBy ] ;
    sh:targetClass gx:VirtualResource .

gx:WalletShape a sh:NodeShape ;
    sh:targetClass gx:Wallet .

gx:EncryptionShape a sh:NodeShape ;
    sh:property [ skos:example "'none', 'rsa'" ;
            sh:datatype xsd:string ;
            sh:description "Supported algorithm used to encrypt." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "encryption algorithm" ;
            sh:order 1 ;
            sh:path gx:encryptionAlgorithm ],
        [ skos:example "'managed', 'byok', 'hyok'" ;
            sh:datatype xsd:string ;
            sh:description "Define key management method. 'managed': Keys are created by and stored in key manager of cloud. 'byok': bring-your-own-key: Keys created by user and stored in key manager of cloud. 'hyok' hold-your-own-key Key created by user and kept by user" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "key management" ;
            sh:order 2 ;
            sh:path gx:keyManagement ] ;
    sh:targetClass gx:Encryption .

gx:FPGAShape a sh:NodeShape ;
    sh:property [ skos:example "'Fermi', 'Kepler', 'Gen9'" ;
            sh:datatype xsd:string ;
            sh:description "FPGA generation." ;
            sh:maxCount 1 ;
            sh:name "generation" ;
            sh:order 1 ;
            sh:path gx:generation ] ;
    sh:targetClass gx:FPGA .

gx:FlavorShape a sh:NodeShape ;
    sh:property [ skos:example "'small', 'medium', 'large'" ;
            sh:datatype xsd:string ;
            sh:description "Unique name of this flavor." ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 1 ;
            sh:path gx:name ],
        [ skos:example "'(a structured object of type gax-core_CPU'" ;
            sh:description "Detailed information about CPU used by this flavor." ;
            sh:maxCount 1 ;
            sh:name "cpu" ;
            sh:node gx:CPUShape ;
            sh:order 2 ;
            sh:path gx:cpu ],
        [ skos:example "'2', '8'" ;
            sh:datatype xsd:integer ;
            sh:description "Number of virtual CPUs." ;
            sh:maxCount 1 ;
            sh:name "number ofv c p us" ;
            sh:order 3 ;
            sh:path gx:numberOfvCPUs ],
        [ skos:example "'(a structured object of type gax-core_CPU'" ;
            sh:description "Detailed information about GPU used by this flavor." ;
            sh:maxCount 1 ;
            sh:name "gpu" ;
            sh:node gx:GPUShape ;
            sh:order 4 ;
            sh:path gx:gpu ],
        [ skos:example "'2', '8'" ;
            sh:datatype xsd:integer ;
            sh:description "Number of virtual GPUs. Either set numberOfvGPU or GpuPassThrough=true. Using both options are prohibitted." ;
            sh:maxCount 1 ;
            sh:name "number ofv g p us" ;
            sh:order 5 ;
            sh:path gx:numberOfvGPUs ],
        [ skos:example "'2', '8'" ;
            sh:datatype xsd:boolean ;
            sh:description "Default: False. True, if GPU Pass-Through is activated. Either set numberOfvGPU or GpuPassThrough=true. Both options are prohibitted." ;
            sh:maxCount 1 ;
            sh:name " gpu pass through" ;
            sh:order 6 ;
            sh:path gx:GpuPassThrough ],
        [ skos:example "'(a structured object of type gx:FPGA'" ;
            sh:description "Detailed information about FPGA used by this flavor." ;
            sh:maxCount 1 ;
            sh:name "fpga" ;
            sh:node gx:FPGAShape ;
            sh:order 7 ;
            sh:path gx:fpga ],
        [ skos:example "'(a structured object of type gx:Measure)'" ;
            sh:description "Amount of memory available for the server." ;
            sh:maxCount 1 ;
            sh:name "ram size" ;
            sh:node gx:MeasureShape ;
            sh:order 8 ;
            sh:path gx:ramSize ],
        [ skos:example "'(a structured object of type gx:Disk)'" ;
            sh:description "Detailed information about root disk of this flavor." ;
            sh:maxCount 1 ;
            sh:name "root disk" ;
            sh:node gx:DiskShape ;
            sh:order 9 ;
            sh:path gx:rootDisk ],
        [ skos:example "'(a structured object of type gx:Disk)'" ;
            sh:description "Detailed information about additional disks of this flavor." ;
            sh:maxCount 1 ;
            sh:name "additional disk" ;
            sh:node gx:DiskShape ;
            sh:order 10 ;
            sh:path gx:additionalDisk ],
        [ skos:example "'cpu', 'disk', 'network', 'gpu', 'none'" ;
            sh:datatype xsd:string ;
            sh:description "Ability to lable high-performance CPUs, disks, network. Choose one of the following classes: CPU, GPU, disk, network, none. Default value none" ;
            sh:maxCount 1 ;
            sh:name "performance class" ;
            sh:order 11 ;
            sh:path gx:performanceClass ],
        [ skos:example "'(a structured object of type gx:Software)', 'bare-metal'" ;
            sh:datatype xsd:string ;
            sh:description "Ability to lable high-performance CPUs, disks, network. Choose one of the following classes: CPU, GPU, disk, network, none. Default value none" ;
            sh:maxCount 1 ;
            sh:name "hypervisor" ;
            sh:order 12 ;
            sh:path gx:hypervisor ] ;
    sh:targetClass gx:Flavor .

gx:SigningShape a sh:NodeShape ;
    sh:property [ skos:example "'md5-check-sum'" ;
            sh:datatype xsd:string ;
            sh:description "Defines algorithm used to sign" ;
            sh:name "signature algo" ;
            sh:order 1 ;
            sh:path gx:signatureAlgo ],
        [ skos:example "'managed', 'byok', 'hyok'" ;
            sh:datatype xsd:string ;
            sh:description "Define key management method. 'managed': Keys are created by and stored in key manager of cloud. 'byok': bring-your-own-key: Keys created by user and stored in key manager of cloud. 'hyok' hold-your-own-key Key created by user and kept by user" ;
            sh:minCount 1 ;
            sh:name "key management" ;
            sh:order 2 ;
            sh:path gx:keyManagement ] ;
    sh:targetClass gx:Signing .

gx:VolumeTypeShape a sh:NodeShape ;
    sh:property [ skos:example "'small', 'medium', 'large'" ;
            sh:datatype xsd:string ;
            sh:description "Unique name of this volume type." ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 1 ;
            sh:path gx:name ] ;
    sh:targetClass gx:VolumeType .

gx:ServiceAccessPointShape a sh:NodeShape ;
    sh:property [ skos:example "'accesspointABC'" ;
            sh:datatype xsd:string ;
            sh:description "Name of the access point" ;
            sh:name "name" ;
            sh:order 1 ;
            sh:path gx:name ],
        [ skos:example "''" ;
            sh:datatype xsd:string ;
            sh:description "Host of the access point" ;
            sh:name "host" ;
            sh:order 2 ;
            sh:path gx:host ],
        [ skos:example "'TCP', 'UDP'" ;
            sh:datatype xsd:string ;
            sh:description "Protocol of the access point" ;
            sh:name "protocol" ;
            sh:order 3 ;
            sh:path gx:protocol ],
        [ skos:example "'1.2'" ;
            sh:datatype xsd:string ;
            sh:description "Version of the access point" ;
            sh:name "version" ;
            sh:order 4 ;
            sh:path gx:version ],
        [ skos:example "'8888'" ;
            sh:datatype xsd:string ;
            sh:description "Port of the access point" ;
            sh:name "port" ;
            sh:order 5 ;
            sh:path gx:port ],
        [ skos:example "'https://gaia-x.eu/openAPIdoc'" ;
            sh:datatype xsd:string ;
            sh:description "URL of the OpenAPI documentation" ;
            sh:name "open a p i" ;
            sh:order 6 ;
            sh:path gx:openAPI ],
        [ skos:example "'accesspointABC'" ;
            sh:datatype xsd:string ;
            sh:description "Name of the access point" ;
            sh:name "name" ;
            sh:order 1 ;
            sh:path gx:name ],
        [ skos:example "''" ;
            sh:datatype xsd:string ;
            sh:description "Host of the access point" ;
            sh:name "host" ;
            sh:order 2 ;
            sh:path gx:host ],
        [ skos:example "'TCP', 'UDP'" ;
            sh:datatype xsd:string ;
            sh:description "Protocol of the access point" ;
            sh:name "protocol" ;
            sh:order 3 ;
            sh:path gx:protocol ],
        [ skos:example "'1.2'" ;
            sh:datatype xsd:string ;
            sh:description "Version of the access point" ;
            sh:name "version" ;
            sh:order 4 ;
            sh:path gx:version ],
        [ skos:example "'8888'" ;
            sh:datatype xsd:string ;
            sh:description "Port of the access point" ;
            sh:name "port" ;
            sh:order 5 ;
            sh:path gx:port ],
        [ skos:example "'https://gaia-x.eu/openAPIdoc'" ;
