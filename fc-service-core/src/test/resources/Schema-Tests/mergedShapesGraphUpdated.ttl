            sh:minCount 1 ;
            sh:name "tenant owned by" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path gx:tenantOwnedBy ],
        [ skos:example "'PD-SAP', 'PLME-SAP'" ;
            sh:description "A list of Service Access Point which can be an endpoint as a mean to access and interact with the resource" ;
            sh:minCount 1 ;
            sh:name "service access point" ;
            sh:node gx:ServiceAccessPointShape ;
            sh:order 5 ;
            sh:path gx:serviceAccessPoint ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "The copyright owner(s), given as a Gaia-X Participant or as some other agent, possibly also a person outside of Gaia-X. A copyright owner is a person or organization, that has the right to exploit the resource. Copyright owner does not necessary refer to the author of the resource, who is a natural person and may differ from copyright owner. A simple name string can be referenced as a blank node whose foaf:name attribute has that string value." ;
            sh:minCount 1 ;
            sh:name "copyright owned by" ;
            sh:node gx:AgentShape ;
            sh:order 1 ;
            sh:path gx:copyrightOwnedBy ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:datatype xsd:string ;
            sh:description "A list of SPDX license identifiers or URL to license document" ;
            sh:minCount 1 ;
            sh:name "license" ;
            sh:order 2 ;
            sh:path gx:license ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:datatype xsd:string ;
            sh:description "A list of policy expressed using a DSL (e.g., Rego or ODRL) (access control, throttling, usage, retention, …)" ;
            sh:minCount 1 ;
            sh:name "policy" ;
            sh:order 3 ;
            sh:path gx:policy ],
        [ skos:example "'Example Resource'" ;
            sh:datatype xsd:string ;
            sh:description "Name of resource." ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 1 ;
            sh:path gx:name ],
        [ skos:example "'Example Resource placed somewhere in Europe'" ;
            sh:datatype xsd:string ;
            sh:description "A more detailed description of resource." ;
            sh:maxCount 1 ;
            sh:name "description" ;
            sh:order 2 ;
            sh:path dct:description ],
        [ skos:example "'(a reference to gx:Resource object)'" ;
            sh:description "Resources related to the resource and that can exist independently of it." ;
            sh:name "aggregation of" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:aggregationOf ] ;
    sh:targetClass gx:InstantiatedVirtualResource .

gx:InterconnectionShape a sh:NodeShape ;
    sh:property [ skos:example "'0x8100', '0x88a8'" ;
            sh:datatype xsd:string ;
            sh:description "The ethertype of the vlan in hexadecimal notation." ;
            sh:name "vlan ether type" ;
            sh:order 14 ;
            sh:path gx:vlanEtherType ],
        [ skos:example "'200', '714'" ;
            sh:datatype xsd:decimal ;
            sh:description "autonomous system (AS) number (ASN) of the side A" ;
            sh:name "connected network_ a" ;
            sh:order 15 ;
            sh:path gx:connectedNetwork_A ],
        [ skos:example "'200', '714'" ;
            sh:datatype xsd:decimal ;
            sh:description "autonomous system (AS) number (ASN) of the side Z" ;
            sh:name "connected network_ z" ;
            sh:order 16 ;
            sh:path gx:connectedNetwork_Z ],
        [ skos:example "'176.46.32.0/24'" ;
            sh:datatype xsd:string ;
            sh:description "CIDR Provider Identifier of network on the side A" ;
            sh:name "prefix set_ a" ;
            sh:order 17 ;
            sh:path gx:prefixSet_A ],
        [ skos:example "'192.46.52.0/24'" ;
            sh:datatype xsd:string ;
            sh:description "CIDR Provider Identifier of network on the side Z" ;
            sh:name "prefix set_ z" ;
            sh:order 18 ;
            sh:path gx:prefixSet_Z ],
        [ skos:example "'virtual', 'bare-metal', 'mixed'" ;
            sh:datatype xsd:string ;
            sh:description "Type of Service Offering. Choose one of the following: virtual, bare-metal, mixed" ;
            sh:maxCount 1 ;
            sh:name "service type" ;
            sh:order 1 ;
            sh:path gx:serviceType ],
        [ skos:example "'floating', 'fixed', 'provider-network'" ;
            sh:datatype xsd:string ;
            sh:description "Defines how public IP address are provided. Floating: floating ips are supported ." ;
            sh:maxCount 1 ;
            sh:name "public ip address provisioning" ;
            sh:order 2 ;
            sh:path gx:publicIpAddressProvisioning ],
        [ skos:example "'ipV6', 'IPv4'" ;
            sh:datatype xsd:string ;
            sh:description "Version of IP address supported. IPv4: only ipV4 addresses are supported. IPv6: both version iIPV4 and IPv6 are supported." ;
            sh:maxCount 1 ;
            sh:name "ip version" ;
            sh:order 3 ;
            sh:path gx:ipVersion ],
        [ skos:example "'virtual', 'physical'" ;
            sh:datatype xsd:string ;
            sh:description "Default: virtual. How networks of different tenants are separated." ;
            sh:maxCount 1 ;
            sh:name "tenant separation" ;
            sh:order 4 ;
            sh:path gx:tenantSeparation ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "a resolvable link to the Terms and Conditions applying to that service." ;
            sh:minCount 1 ;
            sh:name "terms and conditions" ;
            sh:node gx:TermsAndConditionsShape ;
            sh:order 1 ;
            sh:path gx:termsAndConditions ],
        [ skos:example "' '" ;
            sh:datatype xsd:string ;
            sh:description "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
            sh:minCount 1 ;
            sh:name "policy" ;
            sh:order 2 ;
            sh:path gx:policy ],
        [ skos:example "'GDPR2016', 'LGPD2019'" ;
            sh:datatype xsd:string ;
            sh:description "a list of data protection regime from the list available below" ;
            sh:name "data protection regime" ;
            sh:order 3 ;
            sh:path gx:dataProtectionRegime ],
        [ skos:example "' '" ;
            sh:description "a list of methods to export data out of the service" ;
            sh:minCount 1 ;
            sh:name "data account export" ;
            sh:node gx:DataAccountExportShape ;
            sh:order 4 ;
            sh:path gx:dataAccountExport ],
        [ skos:example "'Image classification ML service'" ;
            sh:datatype xsd:string ;
            sh:description "A human readable name of the component" ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 5 ;
            sh:path gx:name ],
        [ skos:example "'An ML service for training, deploying and improving image classifiers.'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language" ;
            sh:maxCount 1 ;
            sh:name "description" ;
            sh:order 6 ;
            sh:path dct:description ],
        [ skos:example "'ML', 'Classification'" ;
            sh:datatype xsd:string ;
            sh:description "Keywords that describe / tag the service." ;
            sh:name "keyword" ;
            sh:order 7 ;
            sh:path dcat:keyword ],
        [ skos:example "'Hybrid', 'gx:PrivateProvisioning'" ;
            sh:datatype xsd:string ;
            sh:description "Provision type of the service" ;
            sh:maxCount 1 ;
            sh:name "provision type" ;
            sh:order 8 ;
            sh:path gx:provisionType ],
        [ skos:example "'(reference to endpoint)'" ;
            sh:description "Endpoint through which the Service Offering can be accessed" ;
            sh:name "endpoint" ;
            sh:node gx:EndpointShape ;
            sh:order 9 ;
            sh:path gx:endpoint ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of participant self-descrription providing this service offering." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "provided by" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:providedBy ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of resource self-escription related to the service and that can exist independently of it." ;
            sh:name "aggregation of" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:aggregationOf ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of the service offering self-description related to the service and that can exist independently of it." ;
            sh:name "depends on" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:dependsOn ],
        [ skos:example "'(a reference to vcard:Address object)'" ;
            sh:description "A vcard:Address Object containing the physical location in ISO 3166-1 alpha2, alpha-3 or numeric format with at least the both ends of the connection." ;
            sh:name "location" ;
            sh:node gx:AddressShape ;
            sh:order 1 ;
            sh:path gx:location ],
        [ skos:example "'Copper cable', '5G'" ;
            sh:datatype xsd:string ;
            sh:description "a type of physical interface" ;
            sh:name "interface.type" ;
            sh:order 2 ;
            sh:path gx:interfaceType ],
        [ skos:example "'a MAC address', 'IP address'" ;
            sh:datatype xsd:string ;
            sh:description "The ID of the source of the connection." ;
            sh:name "connection point a" ;
            sh:order 3 ;
            sh:path gx:connectionPointA ],
        [ skos:example "'a MAC address', 'IP address'" ;
            sh:datatype xsd:string ;
            sh:description "The ID of the destination of the connection." ;
            sh:name "connection point z" ;
            sh:order 4 ;
            sh:path gx:connectionPointZ ],
        [ skos:example "'500 Gbps'" ;
            sh:description "Contractual bandwidth defined in the service level agreement (SLA). Bandwidth is usually measured in dimension of bits per second." ;
            sh:name "bandwidth" ;
            sh:node gx:MeasureShape ;
            sh:order 5 ;
            sh:path gx:bandwidth ],
        [ skos:example "'10 seconds'" ;
            sh:description "Contractual latency defined in the SLA. If not specified, then best effort is assumed. Latency is usually measured in dimension of time." ;
            sh:name "latency" ;
            sh:node gx:MeasureShape ;
            sh:order 6 ;
            sh:path gx:latency ],
        [ skos:example "'99 percent'" ;
            sh:description "Contractual availability of connection defined in the SLA agreement. If not specified, then best effort is assumed. Availability is measured in the pseudo-unit 'percent'." ;
            sh:name "availability" ;
            sh:node gx:MeasureShape ;
            sh:order 7 ;
            sh:path gx:availability ],
        [ skos:example "'0.00002 %'" ;
            sh:description "Contractual packet loss of connection defined in the SLA agreement. If not specified, then best effort is assumed. PackageLoss s measured in the pseudo-unit 'percent'-" ;
            sh:name "packet loss" ;
            sh:node gx:MeasureShape ;
            sh:order 8 ;
            sh:path gx:packetLoss ],
        [ skos:example "'0.01 miliseconds'" ;
            sh:description "Contractual jitterdefined in the SLA. If not specified, then best effort is assumed. Jitter is measured in dimension of time." ;
            sh:name "jitter" ;
            sh:node gx:MeasureShape ;
            sh:order 9 ;
            sh:path gx:jitter ],
        [ skos:example "'97.5%, 99%'" ;
            sh:description "Contractual percentile in the SLA. Usually referred to the nubmer of frames the SLA metrics such as availability, latency and jitter can bbe guaranteed." ;
            sh:name "target percentile" ;
            sh:node gx:MeasureShape ;
            sh:order 10 ;
            sh:path gx:targetPercentile ],
        [ skos:example "'ethernet unicast', 'multicast', 'broadcast support'" ;
            sh:datatype xsd:string ;
            sh:description "the supported types of connection, preferably specified as a controlled vocabulary entry" ;
            sh:name "connection type" ;
            sh:order 11 ;
            sh:path gx:connectionType ],
        [ skos:example "'qinq', 'dot1q'" ;
            sh:datatype xsd:string ;
            sh:description "the chosen types of vlan types" ;
            sh:name "vlan type" ;
            sh:order 12 ;
            sh:path gx:vlanType ],
        [ skos:example "'23', '175'" ;
            sh:description "Vlan Tag ID that range between 1 and 4094. In case qinq connection type is chosen tow vlan tag, namely outer and innter should be provided" ;
            sh:name "vlan tag" ;
            sh:node gx:MeasureShape ;
            sh:order 13 ;
            sh:path gx:vlanTag ] ;
    sh:targetClass gx:Interconnection .

gx:LegalPersonShape a sh:NodeShape ;
    sh:property [ skos:example "'ACME'" ;
            sh:datatype xsd:string ;
            sh:description "Legally binding name" ;
            sh:maxCount 1 ;
            sh:name "legal name" ;
            sh:order 1 ;
            sh:path gx:legalName ],
        [ skos:example "'L.L.C, GmbH'" ;
            sh:datatype xsd:string ;
            sh:description "Legal form" ;
            sh:maxCount 1 ;
            sh:name "legal form" ;
            sh:order 2 ;
            sh:path gx:legalForm ],
        [ skos:example "'A company making everything'" ;
            sh:datatype xsd:string ;
            sh:description "Textual description of this organization." ;
            sh:maxCount 1 ;
            sh:name "description" ;
            sh:order 3 ;
            sh:path gx:description ],
        [ skos:example "'DEU1234.HRB12345'" ;
            sh:datatype xsd:string ;
            sh:description "Country’s registration number which identifies one specific entity. Valid formats are local, EUID, EORI, vatID, leiCode." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "registration number" ;
            sh:order 4 ;
            sh:path gx:registrationNumber ],
        [ skos:example "'(a structured object which has the attribute country as mandatory attribute and some other optional attributes e.g., the attributes vcard:street-address,vcard:locality and vcard:country-name)'" ;
            sh:description "The full legal address of the organization." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "legal address" ;
            sh:node gx:AddressShape ;
            sh:order 5 ;
            sh:path gx:legalAddress ],
        [ skos:example "'(a structured object which has the attribute country as mandatory attribute and some other optional attributes e.g., the attributes vcard:street-address,vcard:locality and vcard:country-name)'" ;
            sh:description "The full legal address of the organization." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "headquarter address" ;
            sh:node gx:AddressShape ;
            sh:order 6 ;
            sh:path gx:headquarterAddress ],
        [ skos:example "'M07J9MTYHFCSVRBV2631'" ;
            sh:datatype xsd:string ;
            sh:description "Unique LEI number as defined by https://www.gleif.org." ;
            sh:maxCount 1 ;
            sh:name "lei code" ;
            sh:order 7 ;
            sh:path gx:leiCode ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "A list of direct participant that this entity is a subOrganization of, if any." ;
            sh:name "parent organization" ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path gx:parentOrganization ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "A list of direct participant with an legal mandate on this entity, e.g., as a subsidiary." ;
            sh:name "sub organization" ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path gx:subOrganization ] ;
    sh:targetClass gx:LegalPerson .

gx:LocatedServiceOfferingShape a sh:NodeShape ;
    sh:property [ skos:example "'did:web:example.com/serviceOffering/sha256'" ;
            sh:description "Id of the Service Offering referenced by this located service" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "is implementation of" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:isImplementationOf ],
        [ skos:example "'did:web:example.com/location/sha256'" ;
            sh:description "Id of the Location where this located service is hosted on" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "is hosted on" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:isHostedOn ],
        [ skos:example "'did:web:example.com/location/sha256'" ;
            sh:description "Ids of the compliance reference claims claimed by the provider for the located service" ;
            sh:name "has compliance certificate claim" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:hasComplianceCertificateClaim ],
        [ skos:example "'did:web:example.com/location/sha256'" ;
            sh:description "Ids of the compliance reference claim claimed by the provider for the located service" ;
            sh:name "has compliance certificate credential" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path gx:hasComplianceCertificateCredential ] ;
    sh:targetClass gx:LocatedServiceOffering .

gx:LocationShape a sh:NodeShape ;
    sh:property [ skos:example "'did:web:example.com/location/sha256'" ;
            sh:description "Id of the participant who operates the Location Unit that implements the Service Offering" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has provider" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:hasProvider ],
        [ skos:example "'did:web:example.com/serviceOffering/sha256-1', 'did:web:example.com/serviceOffering/sha256-2'" ;
            sh:description "List of references of Service Offering that may be hosted on this location" ;
            sh:minCount 1 ;
            sh:name "can host service offering" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:canHostServiceOffering ],
        [ skos:example "'FR-39', 'DE-BE'" ;
            sh:datatype xsd:string ;
            sh:description "ISO 3166-2 5 digit string for location" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has administrative location" ;
            sh:order 3 ;
            sh:path gx:hasAdministrativeLocation ],
        [ skos:example "'did:web:example.com/locatedServiceOffering/sha256'" ;
            sh:description "Ids of Located Service Offerings on this location" ;
            sh:minCount 1 ;
            sh:name "has located service offering" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path gx:hasLocatedServiceOffering ] ;
    sh:targetClass gx:Location .

gx:NetworkShape a sh:NodeShape ;
    sh:property [ skos:example "'Hybrid', 'gx:PrivateProvisioning'" ;
            sh:datatype xsd:string ;
            sh:description "Provision type of the service" ;
            sh:maxCount 1 ;
            sh:name "provision type" ;
            sh:order 8 ;
            sh:path gx:provisionType ],
        [ skos:example "'(reference to endpoint)'" ;
            sh:description "Endpoint through which the Service Offering can be accessed" ;
            sh:name "endpoint" ;
            sh:node gx:EndpointShape ;
            sh:order 9 ;
            sh:path gx:endpoint ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of participant self-descrription providing this service offering." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "provided by" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:providedBy ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of resource self-escription related to the service and that can exist independently of it." ;
            sh:name "aggregation of" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:aggregationOf ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of the service offering self-description related to the service and that can exist independently of it." ;
            sh:name "depends on" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:dependsOn ],
        [ skos:example "'virtual', 'bare-metal', 'mixed'" ;
            sh:datatype xsd:string ;
            sh:description "Type of Service Offering. Choose one of the following: virtual, bare-metal, mixed" ;
            sh:maxCount 1 ;
            sh:name "service type" ;
            sh:order 1 ;
            sh:path gx:serviceType ],
        [ skos:example "'floating', 'fixed', 'provider-network'" ;
            sh:datatype xsd:string ;
            sh:description "Defines how public IP address are provided. Floating: floating ips are supported ." ;
            sh:maxCount 1 ;
            sh:name "public ip address provisioning" ;
            sh:order 2 ;
            sh:path gx:publicIpAddressProvisioning ],
        [ skos:example "'ipV6', 'IPv4'" ;
            sh:datatype xsd:string ;
            sh:description "Version of IP address supported. IPv4: only ipV4 addresses are supported. IPv6: both version iIPV4 and IPv6 are supported." ;
            sh:maxCount 1 ;
            sh:name "ip version" ;
            sh:order 3 ;
            sh:path gx:ipVersion ],
        [ skos:example "'virtual', 'physical'" ;
            sh:datatype xsd:string ;
            sh:description "Default: virtual. How networks of different tenants are separated." ;
            sh:maxCount 1 ;
            sh:name "tenant separation" ;
            sh:order 4 ;
            sh:path gx:tenantSeparation ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "a resolvable link to the Terms and Conditions applying to that service." ;
            sh:minCount 1 ;
            sh:name "terms and conditions" ;
            sh:node gx:TermsAndConditionsShape ;
            sh:order 1 ;
            sh:path gx:termsAndConditions ],
        [ skos:example "' '" ;
            sh:datatype xsd:string ;
            sh:description "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
            sh:minCount 1 ;
            sh:name "policy" ;
            sh:order 2 ;
            sh:path gx:policy ],
        [ skos:example "'GDPR2016', 'LGPD2019'" ;
            sh:datatype xsd:string ;
            sh:description "a list of data protection regime from the list available below" ;
            sh:name "data protection regime" ;
            sh:order 3 ;
            sh:path gx:dataProtectionRegime ],
        [ skos:example "' '" ;
            sh:description "a list of methods to export data out of the service" ;
            sh:minCount 1 ;
            sh:name "data account export" ;
            sh:node gx:DataAccountExportShape ;
            sh:order 4 ;
            sh:path gx:dataAccountExport ],
        [ skos:example "'Image classification ML service'" ;
            sh:datatype xsd:string ;
            sh:description "A human readable name of the component" ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 5 ;
            sh:path gx:name ],
        [ skos:example "'An ML service for training, deploying and improving image classifiers.'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language" ;
            sh:maxCount 1 ;
            sh:name "description" ;
            sh:order 6 ;
            sh:path dct:description ],
        [ skos:example "'ML', 'Classification'" ;
            sh:datatype xsd:string ;
            sh:description "Keywords that describe / tag the service." ;
            sh:name "keyword" ;
            sh:order 7 ;
            sh:path dcat:keyword ] ;
    sh:targetClass gx:Network .

gx:NetworkingDeviceShape a sh:NodeShape ;
    sh:property [ skos:example "'no', 'yes'" ;
            sh:datatype xsd:string ;
            sh:description "A dedicated port for management tasks." ;
            sh:name "management port" ;
            sh:order 1 ;
            sh:path gx:managementPort ],
        [ skos:example "'no', 'yes'" ;
            sh:datatype xsd:string ;
            sh:description "A dedicated port for console tasks." ;
            sh:name "console port" ;
            sh:order 2 ;
            sh:path gx:consolePort ],
        [ skos:example "'10GE', '100GE'" ;
            sh:datatype xsd:float ;
            sh:description "The assigned capacity of ports." ;
            sh:name "port capacity_ a" ;
            sh:order 3 ;
            sh:path gx:portCapacity_A ],
        [ skos:example "'10', '1'" ;
            sh:datatype xsd:integer ;
            sh:description "The assigned number of ports." ;
            sh:name "port capacity_ a_ count" ;
            sh:order 4 ;
            sh:path gx:portCapacity_A_Count ],
        [ skos:example "'yes', 'no'" ;
            sh:datatype xsd:string ;
            sh:description "Availability of redundant power supply for the cases of emergency." ;
            sh:name "redundant power supply" ;
            sh:order 5 ;
            sh:path gx:redundantPowerSupply ],
        [ skos:example "'2Gb'" ;
            sh:description "Ram size of the networking device" ;
            sh:name "ram size" ;
            sh:node gx:MeasureShape ;
            sh:order 6 ;
            sh:path gx:ramSize ],
        [ skos:example "'1'" ;
            sh:description "Number of available CPUs." ;
            sh:name "cpu count" ;
            sh:node gx:MeasureShape ;
            sh:order 7 ;
            sh:path gx:cpuCount ],
        [ skos:example "'switch, router, repetear'" ;
            sh:datatype xsd:string ;
            sh:description "Type of networking device" ;
            sh:name "type" ;
            sh:order 8 ;
            sh:path gx:type ],
        [ skos:example "'IP', 'IRP'" ;
            sh:datatype xsd:string ;
            sh:description "List of  supported protocols among used layers should be specified." ;
            sh:name "supported protocols" ;
            sh:order 9 ;
            sh:path gx:supportedProtocols ],
        [ skos:example "'192.168.24.2/32'" ;
            sh:datatype xsd:float ;
            sh:description "IP address of the netowrking device" ;
            sh:name "network adress" ;
            sh:order 10 ;
            sh:path gx:networkAdress ] ;
    sh:targetClass gx:NetworkingDevice .

gx:NodeShape a sh:NodeShape ;
    sh:property [ skos:example "'a structured object of type cpu, e.g. CPU:numberOfCores=4, CPU:frequency:value=3.0 and CPU:frequency:measure:unit=GHz'" ;
            sh:description "Description of CPU(s) of this node" ;
            sh:name "cpu" ;
            sh:node gx:CPUShape ;
            sh:order 1 ;
            sh:path gx:cpu ],
        [ skos:example "'a structured object of type gpu, e.g. GPU:memoryType=DDR6, GPU:memorySize:value=24 and GPU:memorySize:value:unit=GB'" ;
            sh:description "Description of GPU(s) of this node." ;
            sh:name "gpu" ;
            sh:node gx:GPUShape ;
            sh:order 2 ;
            sh:path gx:gpu ],
        [ skos:example "'a structured object of type measure, e.g. measure:value=950 and measure:unit=GB'" ;
            sh:description "Size of RAM of this node" ;
            sh:name "ramsize" ;
            sh:node gx:MeasureShape ;
            sh:order 3 ;
            sh:path gx:ramsize ],
        [ skos:example "'a structured object of type harddrive, e.g. harddrive:productid=6CX68AV, and harddrive:name=Xeon Platinum 8280,and harddrive:manufacture=NVIDA; harddrive:size:value=1000, harddrive:size:unit=GB, and harddrive:type=SSD'" ;
            sh:description "Description of disk(s) of this nodes" ;
            sh:name "disk" ;
            sh:node gx:DiskShape ;
            sh:order 4 ;
            sh:path gx:disk ],
        [ skos:example "'a structured object of type measure, e.g. measure:value=10 and measure:unit=GBase-T'" ;
            sh:description "Description of network interface card(s) of this node" ;
            sh:name "nic" ;
            sh:node gx:MeasureShape ;
            sh:order 5 ;
            sh:path gx:nic ] ;
    sh:targetClass gx:Node .

gx:ObjectStorageShape a sh:NodeShape ;
    sh:property [ skos:example "'ML', 'Classification'" ;
            sh:datatype xsd:string ;
            sh:description "Keywords that describe / tag the service." ;
            sh:name "keyword" ;
            sh:order 7 ;
            sh:path dcat:keyword ],
        [ skos:example "'Hybrid', 'gx:PrivateProvisioning'" ;
            sh:datatype xsd:string ;
            sh:description "Provision type of the service" ;
            sh:maxCount 1 ;
            sh:name "provision type" ;
            sh:order 8 ;
            sh:path gx:provisionType ],
        [ skos:example "'(reference to endpoint)'" ;
            sh:description "Endpoint through which the Service Offering can be accessed" ;
            sh:name "endpoint" ;
            sh:node gx:EndpointShape ;
            sh:order 9 ;
            sh:path gx:endpoint ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of participant self-descrription providing this service offering." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "provided by" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:providedBy ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of resource self-escription related to the service and that can exist independently of it." ;
            sh:name "aggregation of" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:aggregationOf ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of the service offering self-description related to the service and that can exist independently of it." ;
            sh:name "depends on" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:dependsOn ],
        [ skos:example "'FAT32', 'NTFS'" ;
            sh:datatype xsd:string ;
            sh:description "File system of storage services provides." ;
            sh:maxCount 1 ;
            sh:name "file system" ;
            sh:order 1 ;
            sh:path gx:fileSystem ],
        [ skos:example "'virtual', 'bare-metal', 'mixed'" ;
            sh:datatype xsd:string ;
            sh:description "Type of Service Offering. Choose one of the following: virtual, bare-metal, mixed" ;
            sh:maxCount 1 ;
            sh:name "service type" ;
            sh:order 1 ;
            sh:path gx:serviceType ],
        [ skos:example "'None', 'managed', 'byok', 'hyok'" ;
            sh:datatype xsd:string ;
            sh:description "Default: None. Define encryption method of storage service. None: means no encryption art all. managed: Virtual storage is encrypted by key managed provider. byok: Virtual storage  " ;
            sh:maxCount 1 ;
            sh:name "encryption method" ;
            sh:order 2 ;
            sh:path gx:encryptionMethod ],
        [ skos:example "'True', 'False'" ;
            sh:datatype xsd:boolean ;
            sh:description "Default: False. True is storage service supports snapshots." ;
            sh:maxCount 1 ;
            sh:name "snapshot supported" ;
            sh:order 3 ;
            sh:path gx:snapshotSupported ],
        [ skos:example "'True', 'False'" ;
            sh:datatype xsd:boolean ;
            sh:description "Default: False. True is storage service supports backus." ;
            sh:maxCount 1 ;
            sh:name "backups supported" ;
            sh:order 4 ;
            sh:path gx:backupsSupported ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "a resolvable link to the Terms and Conditions applying to that service." ;
            sh:minCount 1 ;
            sh:name "terms and conditions" ;
            sh:node gx:TermsAndConditionsShape ;
            sh:order 1 ;
            sh:path gx:termsAndConditions ],
        [ skos:example "' '" ;
            sh:datatype xsd:string ;
            sh:description "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
            sh:minCount 1 ;
            sh:name "policy" ;
            sh:order 2 ;
            sh:path gx:policy ],
        [ skos:example "'GDPR2016', 'LGPD2019'" ;
            sh:datatype xsd:string ;
            sh:description "a list of data protection regime from the list available below" ;
            sh:name "data protection regime" ;
            sh:order 3 ;
            sh:path gx:dataProtectionRegime ],
        [ skos:example "' '" ;
            sh:description "a list of methods to export data out of the service" ;
            sh:minCount 1 ;
            sh:name "data account export" ;
            sh:node gx:DataAccountExportShape ;
            sh:order 4 ;
            sh:path gx:dataAccountExport ],
        [ skos:example "'Image classification ML service'" ;
            sh:datatype xsd:string ;
            sh:description "A human readable name of the component" ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 5 ;
            sh:path gx:name ],
        [ skos:example "'An ML service for training, deploying and improving image classifiers.'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language" ;
            sh:maxCount 1 ;
            sh:name "description" ;
            sh:order 6 ;
            sh:path dct:description ] ;
    sh:targetClass gx:ObjectStorage .

