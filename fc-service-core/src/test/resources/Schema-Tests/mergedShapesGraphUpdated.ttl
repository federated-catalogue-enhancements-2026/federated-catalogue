gx:ThirdPartyComplianceCertificateClaimShape a sh:NodeShape ;
    sh:property [ skos:example "'https://company-a.com/self-descriptions/cab.jsonld'" ;
            sh:description "Id of the Participant (self-description) endorsed having a Compliance Assessment Body role that claims the compliance" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has compliance assessment body" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:hasComplianceAssessmentBody ],
        [ skos:example "'https://company-a.com/self-descriptions/compliance-cert-scheme-iso27001.jsonld'" ;
            sh:description "ID of the Compliance Certification Scheme (self-description) involved in the certification" ;
            sh:maxCount 1 ;
            sh:name "has compliance certification scheme" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:hasComplianceCertificationScheme ],
        [ skos:example "'https://company-a.com/self-descriptions/service-offering-iaas.jsonld'" ;
            sh:description "ID of the Service Offering (self-description) certified for the compliance" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has service offering" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:hasServiceOffering ] ;
    sh:targetClass gx:ThirdPartyComplianceCertificateClaim .

gx:ThirdPartyComplianceCertificateCredentialShape a sh:NodeShape ;
    sh:property [ skos:example "'https://company-a.com/self-descriptions/cab.jsonld'" ;
            sh:description "Id of the claim to be signed in a verifiable credential build with all the information that are bound in the claim. In case of third party credential the id is the id of the third party" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "credential subject" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:credentialSubject ],
        [ skos:example "'https://company-a.com/self-descriptions/cab.jsonld'" ;
            sh:description "ID of the claim to be signed in a verifiable credential build with all the information that are bound in the claim. In case of third party credential the ID is the ID of the third party" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "credential subject" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:credentialSubject ] ;
    sh:targetClass gx:ThirdPartyComplianceCertificateCredential .

gx:ThirdPartyComplianceCertificationSchemeShape a sh:NodeShape ;
    sh:property [ skos:example "'https://company-a.com/self-descriptions/cab.jsonld'" ;
            sh:description "Unordered list of IDs of ComplianceAssessmentBody (participant) endorsed having a Compliance Assessment Body role by the Compliance Reference. This unordered list is managed and validated by the Compliance Reference Manager" ;
            sh:minCount 1 ;
            sh:name "has compliance assessment bodies" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:hasComplianceAssessmentBodies ],
        [ skos:example "'https://company-a.com/self-descriptions/compliance-ref-iso27001.jsonld'" ;
            sh:description "ID of Compliance Reference (self-description) to be certified by any means defined in the Certification Scheme" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has compliance reference" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:hasComplianceReference ],
        [ skos:example "'https://company-a.com/self-descriptions/compliance-ref-iso27001.jsonld'" ;
            sh:description "ID of Compliance Criterion Combination granted by the scheme in case of certification" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "grants compliance criteria combination" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:grantsComplianceCriteriaCombination ] ;
    sh:targetClass gx:ThirdPartyComplianceCertificationScheme .

gx:VerifiableCredentialWalletShape a sh:NodeShape ;
    sh:property [ skos:example "'https://gaia-x.eu'" ;
            sh:datatype xsd:string ;
            sh:description "a list of machine readable format used to export verifiable credentials." ;
            sh:minCount 1 ;
            sh:name "verifiable credential export format" ;
            sh:order 1 ;
            sh:path gx:verifiableCredentialExportFormat ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:datatype xsd:string ;
            sh:description "a list of machine readable format used to export private keys." ;
