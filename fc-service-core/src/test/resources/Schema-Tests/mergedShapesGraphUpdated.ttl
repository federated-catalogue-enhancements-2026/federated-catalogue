@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gx: <https://w3id.org/gaia-x/2511#> .

gx:BigDataShape a sh:NodeShape ;
    sh:property [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of the service offering self-description related to the service and that can exist independently of it." ;
            sh:name "depends on" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:dependsOn ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "a resolvable link to the Terms and Conditions applying to that service." ;
            sh:minCount 1 ;
            sh:name "terms and conditions" ;
            sh:node gx:TermsAndConditionsShape ;
            sh:order 1 ;
            sh:path gx:termsAndConditions ],
        [ skos:example "' '" ;
            sh:datatype xsd:string ;
            sh:description "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
            sh:minCount 1 ;
            sh:name "policy" ;
            sh:order 2 ;
            sh:path gx:policy ],
        [ skos:example "'GDPR2016', 'LGPD2019'" ;
            sh:datatype xsd:string ;
            sh:description "a list of data protection regime from the list available below" ;
            sh:name "data protection regime" ;
            sh:order 3 ;
            sh:path gx:dataProtectionRegime ],
        [ skos:example "' '" ;
            sh:description "a list of methods to export data out of the service" ;
            sh:minCount 1 ;
            sh:name "data account export" ;
            sh:node gx:DataAccountExportShape ;
            sh:order 4 ;
            sh:path gx:dataAccountExport ],
        [ skos:example "'Image classification ML service'" ;
            sh:datatype xsd:string ;
            sh:description "A human readable name of the component" ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 5 ;
            sh:path gx:name ],
        [ skos:example "'An ML service for training, deploying and improving image classifiers.'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language" ;
            sh:maxCount 1 ;
            sh:name "description" ;
            sh:order 6 ;
            sh:path dct:description ],
        [ skos:example "'ML', 'Classification'" ;
            sh:datatype xsd:string ;
            sh:description "Keywords that describe / tag the service." ;
            sh:name "keyword" ;
            sh:order 7 ;
            sh:path dcat:keyword ],
        [ skos:example "'Hybrid', 'gx:PrivateProvisioning'" ;
            sh:datatype xsd:string ;
            sh:description "Provision type of the service" ;
            sh:maxCount 1 ;
            sh:name "provision type" ;
            sh:order 8 ;
            sh:path gx:provisionType ],
        [ skos:example "'(reference to endpoint)'" ;
            sh:description "Endpoint through which the Service Offering can be accessed" ;
            sh:name "endpoint" ;
            sh:node gx:EndpointShape ;
            sh:order 9 ;
            sh:path gx:endpoint ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of participant self-descrription providing this service offering." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "provided by" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:providedBy ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of resource self-escription related to the service and that can exist independently of it." ;
            sh:name "aggregation of" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:aggregationOf ] ;
    sh:targetClass gx:BigData .

gx:BlockStorageShape a sh:NodeShape ;
    sh:property [ skos:example "'ML', 'Classification'" ;
            sh:datatype xsd:string ;
            sh:description "Keywords that describe / tag the service." ;
            sh:name "keyword" ;
            sh:order 7 ;
            sh:path dcat:keyword ],
        [ skos:example "'Hybrid', 'gx:PrivateProvisioning'" ;
            sh:datatype xsd:string ;
            sh:description "Provision type of the service" ;
            sh:maxCount 1 ;
            sh:name "provision type" ;
            sh:order 8 ;
            sh:path gx:provisionType ],
        [ skos:example "'(reference to endpoint)'" ;
            sh:description "Endpoint through which the Service Offering can be accessed" ;
            sh:name "endpoint" ;
            sh:node gx:EndpointShape ;
            sh:order 9 ;
            sh:path gx:endpoint ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of participant self-descrription providing this service offering." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "provided by" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:providedBy ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of resource self-escription related to the service and that can exist independently of it." ;
            sh:name "aggregation of" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:aggregationOf ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of the service offering self-description related to the service and that can exist independently of it." ;
            sh:name "depends on" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:dependsOn ],
        [ skos:example "'local-fast', 'remote-fast', 'remote-standard'" ;
            sh:description "List of volume types supported by this block storage" ;
            sh:maxCount 1 ;
            sh:name "volume types" ;
            sh:node gx:VolumeTypeShape ;
            sh:order 1 ;
            sh:path gx:volumeTypes ],
        [ skos:example "'virtual', 'bare-metal', 'mixed'" ;
            sh:datatype xsd:string ;
            sh:description "Type of Service Offering. Choose one of the following: virtual, bare-metal, mixed" ;
            sh:maxCount 1 ;
            sh:name "service type" ;
            sh:order 1 ;
            sh:path gx:serviceType ],
        [ skos:example "'None', 'managed', 'byok', 'hyok'" ;
            sh:datatype xsd:string ;
            sh:description "Default: None. Define encryption method of storage service. None: means no encryption art all. managed: Virtual storage is encrypted by key managed provider. byok: Virtual storage  " ;
            sh:maxCount 1 ;
            sh:name "encryption method" ;
            sh:order 2 ;
            sh:path gx:encryptionMethod ],
        [ skos:example "'True', 'False'" ;
            sh:datatype xsd:boolean ;
            sh:description "Default: False. True is storage service supports snapshots." ;
            sh:maxCount 1 ;
            sh:name "snapshot supported" ;
            sh:order 3 ;
            sh:path gx:snapshotSupported ],
        [ skos:example "'True', 'False'" ;
            sh:datatype xsd:boolean ;
            sh:description "Default: False. True is storage service supports backus." ;
            sh:maxCount 1 ;
            sh:name "backups supported" ;
            sh:order 4 ;
            sh:path gx:backupsSupported ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "a resolvable link to the Terms and Conditions applying to that service." ;
            sh:minCount 1 ;
            sh:name "terms and conditions" ;
            sh:node gx:TermsAndConditionsShape ;
            sh:order 1 ;
            sh:path gx:termsAndConditions ],
        [ skos:example "' '" ;
            sh:datatype xsd:string ;
            sh:description "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
            sh:minCount 1 ;
            sh:name "policy" ;
            sh:order 2 ;
            sh:path gx:policy ],
        [ skos:example "'GDPR2016', 'LGPD2019'" ;
            sh:datatype xsd:string ;
            sh:description "a list of data protection regime from the list available below" ;
            sh:name "data protection regime" ;
            sh:order 3 ;
            sh:path gx:dataProtectionRegime ],
        [ skos:example "' '" ;
            sh:description "a list of methods to export data out of the service" ;
            sh:minCount 1 ;
            sh:name "data account export" ;
            sh:node gx:DataAccountExportShape ;
            sh:order 4 ;
            sh:path gx:dataAccountExport ],
        [ skos:example "'Image classification ML service'" ;
            sh:datatype xsd:string ;
            sh:description "A human readable name of the component" ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 5 ;
            sh:path gx:name ],
        [ skos:example "'An ML service for training, deploying and improving image classifiers.'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language" ;
            sh:maxCount 1 ;
            sh:name "description" ;
            sh:order 6 ;
            sh:path dct:description ] ;
    sh:targetClass gx:BlockStorage .

gx:CatalogueShape a sh:NodeShape ;
    sh:property [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of resource self-escription related to the service and that can exist independently of it." ;
            sh:name "aggregation of" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:aggregationOf ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of the service offering self-description related to the service and that can exist independently of it." ;
            sh:name "depends on" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:dependsOn ],
        [ skos:example "''" ;
            sh:datatype xsd:string ;
            sh:description "A route used to synchronize catalogues and retrieve the list of Verifiable Credentials (issuer, id)." ;
            sh:minCount 1 ;
            sh:name "get verifiable credentials i ds" ;
            sh:order 1 ;
            sh:path gx:getVerifiableCredentialsIDs ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "a resolvable link to the Terms and Conditions applying to that service." ;
            sh:minCount 1 ;
            sh:name "terms and conditions" ;
            sh:node gx:TermsAndConditionsShape ;
            sh:order 1 ;
            sh:path gx:termsAndConditions ],
        [ skos:example "' '" ;
            sh:datatype xsd:string ;
            sh:description "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
            sh:minCount 1 ;
            sh:name "policy" ;
            sh:order 2 ;
            sh:path gx:policy ],
        [ skos:example "'GDPR2016', 'LGPD2019'" ;
            sh:datatype xsd:string ;
            sh:description "a list of data protection regime from the list available below" ;
            sh:name "data protection regime" ;
            sh:order 3 ;
            sh:path gx:dataProtectionRegime ],
        [ skos:example "' '" ;
            sh:description "a list of methods to export data out of the service" ;
            sh:minCount 1 ;
            sh:name "data account export" ;
            sh:node gx:DataAccountExportShape ;
            sh:order 4 ;
            sh:path gx:dataAccountExport ],
        [ skos:example "'Image classification ML service'" ;
            sh:datatype xsd:string ;
            sh:description "A human readable name of the component" ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 5 ;
            sh:path gx:name ],
        [ skos:example "'An ML service for training, deploying and improving image classifiers.'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language" ;
            sh:maxCount 1 ;
            sh:name "description" ;
            sh:order 6 ;
            sh:path dct:description ],
        [ skos:example "'ML', 'Classification'" ;
            sh:datatype xsd:string ;
            sh:description "Keywords that describe / tag the service." ;
            sh:name "keyword" ;
            sh:order 7 ;
            sh:path dcat:keyword ],
        [ skos:example "'Hybrid', 'gx:PrivateProvisioning'" ;
            sh:datatype xsd:string ;
            sh:description "Provision type of the service" ;
            sh:maxCount 1 ;
            sh:name "provision type" ;
            sh:order 8 ;
            sh:path gx:provisionType ],
        [ skos:example "'(reference to endpoint)'" ;
            sh:description "Endpoint through which the Service Offering can be accessed" ;
            sh:name "endpoint" ;
            sh:node gx:EndpointShape ;
            sh:order 9 ;
            sh:path gx:endpoint ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of participant self-descrription providing this service offering." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "provided by" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:providedBy ] ;
    sh:targetClass gx:Catalogue .

gx:ComplianceAssessmentBodyShape a sh:NodeShape ;
    sh:property [ skos:example "'did:web:compliance.gaia-x.eu/3rdPartyComplianceCertScheme/sha256#1', 'did:web:compliance.gaia-x.eu/3rdPartyComplianceCertScheme/sha256#2'" ;
            sh:description "IDs of the Third Party Compliance Certification Scheme this Compliance Assessment Body can certify." ;
            sh:minCount 1 ;
            sh:name "can certify third party compliance certification scheme" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:canCertifyThirdPartyComplianceCertificationScheme ],
        [ skos:example "'did:web:compliance.gaia-x.eu/complianceCertClaim/sha256#1', 'did:web:compliance.gaia-x.eu/complianceCertClaim/sha256#2'" ;
            sh:description "IDs of Certificate claims issued by this Compliance Assessment Body." ;
            sh:minCount 1 ;
            sh:name "has third party compliance certificate claim" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:hasThirdPartyComplianceCertificateClaim ],
        [ skos:example "'did:web:compliance.gaia-x.eu/complianceVC/sha256#1', 'did:web:compliance.gaia-x.eu/complianceVC/sha256#2'" ;
            sh:description "IDs of the Certificate claims VC certified by this Compliance Assessment Body." ;
            sh:minCount 1 ;
            sh:name "has third party compliance credential" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:hasThirdPartyComplianceCredential ] ;
    sh:targetClass gx:ComplianceAssessmentBody .

gx:ComplianceCertificateClaimShape a sh:NodeShape ;
    sh:property [ skos:example "'https://company-a.com/self-descriptions/compliance-cert-scheme-iso27001.jsonld'" ;
            sh:description "ID of the Compliance Certification Scheme (self-description) involved in the certification" ;
            sh:maxCount 1 ;
            sh:name "has compliance certification scheme" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:hasComplianceCertificationScheme ],
        [ skos:example "'https://company-a.com/self-descriptions/service-offering-iaas.jsonld'" ;
            sh:description "ID of the Service Offering (self-description) certified for the compliance" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has service offering" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:hasServiceOffering ] ;
    sh:targetClass gx:ComplianceCertificateClaim .

gx:ComplianceCertificateCredentialShape a sh:NodeShape ;
    sh:property [ skos:example "'https://company-a.com/self-descriptions/cab.jsonld'" ;
            sh:description "ID of the claim to be signed in a verifiable credential build with all the information that are bound in the claim. In case of third party credential the ID is the ID of the third party" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "credential subject" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:credentialSubject ] ;
    sh:targetClass gx:ComplianceCertificateCredential .

gx:ComplianceCertificationSchemeShape a sh:NodeShape ;
    sh:property [ skos:example "'https://company-a.com/self-descriptions/compliance-ref-iso27001.jsonld'" ;
            sh:description "ID of Compliance Reference (self-description) to be certified by any means defined in the Certification Scheme" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has compliance reference" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:hasComplianceReference ],
        [ skos:example "'https://company-a.com/self-descriptions/compliance-ref-iso27001.jsonld'" ;
            sh:description "ID of Compliance Criterion Combination granted by the scheme in case of certification" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "grants compliance criteria combination" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:grantsComplianceCriteriaCombination ] ;
    sh:targetClass gx:ComplianceCertificationScheme .

gx:ComplianceCriteriaCombinationShape a sh:NodeShape ;
    sh:property [ skos:example "'Gaia-X Criteria Combination #1'" ;
            sh:datatype xsd:string ;
            sh:description "Name of the Gaia-X criteria combination" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has name" ;
            sh:order 1 ;
            sh:path gx:hasName ],
        [ skos:example "'Gaia-X'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language" ;
            sh:maxCount 1 ;
            sh:name "has description" ;
            sh:order 2 ;
            sh:path dct:hasDescription ],
        [ skos:example "'22/04 or 2022/04/12 or 1.5.34 or built 240344'" ;
            sh:description "List of Required Criteria to be granted for the label or list of granted Criteria by the compliance. All the Criteria have to be granted (logic AND)" ;
            sh:minCount 1 ;
            sh:name "required or granted criteria" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:requiredOrGrantedCriteria ] ;
    sh:targetClass gx:ComplianceCriteriaCombination .

gx:ComplianceCriterionShape a sh:NodeShape ;
    sh:property [ skos:example "'Gaia-X C1/L1'" ;
            sh:datatype xsd:string ;
            sh:description "Name of the Gaia-X Criterion" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has name" ;
            sh:order 1 ;
            sh:path gx:hasName ],
        [ skos:example "'Gaia-X'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language of the Gaia-X Criterion as defined in TF document" ;
            sh:maxCount 1 ;
            sh:name "has description" ;
            sh:order 2 ;
            sh:path dct:hasDescription ],
        [ skos:example "'1', '2', '3'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language of the Label level. The level ordering is done by alphanumeric order." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has level" ;
            sh:order 3 ;
            sh:path gx:hasLevel ] ;
    sh:targetClass gx:ComplianceCriterion .

gx:ComplianceLabelShape a sh:NodeShape ;
    sh:property [ skos:example "'Gaia-X GDPR Trusted Label'" ;
            sh:datatype xsd:string ;
            sh:description "Name of the Gaia-X Label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has name" ;
            sh:order 1 ;
            sh:path gx:hasName ],
        [ skos:example "'Gaia-X'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language of the Gaia-X Label as defined in TF document" ;
            sh:maxCount 1 ;
            sh:name "has description" ;
            sh:order 2 ;
            sh:path dct:hasDescription ],
        [ skos:example "'1', '2', '3'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language of the Gaia-X Label Level as defined in TF document" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has level" ;
            sh:order 3 ;
            sh:path gx:hasLevel ],
        [ skos:example "'1', '2', '3'" ;
            sh:description "List of Criteria Combinations. If one of these Combinations is valid the Label is Granted" ;
            sh:minCount 1 ;
            sh:name "has required criteria combinations" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path gx:hasRequiredCriteriaCombinations ] ;
    sh:targetClass gx:ComplianceLabel .

gx:ComplianceReferenceManagerShape a sh:NodeShape ;
    sh:property [ skos:example "'https://company-a.com/self-descriptions/comp-ref1.jsonld'" ;
            sh:description "Unordered list of Ids of ComplianceReferences (self-description) managed by this ComplianceReferenceManager" ;
            sh:minCount 1 ;
            sh:name "has compliance references" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:hasComplianceReferences ] ;
    sh:targetClass gx:ComplianceReferenceManager .

gx:ComplianceReferenceShape a sh:NodeShape ;
    sh:property [ skos:example "'https://www.iso.org/iso-27001.pdf'" ;
            sh:datatype xsd:anyURI ;
            sh:description "URI to reference the content of the compliance reference in a single PDF file" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has reference url" ;
            sh:order 1 ;
            sh:path gx:hasReferenceUrl ],
        [ skos:example "'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad'" ;
            sh:datatype xsd:string ;
            sh:description "SHA256 of PDF document referenced by hasReferenceUrl." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has sha256" ;
            sh:order 2 ;
            sh:path gx:hasSha256 ],
        [ skos:example "'ISO 27001'" ;
            sh:datatype xsd:string ;
            sh:description "Name of the Compliance Reference" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has compliance reference title" ;
            sh:order 3 ;
            sh:path gx:hasComplianceReferenceTitle ],
        [ skos:example "'Information security management system standards.'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language" ;
            sh:maxCount 1 ;
            sh:name "has description" ;
            sh:order 4 ;
            sh:path dct:hasDescription ],
        [ skos:example "'https://company-a.com/self-descriptions/compliance-ref-manager.jsonld'" ;
            sh:description "ID of Participant (self-description) in charge of managing this Compliance Reference" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "has compliance reference manager" ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path gx:hasComplianceReferenceManager ],
        [ skos:example "'22/04 or 2022/04/12 or 1.5.34 or built 240344'" ;
            sh:datatype xsd:string ;
            sh:description "versioning according to [semver](https://semver.org/)." ;
            sh:maxCount 1 ;
            sh:name "has version" ;
            sh:order 6 ;
            sh:path gx:hasVersion ],
        [ skos:example "'22/04 or 2022/04/12 or 1.5.34 or built 240344'" ;
            sh:datatype xsd:dateTime ;
            sh:description "Indicates the first date when the compliance reference goes into effect" ;
            sh:maxCount 1 ;
            sh:name "c r valid from" ;
            sh:order 7 ;
            sh:path gx:cRValidFrom ],
        [ skos:example "'22/04 or 2022/04/12 or 1.5.34 or built 240344'" ;
            sh:datatype xsd:dateTime ;
            sh:description "Indicates the last date when the compliance reference is no more into effect" ;
            sh:maxCount 1 ;
            sh:name "c r valid until" ;
            sh:order 8 ;
            sh:path gx:cRValidUntil ],
        [ skos:example "'did:web:compliance.cispe.org/coc/gdpr/thirdparty#1'" ;
            sh:description "List of schemes that grants certification. This list is managed by a reference manager." ;
            sh:minCount 1 ;
            sh:name "has compliance certification schemes" ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path gx:hasComplianceCertificationSchemes ] ;
    sh:targetClass gx:ComplianceReference .

gx:ComputeShape a sh:NodeShape ;
    sh:property [ skos:example "'Image classification ML service'" ;
            sh:datatype xsd:string ;
            sh:description "A human readable name of the component" ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 5 ;
            sh:path gx:name ],
        [ skos:example "'An ML service for training, deploying and improving image classifiers.'" ;
            sh:datatype xsd:string ;
            sh:description "A description in natural language" ;
            sh:maxCount 1 ;
            sh:name "description" ;
            sh:order 6 ;
            sh:path dct:description ],
        [ skos:example "'ML', 'Classification'" ;
            sh:datatype xsd:string ;
            sh:description "Keywords that describe / tag the service." ;
            sh:name "keyword" ;
            sh:order 7 ;
            sh:path dcat:keyword ],
        [ skos:example "'Hybrid', 'gx:PrivateProvisioning'" ;
            sh:datatype xsd:string ;
            sh:description "Provision type of the service" ;
            sh:maxCount 1 ;
            sh:name "provision type" ;
            sh:order 8 ;
            sh:path gx:provisionType ],
        [ skos:example "'(reference to endpoint)'" ;
            sh:description "Endpoint through which the Service Offering can be accessed" ;
            sh:name "endpoint" ;
            sh:node gx:EndpointShape ;
            sh:order 9 ;
            sh:path gx:endpoint ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of participant self-descrription providing this service offering." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "provided by" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gx:providedBy ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of resource self-escription related to the service and that can exist independently of it." ;
            sh:name "aggregation of" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gx:aggregationOf ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "DID of the service offering self-description related to the service and that can exist independently of it." ;
            sh:name "depends on" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gx:dependsOn ],
        [ skos:example "'hw-virtualized', 'sw-virtualized', 'os-virtualized', 'os-hw-virtualized', 'hw-partitioned', 'physical'" ;
            sh:datatype xsd:string ;
            sh:description "Default: virtual. How compute resources of different tenants are separated." ;
            sh:maxCount 1 ;
            sh:name "tenant separation" ;
            sh:order 1 ;
            sh:path gx:tenantSeparation ],
        [ skos:example "'(a structured object of type gx:Flavor)'" ;
            sh:description "Detailed description of available flavors. A flavor describes the size of the server. " ;
            sh:minCount 1 ;
            sh:name "flavor" ;
            sh:node gx:FlavorShape ;
            sh:order 2 ;
            sh:path gx:flavor ],
        [ skos:example "''" ;
            sh:datatype xsd:string ;
            sh:description "lists autoscaling group that this VM belongs to." ;
            sh:maxCount 1 ;
            sh:name "is part of scaling group" ;
            sh:order 3 ;
            sh:path gx:isPartOfScalingGroup ],
        [ skos:example "'(a structured object of type gx:ImageRegistry)'" ;
            sh:description "Reference to image registry of this compute service." ;
            sh:minCount 1 ;
            sh:name "image registry" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path gx:imageRegistry ],
        [ skos:example "'(a structured object of type gx:Network)'" ;
            sh:description "Reference to network service offing for this compute service." ;
            sh:minCount 1 ;
            sh:name "network" ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path gx:network ],
        [ skos:example "'(a structured object of type gx:Storage)'" ;
            sh:description "Reference to storage service offing to create disks used within this compute service." ;
            sh:minCount 1 ;
            sh:name "storage" ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path gx:storage ],
        [ skos:example "'(a structured object of type gx:IdentityAccessManagement)'" ;
            sh:description "Reference to identity access management service  storage service offing to create disks used within this compute service." ;
            sh:minCount 1 ;
            sh:name "identity" ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path gx:identity ],
        [ skos:example "'https://gaia-x.eu'" ;
            sh:description "a resolvable link to the Terms and Conditions applying to that service." ;
            sh:minCount 1 ;
            sh:name "terms and conditions" ;
            sh:node gx:TermsAndConditionsShape ;
            sh:order 1 ;
            sh:path gx:termsAndConditions ],
        [ skos:example "' '" ;
            sh:datatype xsd:string ;
            sh:description "a list of policy expressed using a DSL (e.g., Rego or ODRL)" ;
            sh:minCount 1 ;
            sh:name "policy" ;
            sh:order 2 ;
            sh:path gx:policy ],
        [ skos:example "'GDPR2016', 'LGPD2019'" ;
            sh:datatype xsd:string ;
            sh:description "a list of data protection regime from the list available below" ;
            sh:name "data protection regime" ;
            sh:order 3 ;
            sh:path gx:dataProtectionRegime ],
        [ skos:example "' '" ;
            sh:description "a list of methods to export data out of the service" ;
            sh:minCount 1 ;
            sh:name "data account export" ;
            sh:node gx:DataAccountExportShape ;
            sh:order 4 ;
            sh:path gx:dataAccountExport ] ;
    sh:targetClass gx:Compute .

