gx:GPUShape a sh:NodeShape ;
    sh:property [ skos:example "'Fermi', 'Kepler', 'Gen9'" ;
            sh:datatype xsd:string ;
            sh:description "GPU generation." ;
            sh:maxCount 1 ;
            sh:name "gpu generation" ;
            sh:order 1 ;
            sh:path gx:gpuGeneration ],
        [ skos:example "'a structure object of type measure, e.g. measure:value=24 and measure:unit=GB'" ;
            sh:description "Memory of the GPU" ;
            sh:maxCount 1 ;
            sh:name "memory size" ;
            sh:node gx:MeasureShape ;
            sh:order 2 ;
            sh:path gx:memorySize ],
        [ skos:example "'DDR6'" ;
            sh:datatype xsd:string ;
            sh:description "Memory type of the GPU" ;
            sh:maxCount 1 ;
            sh:name "memory type" ;
            sh:order 3 ;
            sh:path gx:memoryType ],
        [ skos:example "'PCIe Gen4: 64GB/s'" ;
            sh:datatype xsd:string ;
            sh:description "Interconnection of the GPU" ;
            sh:maxCount 1 ;
            sh:name "connection" ;
            sh:order 4 ;
            sh:path gx:connection ],
        [ skos:example "'Fermi', 'Kepler', 'Gen9'" ;
            sh:datatype xsd:string ;
