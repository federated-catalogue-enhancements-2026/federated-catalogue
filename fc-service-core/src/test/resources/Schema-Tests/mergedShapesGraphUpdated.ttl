            sh:maxCount 1 ;
            sh:name "cpu generation" ;
            sh:order 2 ;
            sh:path gx:cpuGeneration ],
        [ skos:example "'fpu', 'vme', 'de', 'pse', 'sse', 'sse2', 'ht', 'vmx', 'smx', 'sse4_1', 'sse4_2', 'avx', '3dnowprefetch', 'ibrs_enhanced', 'ept_ad', 'sgx', 'sgx_lc', 'md_clear', 'arch_capabilities', '...'" ;
