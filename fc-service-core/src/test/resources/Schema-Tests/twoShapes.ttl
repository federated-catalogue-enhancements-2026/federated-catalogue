@prefix dcat:            <http://www.w3.org/ns/dcat#> .
@prefix dct:             <http://purl.org/dc/terms/> .
@prefix did:             <https://www.w3.org/TR/did-core/#> .
@prefix sh:              <http://www.w3.org/ns/shacl#> .
@prefix vcard:           <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd:             <http://www.w3.org/2001/XMLSchema#> .
@prefix gx: <https://w3id.org/gaia-x/2511#> .

gx:DataConnectorShape
        a               sh:NodeShape ;
        sh:property     [ sh:datatype  xsd:string ;
                          sh:maxCount  1 ;
                          sh:minCount  0 ;
                          sh:name      "service title" ;
                          sh:order     5 ;
                          sh:path      gx:serviceTitle
                        ] ;
        sh:property     [ sh:name      "standard conformity" ;
                          sh:nodeKind  sh:IRI ;
                          sh:order     6 ;
                          sh:path      gx:standardConformity
                        ] ;
        sh:property     [ sh:minCount  1 ;
                          sh:name      "physical resource" ;
                          sh:nodeKind  sh:IRI ;
                          sh:order     1 ;
                          sh:path      gx:physicalResource
                        ] ;
        sh:property     [ sh:datatype  xsd:anyURI ;
                          sh:minCount  1 ;
                          sh:name      "policies" ;
                          sh:order     3 ;
                          sh:path      gx:policies
                        ] ;
        sh:property     [ sh:datatype  xsd:string ;
                          sh:maxCount  1 ;
                          sh:minCount  0 ;
                          sh:name      "provision type" ;
                          sh:order     8 ;
                          sh:path      gx:provisionType
                        ] ;
        sh:property     [ sh:datatype  xsd:dateTimeStamp ;
                          sh:name      "creation time" ;
                          sh:order     5 ;
                          sh:path      gx:creationTime
                        ] ;
        sh:property     [ sh:minCount  1 ;
                          sh:name      "virtual resource" ;
                          sh:nodeKind  sh:IRI ;
                          sh:order     2 ;
                          sh:path      gx:virtualResource
                        ] ;
        sh:property     [ sh:datatype  xsd:string ;
                          sh:name      "type" ;
                          sh:order     4 ;
                          sh:path      gx:type
                        ] ;
        sh:property     [ sh:datatype  xsd:anyURI ;
                          sh:minCount  1 ;
                          sh:name      "terms and conditions" ;
                          sh:order     3 ;
                          sh:path      gx:termsAndConditions
                        ] ;
        sh:property     [ sh:datatype  xsd:string ;
                          sh:minCount  0 ;
                          sh:name      "policies" ;
                          sh:order     4 ;
                          sh:path      gx:policies
                        ] ;
        sh:property     [ sh:minCount  0 ;
                          sh:name      "aggregation of" ;
                          sh:nodeKind  sh:IRI ;
                          sh:order     2 ;
                          sh:path      gx:aggregationOf
                        ] ;
        sh:property     [ sh:maxCount  1 ;
                          sh:minCount  1 ;
                          sh:name      "provided by" ;
                          sh:nodeKind  sh:IRI ;
                          sh:order     1 ;
                          sh:path      gx:providedBy
                        ] ;
        sh:property     [ sh:datatype  xsd:string ;
                          sh:minCount  0 ;
                          sh:name      "keyword" ;
                          sh:order     7 ;
                          sh:path      dcat:keyword
                        ] ;
        sh:property     [ sh:name      "depends on" ;
                          sh:nodeKind  sh:IRI ;
                          sh:order     9 ;
                          sh:path      gx:dependsOn
                        ] ;
        sh:property     [ sh:name   "endpoint" ;
                          sh:node   gx:EndpointShape ;
                          sh:order  7 ;
                          sh:path   gx:endpoint
                        ] ;
        sh:property     [ sh:datatype  xsd:string ;
                          sh:maxCount  1 ;
                          sh:minCount  0 ;
                          sh:name      "description" ;
                          sh:order     6 ;
                          sh:path      dct:description
                        ] ;
        sh:targetClass  gx:DataConnector .

gx:PhysicalResourceShape
        a               sh:NodeShape ;
        sh:property     [ sh:minCount  1 ;
                          sh:name      "maintained by" ;
                          sh:nodeKind  sh:IRI ;
                          sh:order     1 ;
                          sh:path      gx:maintainedBy
                        ] ;
        sh:property     [ sh:minCount  0 ;
                          sh:name      "owned by" ;
                          sh:nodeKind  sh:IRI ;
                          sh:order     2 ;
                          sh:path      gx:ownedBy
                        ] ;
        sh:property     [ sh:minCount  0 ;
                          sh:name      "manufactured by" ;
                          sh:nodeKind  sh:IRI ;
                          sh:order     3 ;
                          sh:path      gx:manufacturedBy
                        ] ;
        sh:property     [ sh:datatype  xsd:string ;
                          sh:minCount  1 ;
                          sh:name      "location address" ;
                          sh:order     4 ;
                          sh:path      gx:locationAddress
                        ] ;
        sh:property     [ sh:minCount  0 ;
                          sh:name      "aggregation of" ;
                          sh:nodeKind  sh:IRI ;
                          sh:order     1 ;
                          sh:path      gx:aggregationOf
                        ] ;
        sh:property     [ sh:datatype  xsd:string ;
                          sh:maxCount  1 ;
                          sh:minCount  0 ;
                          sh:name      "name" ;
                          sh:order     2 ;
                          sh:path      gx:name
                        ] ;
        sh:property     [ sh:datatype  xsd:string ;
                          sh:maxCount  1 ;
                          sh:minCount  0 ;
                          sh:name      "description" ;
                          sh:order     3 ;
                          sh:path      dct:description
                        ] ;
        sh:targetClass  gx:PhysicalResource .

gx:EndpointShape
        a               sh:NodeShape ;
        sh:property     [ sh:datatype  xsd:anyURI ;
                          sh:name      " end point u r l" ;
                          sh:order     1 ;
                          sh:path      gx:EndPointURL
                        ] ;
        sh:property     [ sh:name      " standard conformity" ;
                          sh:nodeKind  sh:IRI ;
                          sh:order     2 ;
                          sh:path      gx:StandardConformity
                        ] ;
        sh:property     [ sh:datatype  xsd:anyURI ;
                          sh:name      " endpoint description" ;
                          sh:order     3 ;
                          sh:path      gx:EndpointDescription
                        ] ;
        sh:targetClass  gx:Endpoint .
