@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix did: <https://www.w3.org/TR/did-core/#> .
@prefix gx: <https://w3id.org/gaia-x/2511#> .

gx:InfrastructureShape
a sh:NodeShape ;
sh:targetClass gx:Infrastructure ;
sh:property [ sh:path gx:providedBy ;
sh:name "provided by" ;
sh:order 1 ;
sh:minCount 1 ;
sh:maxCount 1 ;
sh:nodeKind sh:IRI ] ;
sh:property [ sh:path gx:aggregationOf ;
sh:name "aggregation of" ;
sh:order 2 ;
sh:minCount 0 ;
sh:nodeKind sh:IRI ] ;
sh:property [ sh:path gx:termsAndConditions ;
sh:name "terms and conditions" ;
sh:order 3 ;
sh:minCount 1 ;
sh:datatype xsd:anyURI ] ;
sh:property [ sh:path gx:policies ;
sh:name "policies" ;
sh:order 4 ;
sh:minCount 0 ;
sh:datatype xsd:string ] ;
sh:property [ sh:path gx:serviceTitle ;
sh:name "service title" ;
sh:order 5 ;
sh:minCount 0 ;
sh:maxCount 1 ;
sh:datatype xsd:string ] ;
sh:property [ sh:path dct:description ;
sh:name "description" ;
sh:order 6 ;
sh:minCount 0 ;
sh:maxCount 1 ;
sh:datatype xsd:string ] ;
sh:property [ sh:path dcat:keyword ;
sh:name "keyword" ;
sh:order 7 ;
sh:minCount 0 ;
sh:datatype xsd:string ] ;
sh:property [ sh:path gx:provisionType ;
sh:name "provision type" ;
sh:order 8 ;
sh:minCount 0 ;
sh:maxCount 1 ;
sh:datatype xsd:string ] ;
sh:property [ sh:path gx:dependsOn ;
sh:name "depends on" ;
sh:order 9 ;
sh:nodeKind sh:IRI ] ;
.