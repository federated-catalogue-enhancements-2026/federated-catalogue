COMPOSE_PROJECT_NAME = xfsc-fc

### SERVER AND PORTAL CONTAINER PROPERTIES ###
FC_SERVICE_SERVER_DOCKER_CONTEXT=".."
FC_SERVICE_SERVER_DOCKER_TARGET="fc-service-server"
FC_DEMO_PORTAL_DOCKER_CONTEXT=".."
FC_DEMO_PORTAL_DOCKER_TARGET="fc-demo-portal"
# Use lightweight Dockerfile that copies pre-built JARs (no Maven inside Docker).
# Run ./dev.sh build first to create the JARs locally.
FC_DOCKERFILE="Dockerfile.dev"

### KEYCLOCK PROPERTIES ###
PORT_KEYCLOAK=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
PROXY_ADDRESS_FORWARDING=true
AUTH_SERVER_HOST_GATEWAY=127.0.0.1
# Keycloak realm config directory: dev, staging, prod (see keycloak/realms/)
KC_REALM_ENV=dev

### KEYCLOAK ADMIN CONSOLE ###
KEYCLOAK_ADMIN_CONSOLE_URL=http://localhost:8080/admin/gaia-x/console/

### FC SERVER PROPERTIES ###
CI_REGISTRY=ghcr.io/federated-catalogue-enhancements-2026/federated-catalogue/fc-demo-portal:feature-kubernetes
# federated-catalog client secret, gaia-x realm
FC_CLIENT_SECRET=**********

### DB PROPERTIES ###
#DB_NAME=public
DB_USER=postgres
DB_PASS=postgres
DB_URL=jdbc:postgresql://postgres:5432/fed_cat

### GRAPH STORE PROPERTIES ###
GRAPH_STORE_IMPL=neo4j
GRAPH_STORE_URI=bolt://neo4j:7687
GRAPH_STORE_USER=neo4j
GRAPH_STORE_PASSWORD=neo12345

### NATS PROPERTIES ###
NATS_URL=nats://nats:4222

### SIGNATURE VERIFICATION ###
# Mock trust anchor registry on did-server (self-contained, no internet dependency)
FC_TRUST_ANCHOR_URL=https://did-server/api/trustAnchor/chain/file
# Use local DID resolver — uni-res is broken on 2.0.0 ("No consumer for application/did")
FC_SIGNATURE_VERIFIER=local